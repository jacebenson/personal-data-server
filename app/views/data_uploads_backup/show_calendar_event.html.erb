<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📅 Calendar Event Details</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Event information and details</p>
    </div>

    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">
            <%= @calendar_event.summary %>
          </h3>
          <div class="flex space-x-2">
            <% if @calendar_event.start_time > Time.current %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                Upcoming
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                Past
              </span>
            <% end %>

            <% if @calendar_event.all_day? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                All Day
              </span>
            <% end %>

            <% if @calendar_event.recurring? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
                Recurring
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="px-6 py-6">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <!-- Start Time -->
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Start Time</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">
              <% if @calendar_event.all_day? %>
                <%= @calendar_event.start_time.strftime("%B %d, %Y") %> (All Day)
              <% else %>
                <%= @calendar_event.start_time.strftime("%B %d, %Y at %l:%M %p") %>
              <% end %>
            </dd>
          </div>

          <!-- End Time -->
          <% if @calendar_event.end_time.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">End Time</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <% if @calendar_event.all_day? %>
                  <%= @calendar_event.end_time.strftime("%B %d, %Y") %>
                <% else %>
                  <%= @calendar_event.end_time.strftime("%B %d, %Y at %l:%M %p") %>
                <% end %>
                <span class="text-gray-500 dark:text-gray-400">(<%= @calendar_event.duration_text %>)</span>
              </dd>
            </div>
          <% end %>

          <!-- Calendar -->
          <% if @calendar_event.calendar_name.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Calendar</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                  <%= @calendar_event.calendar_name %>
                </span>
              </dd>
            </div>
          <% end %>

          <!-- Location -->
          <% if @calendar_event.location.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Location</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <div class="flex items-center">
                  <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <%= @calendar_event.location %>
                </div>
              </dd>
            </div>
          <% end %>

          <!-- Status -->
          <% if @calendar_event.status.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <% case @calendar_event.status.downcase %>
                <% when "confirmed" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    Confirmed
                  </span>
                <% when "tentative" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                    Tentative
                  </span>
                <% when "cancelled" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                    Cancelled
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                    <%= @calendar_event.status.humanize %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>

          <!-- Categories -->
          <% if @calendar_event.categories.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Categories</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <% @calendar_event.categories.split(", ").each do |category| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 mr-1">
                    <%= category.strip %>
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>

          <!-- Organizer -->
          <% if @calendar_event.organizer_email.present? || @calendar_event.organizer_name.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Organizer</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <% if @calendar_event.organizer_name.present? %>
                  <%= @calendar_event.organizer_name %>
                  <% if @calendar_event.organizer_email.present? %>
                    <span class="text-gray-500 dark:text-gray-400">(<%= @calendar_event.organizer_email %>)</span>
                  <% end %>
                <% elsif @calendar_event.organizer_email.present? %>
                  <%= @calendar_event.organizer_email %>
                <% end %>
              </dd>
            </div>
          <% end %>

          <!-- Attendees -->
          <% if @calendar_event.attendee_emails.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Attendees</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <div class="flex flex-wrap gap-1">
                  <% @calendar_event.attendee_emails.split(", ").each do |attendee| %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                      <%= attendee.strip %>
                    </span>
                  <% end %>
                </div>
              </dd>
            </div>
          <% end %>

          <!-- Recurrence Rule -->
          <% if @calendar_event.recurrence_rule.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Recurrence</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <code class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded text-xs font-mono">
                  <%= @calendar_event.recurrence_rule %>
                </code>
              </dd>
            </div>
          <% end %>

          <!-- Event ID -->
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Event ID</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">
              <code class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded text-xs font-mono">
                <%= @calendar_event.uid %>
              </code>
            </dd>
          </div>
        </dl>

        <!-- Description -->
        <% if @calendar_event.description.present? %>
          <div class="mt-8">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Description</dt>
            <dd class="text-sm text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
              <div class="whitespace-pre-wrap break-words">
                <%= @calendar_event.description %>
              </div>
            </dd>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Navigation -->
    <div class="mt-8 flex justify-between">
      <%= link_to view_calendars_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
        ← Back to Calendar Events
      <% end %>

      <% if @calendar_event.calendar_name.present? %>
        <%= link_to remove_calendar_data_uploads_path(@calendar_event.calendar_name), method: :delete,
            confirm: "Are you sure you want to delete all events from the '#{@calendar_event.calendar_name}' calendar?",
            class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-gray-700 dark:text-red-300 dark:border-red-600 dark:hover:bg-red-900/20" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Remove This Calendar
        <% end %>
      <% end %>
    </div>
  </div>
</div>
