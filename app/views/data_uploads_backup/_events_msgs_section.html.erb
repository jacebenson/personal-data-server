<!-- Personal Data Category -->
<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <div class="h-8 w-8 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-3">
          <span class="text-xl">📅</span>
        </div>
        <%= link_to personal_path, class: "group" do %>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">Events + Msgs</h3>
        <% end %>
      </div>
      <%= link_to personal_path, class: "group" do %>
        <svg class="h-5 w-5 text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      <% end %>
    </div>
  </div>
  <div class="p-6">
    <div class="space-y-2">
      <% today_events = current_user.calendar_events.today.chronological.limit(2) %>
      <% if today_events.any? %>
        <% today_events.each do |event| %>
          <%= link_to calendar_event_path(event), class: "block text-sm hover:bg-gray-50 dark:hover:bg-gray-700 rounded p-1 -m-1 transition-colors" do %>
            <span class="font-medium text-gray-900 dark:text-white">
              <%= event.start_time&.strftime("%l:%M%p")&.downcase || "All day" %>
            </span>
            <span class="text-gray-600 dark:text-gray-300 ml-1"><%= event.summary %></span>
            <% if event.location.present? %>
              <span class="text-gray-500 dark:text-gray-400 ml-1">@ <%= event.location %></span>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">No events today</p>
      <% end %>
    </div>
  </div>
</div>
