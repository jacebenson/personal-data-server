<!-- Financial Data Category -->
<%= link_to financial_path, class: "group block" do %>
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="h-8 w-8 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-3">
            <span class="text-xl">💸</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400">Money</h3>
        </div>
        <svg class="h-5 w-5 text-gray-400 group-hover:text-green-600 dark:group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </div>
    </div>
    <div class="p-6">
      <div class="space-y-3">
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">
            <span class="privacy-sensitive">$<%= number_with_delimiter((current_user.investments.sum(:amount) / 1000).round(0)) %>k</span> / <span class="privacy-sensitive">$1.2M</span>
          </p>
        </div>
        <div>
          <p class="text-lg font-semibold text-gray-900 dark:text-white">
            <span class="privacy-sensitive">$<%= number_with_delimiter(current_user.bank_statements.where(account: 'Ally Personal Checking').sum(:amount).round(0)) %></span> in your pocket
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>
