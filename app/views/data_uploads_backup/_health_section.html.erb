<!-- Health Data Section - Full Width -->
<div class="mb-8">
  <%= link_to health_index_path, class: "group block" do %>
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <div class="h-8 w-8 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-3">
              <span class="text-xl">🏥</span>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400">Health</h3>
          </div>
          <svg class="h-5 w-5 text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </div>
    <div class="p-6">
      <% health_patient = HealthPatient.first %>
      <% if health_patient %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Weight Chart -->
          <div>
            <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Weight Over Time</h4>
            <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg p-4">
              <% weight_records = health_patient.health_vital_signs.where.not(weight: [nil, "", 0]).where.not(measurement_date: [nil, ""]).where("measurement_date >= ?", 6.months.ago.to_date).order(:measurement_date) %>
              <% if weight_records.any? %>
                <% 
                  # Debug: show raw data
                  Rails.logger.debug "Weight records count: #{weight_records.count}"
                  weight_records.each do |record|
                    weight_kg = record.weight.to_f
                    weight_lbs = (weight_kg * 2.20462).round(1)
                    Rails.logger.debug "Record #{record.id}: #{record.measurement_date} - #{weight_kg}kg = #{weight_lbs}lbs"
                  end
                  
                  # Prepare data for chart
                  chart_data = weight_records.map do |record|
                    weight_kg = record.weight.to_f
                    weight_lbs = (weight_kg * 2.20462).round(1)
                    date = Date.parse(record.measurement_date)
                    [date.strftime("%m/%d/%y"), weight_lbs]
                  end
                  
                  # Also show current stats
                  latest_weight = weight_records.last
                  first_weight = weight_records.first
                  latest_weight_kg = latest_weight.weight.to_f
                  latest_weight_lbs = (latest_weight_kg * 2.20462).round(1)
                  first_weight_lbs = (first_weight.weight.to_f * 2.20462).round(1)
                  
                  Rails.logger.debug "Latest weight: #{latest_weight.measurement_date} - #{latest_weight_kg}kg = #{latest_weight_lbs}lbs"
                  Rails.logger.debug "First weight: #{first_weight.measurement_date} - #{first_weight.weight.to_f}kg = #{first_weight_lbs}lbs"
                %>
                
                <!-- Chart -->
                <%= line_chart chart_data, 
                    height: "200px",
                    min: 350,
                    colors: ["#3B82F6"],
                    suffix: " lbs",
                    curve: false,
                    discrete: true,
                    library: {
                      backgroundColor: "transparent",
                      borderColor: "#3B82F6",
                      borderWidth: 2,
                      pointBackgroundColor: "#3B82F6",
                      pointBorderColor: "#FFFFFF",
                      pointBorderWidth: 2,
                      pointRadius: 4,
                      tension: 0.1,
                      scales: {
                        y: {
                          display: false
                        }
                      }
                    } %>
                
                <!-- Current stats overlay -->
                <div class="mt-2 text-center">
                  <div class="text-sm font-medium text-gray-900 dark:text-white">
                    Current: <span class="privacy-sensitive"><%= latest_weight_lbs %> lbs</span>
                    <% if weight_records.count > 1 %>
                      <% weight_change_lbs = latest_weight_lbs - first_weight_lbs %>
                      <span class="ml-2 <%= weight_change_lbs > 0 ? 'text-red-600' : 'text-green-600' %>">
                        (<span class="privacy-sensitive"><%= weight_change_lbs > 0 ? '+' : '' %><%= weight_change_lbs.round(1) %> lbs</span>)
                      </span>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <div class="flex items-center justify-center h-full">
                  <p class="text-gray-500 dark:text-gray-400">No weight data available</p>
                </div>
              <% end %>
            </div>
          </div>
          
          <!-- Sleep Chart -->
          <div>
            <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Sleep</h4>
            <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg p-4">
              <% sleep_records = health_patient.health_sleep_data.where(session_date: 30.days.ago..Date.current).order(:session_date) %>
              <% if sleep_records.any? %>
                <% 
                  # Prepare data for chart - convert scientific notation to hours
                  chart_data = sleep_records.map do |record|
                    usage_hours = record.usage_hours.to_f
                    date = Date.parse(record.session_date.to_s)
                    [date.strftime("%m/%d"), usage_hours.round(1)]
                  end
                  
                  # Get latest stats
                  latest_record = sleep_records.last
                  latest_hours = latest_record.usage_hours.to_f
                  hours = latest_hours.to_i
                  minutes = ((latest_hours - hours) * 60).round
                  
                  # Calculate average
                  avg_hours = sleep_records.average(:usage_hours).to_f
                %>
                
                <!-- Chart with 8-hour goal line -->
                <div class="relative">
                  <%= column_chart chart_data, 
                      height: "180px",
                      max: 10,
                      colors: ["#3B82F6"],
                      suffix: "h" %>
                  
                  <!-- 8-hour goal line overlay -->
                  <div class="absolute inset-0 pointer-events-none">
                    <div class="absolute left-12 right-4 border-t-2 border-dashed border-red-500 opacity-75" style="top: <%= 180 - (8.0 / 10.0 * 180) %>px;">
                    </div>
                    <span class="absolute right-1 text-xs text-red-600 bg-white dark:bg-gray-700 px-1 rounded" style="top: <%= 180 - (8.0 / 10.0 * 180) - 10 %>px;">8h goal</span>
                  </div>
                </div>
                
                <!-- Current stats -->
                <div class="mt-2 flex justify-between text-sm">
                  <div class="text-gray-900 dark:text-white">
                    <span class="font-medium">Last: <%= hours %>h <%= minutes %>m</span>
                  </div>
                  <div class="text-gray-600 dark:text-gray-300">
                    Avg: <%= avg_hours.round(1) %>h
                  </div>
                </div>
              <% else %>
                <div class="flex items-center justify-center h-full">
                  <p class="text-gray-500 dark:text-gray-400">No sleep data available</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-gray-500 dark:text-gray-400">No health data available</p>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>
</div>
