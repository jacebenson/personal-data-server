<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to data_uploads_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Data Uploads
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Upload Transactions</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload a CSV file containing your transaction data</p>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">CSV File Upload</h3>
      </div>

      <div class="p-6">
        <%= form_with url: process_transactions_data_uploads_path, multipart: true, local: true, class: "space-y-6" do |form| %>
          <div>
            <label for="file" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Select CSV File
            </label>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".csv",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100" %>
            </div>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              CSV files only. Maximum file size: 10MB
            </p>
          </div>

          <div class="flex justify-end">
            <%= form.submit "Upload and Process",
                class: "bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Expected CSV Format -->
    <div class="mt-8 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
      <h3 class="text-lg font-medium text-blue-800 dark:text-blue-200 mb-4">Expected CSV Format</h3>
      <p class="text-sm text-blue-700 dark:text-blue-300 mb-4">
        Your CSV file should include the following columns:
      </p>
      <div class="bg-white dark:bg-gray-800 rounded border p-4">
        <code class="text-sm text-gray-800 dark:text-gray-200">
          Date, Description, Amount, Type, Reference<br>
          2024-01-15, "Online Purchase", -89.99, "debit", "TXN123456"<br>
          2024-01-16, "Direct Deposit", 1500.00, "credit", "DD789012"
        </code>
      </div>
      <ul class="mt-4 text-sm text-blue-700 dark:text-blue-300 space-y-1">
        <li><strong>Date:</strong> YYYY-MM-DD, MM/DD/YYYY, or DD/MM/YYYY format</li>
        <li><strong>Description:</strong> Transaction description</li>
        <li><strong>Amount:</strong> Positive or negative number</li>
        <li><strong>Type:</strong> Transaction type (e.g., debit, credit, transfer)</li>
        <li><strong>Reference:</strong> Optional reference number or ID</li>
      </ul>
    </div>
  </div>
</div>
