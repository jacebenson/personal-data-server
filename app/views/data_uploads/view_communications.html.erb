<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        <% if @message_type == 'linkedin' %>
          💼 LinkedIn Messages
        <% else %>
          📧 Email Messages
        <% end %>
      </h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        <% if @message_type == 'linkedin' %>
          View and manage your imported LinkedIn messages
        <% else %>
          View and manage your imported email messages
        <% end %>
      </p>
    </div>

    <!-- Message Type Navigation -->
    <div class="mb-8">
      <nav class="flex space-x-1 bg-gray-100 dark:bg-gray-800 rounded-lg p-1">
        <%= link_to view_communications_data_uploads_path(type: 'email'),
            class: "flex-1 text-center px-4 py-2 text-sm font-medium rounded-md transition-colors #{'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow' if @message_type != 'linkedin'} #{'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300' if @message_type == 'linkedin'}" do %>
          📧 Email Messages (<%= number_with_delimiter(current_user.email_messages.count) %>)
        <% end %>
        <%= link_to view_communications_data_uploads_path(type: 'linkedin'),
            class: "flex-1 text-center px-4 py-2 text-sm font-medium rounded-md transition-colors #{'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow' if @message_type == 'linkedin'} #{'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300' if @message_type != 'linkedin'}" do %>
          💼 LinkedIn Messages (<%= number_with_delimiter(current_user.linkedin_messages.count) %>)
        <% end %>
      </nav>
    </div>

    <!-- Statistics Summary -->
    <div class="mb-8 grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Messages</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= number_with_delimiter(@total_messages) %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  <% if @message_type == 'linkedin' %>
                    Conversations
                  <% else %>
                    Total Size
                  <% end %>
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% if @message_type == 'linkedin' %>
                    <%= number_with_delimiter(current_user.linkedin_messages.pluck(:conversation_id).uniq.count) %>
                  <% else %>
                    <%= number_to_human_size(@total_size) %>
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Folders</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @folders.length %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Date Range</dt>
                <dd class="text-sm font-medium text-gray-900 dark:text-white">
                  <% if @date_range[:earliest] && @date_range[:latest] %>
                    <%= @date_range[:earliest].year %> - <%= @date_range[:latest].year %>
                  <% else %>
                    No data
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="mb-6 bg-white dark:bg-gray-800 shadow rounded-lg p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Filters</h3>
      <div class="flex flex-wrap gap-4">
        <%= link_to view_communications_data_uploads_path(type: @message_type),
            class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium #{'bg-blue-50 text-blue-700 border-blue-300' if @filtered_folder.blank?} #{'text-gray-700 bg-white hover:bg-gray-50' if @filtered_folder.present?} dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600" do %>
          All Folders (<%= @total_messages %>)
        <% end %>

        <% @folders.each do |folder, count| %>
          <%= link_to view_communications_data_uploads_path(type: @message_type, folder: folder),
              class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium #{'bg-blue-50 text-blue-700 border-blue-300' if @filtered_folder == folder} #{'text-gray-700 bg-white hover:bg-gray-50' if @filtered_folder != folder} dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600" do %>
            <%= folder %> (<%= count %>)
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Messages Table -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">
          <% if @message_type == 'linkedin' %>
            LinkedIn Messages
          <% else %>
            Email Messages
          <% end %>
          <% if @filtered_folder.present? %>
            in "<%= @filtered_folder %>"
          <% end %>
        </h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
          Showing <%= (@current_page - 1) * 50 + 1 %>-<%= [(@current_page - 1) * 50 + (@message_type == 'linkedin' ? @linkedin_messages : @email_messages)&.length.to_i, @total_count].min %> of <%= number_with_delimiter(@total_count) %> messages
        </p>
      </div>

      <% if (@message_type == 'linkedin' && @linkedin_messages&.any?) || (@message_type == 'email' && @email_messages&.any?) %>
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% if @message_type == 'linkedin' %>
            <% @linkedin_messages.each do |message| %>
              <li class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <div class="flex items-center justify-between">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center space-x-3">
                      <div class="flex-shrink-0">
                        <div class="h-10 w-10 rounded-full bg-green-300 dark:bg-green-600 flex items-center justify-center">
                          <span class="text-sm font-medium text-green-700 dark:text-green-300">
                            <%= message.sender_display_name.first.upcase if message.sender_display_name.present? %>
                          </span>
                        </div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center space-x-2">
                          <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                            <%= message.sender_display_name %>
                          </p>
                          <span class="text-gray-400">→</span>
                          <p class="text-sm text-gray-700 dark:text-gray-300 truncate">
                            <%= message.recipient_display_name %>
                          </p>
                        </div>
                        <% if message.subject.present? %>
                          <p class="text-sm text-gray-900 dark:text-white font-medium truncate">
                            Subject: <%= message.subject %>
                          </p>
                        <% end %>
                        <p class="text-sm text-gray-500 dark:text-gray-400 truncate">
                          <%= message.content_preview(100) %>
                        </p>
                        <% if message.conversation_url %>
                          <a href="<%= message.conversation_url %>" target="_blank" class="text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-200">
                            View on LinkedIn →
                          </a>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="flex-shrink-0 text-right">
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                      <%= message.sent_at.strftime("%b %d, %Y") %>
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500">
                      <%= message.sent_at.strftime("%I:%M %p") %>
                    </p>
                    <div class="flex items-center justify-end space-x-2 mt-1">
                      <% if message.has_attachments? %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                          📎 <%= message.attachment_list.length %>
                        </span>
                      <% end %>
                      <% if message.is_draft? %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                          Draft
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </li>
            <% end %>
          <% else %>
            <% @email_messages.each do |message| %>
              <%= link_to show_communication_data_uploads_path(message), class: "block" do %>
                <li class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center space-x-3">
                        <div class="flex-shrink-0">
                          <div class="h-10 w-10 rounded-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                              <%= message.sender_display_name.first.upcase if message.sender_display_name.present? %>
                            </span>
                          </div>
                        </div>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                            <%= message.sender_display_name %>
                            <span class="text-gray-500 dark:text-gray-400">
                              &lt;<%= message.sender_email %>&gt;
                            </span>
                          </p>
                          <p class="text-sm text-gray-900 dark:text-white font-medium truncate">
                            <%= message.short_subject(60) %>
                          </p>
                          <p class="text-sm text-gray-500 dark:text-gray-400 truncate">
                            <%= message.content_preview(100) %>
                          </p>
                        </div>
                      </div>
                    </div>
                    <div class="flex-shrink-0 text-right">
                      <p class="text-sm text-gray-500 dark:text-gray-400">
                        <%= message.received_date.strftime("%b %d, %Y") %>
                      </p>
                      <p class="text-xs text-gray-400 dark:text-gray-500">
                        <%= message.received_date.strftime("%I:%M %p") %>
                      </p>
                      <div class="flex items-center justify-end space-x-2 mt-1">
                        <% if message.attachments_count > 0 %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                            📎 <%= message.attachments_count %>
                          </span>
                        <% end %>
                        <span class="text-xs text-gray-400 dark:text-gray-500">
                          <%= message.formatted_size %>
                        </span>
                      </div>
                    </div>
                  </div>
                </li>
              <% end %>
            <% end %>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">
            <% if @message_type == 'linkedin' %>
              No LinkedIn messages
            <% else %>
              No email messages
            <% end %>
          </h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            <% if @message_type == 'linkedin' %>
              No LinkedIn messages found<% if @filtered_folder.present? %> in "<%= @filtered_folder %>" folder<% end %>.
            <% else %>
              No email messages found<% if @filtered_folder.present? %> in "<%= @filtered_folder %>" folder<% end %>.
            <% end %>
          </p>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @total_pages > 1 %>
      <div class="mt-6 flex items-center justify-between">
        <div class="flex-1 flex justify-between sm:hidden">
          <% if @has_prev %>
            <%= link_to view_communications_data_uploads_path(type: @message_type, page: @current_page - 1, folder: @filtered_folder),
                class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
              Previous
            <% end %>
          <% end %>
          <% if @has_next %>
            <%= link_to view_communications_data_uploads_path(type: @message_type, page: @current_page + 1, folder: @filtered_folder),
                class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
              Next
            <% end %>
          <% end %>
        </div>
        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
          <div>
            <p class="text-sm text-gray-700 dark:text-gray-300">
              Showing page <span class="font-medium"><%= @current_page %></span> of <span class="font-medium"><%= @total_pages %></span>
            </p>
          </div>
          <div>
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
              <% if @has_prev %>
                <%= link_to view_communications_data_uploads_path(type: @message_type, page: @current_page - 1, folder: @filtered_folder),
                    class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                  <span class="sr-only">Previous</span>
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              <% end %>

              <% ([@current_page - 2, 1].max..[@current_page + 2, @total_pages].min).each do |page_num| %>
                <% if page_num == @current_page %>
                  <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-blue-50 text-sm font-medium text-blue-600 dark:bg-blue-900 dark:text-blue-200">
                    <%= page_num %>
                  </span>
                <% else %>
                  <%= link_to view_communications_data_uploads_path(type: @message_type, page: page_num, folder: @filtered_folder),
                      class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                    <%= page_num %>
                  <% end %>
                <% end %>
              <% end %>

              <% if @has_next %>
                <%= link_to view_communications_data_uploads_path(type: @message_type, page: @current_page + 1, folder: @filtered_folder),
                    class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                  <span class="sr-only">Next</span>
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              <% end %>
            </nav>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Back to Data Uploads -->
    <div class="mt-8 text-center">
      <%= link_to communications_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
        </svg>
        Back to Communications Upload
      <% end %>
    </div>

    <!-- Admin Actions -->
    <% if @message_type == 'email' %>
      <% if @total_messages > 0 %>
        <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
          <%= link_to "Delete All Email Messages", clear_communications_data_uploads_path,
              method: :delete,
              confirm: "Are you sure you want to delete all #{number_with_delimiter(@total_messages)} email messages? This action cannot be undone.",
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
