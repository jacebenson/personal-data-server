<style>
  /* Custom styles for collapsible sections */
  details > summary {
    list-style: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary svg {
    transform: rotate(-90deg);
    transition: transform 0.2s ease-in-out;
  }

  details[open] > summary svg {
    transform: rotate(0deg);
  }

  details > div {
    animation: slideDown 0.3s ease-in-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      max-height: 0;
    }
    to {
      opacity: 1;
      max-height: 1000px;
    }
  }

  /* Enhanced hover effects */
  .transaction-row {
    transition: all 0.15s ease-in-out;
  }

  .transaction-row:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
</style>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <%= link_to financial_path, class: "inline-flex items-center text-green-600 hover:text-green-500" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Financial Data
          <% end %>

          <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Investment Transactions</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">View and manage your imported investment transaction data</p>
        </div>
        <% if @total_count > 0 %>
          <div class="flex space-x-3">
            <%= link_to fidelity_data_data_uploads_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Upload More
            <% end %>
            <%= button_to clear_investments_data_uploads_path, method: :delete,
                confirm: "Are you sure you want to delete all #{@total_count} investment records? This cannot be undone.",
                class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
              Clear All Records
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Transactions
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @investments.count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Unique Accounts
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @investments.distinct.count(:account) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Date Range
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% if @investments.any? %>
                    <%= @investments.minimum(:date)&.strftime("%m/%Y") %> -
                    <%= @investments.maximum(:date)&.strftime("%m/%Y") %>
                  <% else %>
                    No data
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Amount
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% total_amount = @investments.sum(&:amount) %>
                  <%= number_to_currency(total_amount) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Investments Table -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Investment Transactions by Account</h3>
            <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">
              Click on an account to expand and view transactions. First account is open by default.
            </p>
          </div>
          <div class="flex items-center space-x-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              <%= @investments.distinct.count(:account) %> accounts
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
              <%= @investments.count %> total transactions
            </span>
          </div>
        </div>
      </div>

      <% if @investments.any? %>
        <!-- Group transactions by account -->
        <% @investments.includes(:user).group_by(&:account).each_with_index do |(account_name, account_investments), index| %>
        <%
                    if account_name && account_name.include?(' - ')
                      account_parts = account_name.split(' - ', 2)
                      account_number = account_parts[0]
                      account_display_name = account_parts[1]
                    else
                      account_number = nil
                      account_display_name = account_name || "Unknown Account"
                    end
                    account_total = account_investments.sum(&:amount)
                  %>

          <!-- Collapsible Account Section -->
          <details class="border border-gray-200 dark:border-gray-700 rounded-lg mb-4 overflow-hidden" <%= 'open' if index == 0 %>>
            <summary class="cursor-pointer bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 px-6 py-4 transition-colors duration-200">
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                      <%= account_display_name %>
                    </h3>
                    <div class="flex items-center space-x-3 text-sm text-gray-500 dark:text-gray-400 mt-1">
                      <% if account_number %>
                        <span class="font-mono text-xs bg-gray-200 dark:bg-gray-600 px-2 py-1 rounded">
                          <%= account_number %>
                        </span>
                      <% end %>
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <%= account_investments.count %> transactions
                      </span>
                    </div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-bold <%= account_total < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                    <%= number_to_currency(account_total) %>
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    <%= account_investments.minimum(:date)&.strftime("%m/%d/%Y") %> -
                    <%= account_investments.maximum(:date)&.strftime("%m/%d/%Y") %>
                  </div>
                </div>
              </div>
            </summary>


            <!-- Account Transactions Table -->
            <div class="bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                  <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Action</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Security</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Price</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Amount</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                    <% account_investments.sort_by(&:date).reverse.each_with_index do |investment, row_index| %>
                      <tr class="transaction-row hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-150 <%= 'bg-gray-50 dark:bg-gray-700' if row_index.even? %>">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                          <div class="flex items-center">
                            <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                            <%= investment.date&.strftime("%m/%d/%Y") %>
                          </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <span class="inline-flex items-center px-3 py-1 text-xs font-semibold rounded-full
                            <%= case investment.action&.upcase
                                when 'BUY', 'BUYMF', 'BUYSTOCK'
                                  'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                                when 'SELL', 'SELLMF', 'SELLSTOCK'
                                  'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                                when 'DIVIDEND', 'INCOME'
                                  'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                                when 'REINVESTMENT', 'REINVEST'
                                  'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200'
                                else
                                  'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                                end %>">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                              <% case investment.action&.upcase
                                 when 'BUY', 'BUYMF', 'BUYSTOCK' %>
                                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
                              <% when 'SELL', 'SELLMF', 'SELLSTOCK' %>
                                <path fill-rule="evenodd" d="M3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
                              <% when 'DIVIDEND', 'INCOME' %>
                                <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path>
                              <% else %>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd"></path>
                              <% end %>
                            </svg>
                            <%= investment.action %>
                          </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                          <div class="flex items-start space-x-3">
                            <div class="flex-shrink-0">
                              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
                                <span class="text-xs font-bold text-blue-600 dark:text-blue-200">
                                  <%= investment.symbol&.first(2)&.upcase %>
                                </span>
                              </div>
                            </div>
                            <div class="min-w-0 flex-1">
                              <div class="font-medium text-gray-900 dark:text-white">
                                <%= investment.symbol %>
                              </div>
                              <% if investment.description.present? %>
                                <div class="text-gray-500 dark:text-gray-400 text-xs truncate max-w-xs">
                                  <%= investment.description %>
                                </div>
                              <% end %>
                            </div>
                          </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                          <% if investment.quantity %>
                            <div class="flex items-center space-x-1">
                              <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                              </svg>
                              <span class="font-mono"><%= number_with_precision(investment.quantity, precision: 3) %></span>
                            </div>
                          <% else %>
                            <span class="text-gray-400">—</span>
                          <% end %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                          <% if investment.price %>
                            <div class="flex items-center space-x-1">
                              <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                              </svg>
                              <span class="font-mono"><%= number_to_currency(investment.price) %></span>
                            </div>
                          <% else %>
                            <span class="text-gray-400">—</span>
                          <% end %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                          <% if investment.amount %>
                            <div class="flex items-center justify-end space-x-1">
                              <svg class="w-4 h-4 <%= investment.amount < 0 ? 'text-red-500' : 'text-green-500' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <% if investment.amount < 0 %>
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
                                <% else %>
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                <% end %>
                              </svg>
                              <span class="font-mono <%= investment.amount < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                                <%= number_to_currency(investment.amount) %>
                              </span>
                            </div>
                          <% else %>
                            <span class="text-gray-400">—</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>

              <!-- Account Summary Footer -->
              <div class="bg-gray-50 dark:bg-gray-700 px-6 py-3 border-t border-gray-200 dark:border-gray-600">
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-300">
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                      </svg>
                      Total: <%= account_investments.count %> transactions
                    </span>
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      From <%= account_investments.minimum(:date)&.strftime("%m/%d/%Y") %> to <%= account_investments.maximum(:date)&.strftime("%m/%d/%Y") %>
                    </span>
                  </div>
                  <div class="text-right">
                    <span class="text-sm text-gray-500 dark:text-gray-400">Account Total:</span>
                    <span class="ml-2 text-lg font-bold <%= account_total < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                      <%= number_to_currency(account_total) %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </details>
        <% end %>

        <% if @investments.count > 50 %>
          <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 border-t border-gray-200 dark:border-gray-600">
            <p class="text-sm text-gray-700 dark:text-gray-300">
              Showing first 50 of <%= @investments.count %> total transactions
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No investment data found</h3>
          <p class="mt-2 text-gray-500 dark:text-gray-400">
            Upload some investment files to see your transaction data here.
          </p>
          <div class="mt-6 space-x-4">
            <%= link_to "Upload Fidelity Data", fidelity_investments_data_uploads_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
            <%= link_to "Upload Principal Data", principal_investments_data_uploads_path,
