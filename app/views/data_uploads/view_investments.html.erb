<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to data_uploads_path, class: "inline-flex items-center text-green-600 hover:text-green-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Data Uploads
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Investment Transactions</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">View and manage your imported investment transaction data</p>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Transactions
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @investments.count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Unique Accounts
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @investments.distinct.count(:account) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Date Range
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% if @investments.any? %>
                    <%= @investments.minimum(:date)&.strftime("%m/%Y") %> -
                    <%= @investments.maximum(:date)&.strftime("%m/%Y") %>
                  <% else %>
                    No data
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Amount
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% total_amount = @investments.sum(&:amount) %>
                  <%= number_to_currency(total_amount) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Investments Table -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Recent Investment Transactions</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">
          Latest investment activity across all accounts
        </p>
      </div>

      <% if @investments.any? %>
        <!-- Group transactions by account -->
        <% @investments.includes(:user).group_by(&:account).each do |account_name, account_investments| %>
          <div class="mb-8 last:mb-0">
            <!-- Account Header -->
            <div class="bg-gray-100 dark:bg-gray-700 px-6 py-4 border-b border-gray-200 dark:border-gray-600">
              <div class="flex items-center justify-between">
                <div>
                  <%
                    # Parse account name to extract account number and name
                    if account_name && account_name.include?(' - ')
                      account_parts = account_name.split(' - ', 2)
                      account_number = account_parts[0]
                      account_display_name = account_parts[1]
                    else
                      account_number = nil
                      account_display_name = account_name || "Unknown Account"
                    end
                  %>
                  <h4 class="text-lg font-semibold text-gray-900 dark:text-white">
                    <%= account_display_name %>
                  </h4>
                  <div class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
                    <% if account_number %>
                      <span class="font-mono text-xs">Account: <%= account_number %></span>
                      <span>•</span>
                    <% end %>
                    <span><%= account_investments.count %> transactions</span>
                  </div>
                </div>
                <div class="text-right">
                  <% account_total = account_investments.sum(&:amount) %>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Total</p>
                  <p class="text-lg font-semibold <%= account_total < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                    <%= number_to_currency(account_total) %>
                  </p>
                </div>
              </div>
            </div>

            <!-- Account Transactions Table -->
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Action</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Security</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Price</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Amount</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <% account_investments.sort_by(&:date).reverse.each do |investment| %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                        <%= investment.date&.strftime("%m/%d/%Y") %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
                          <%= case investment.action&.upcase
                              when 'BUY', 'BUYMF', 'BUYSTOCK'
                                'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                              when 'SELL', 'SELLMF', 'SELLSTOCK'
                                'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                              when 'DIVIDEND', 'INCOME'
                                'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                              when 'REINVESTMENT', 'REINVEST'
                                'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200'
                              else
                                'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                              end %>">
                          <%= investment.action %>
                        </span>
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-900 dark:text-white">
                        <div>
                          <div class="font-medium"><%= investment.symbol %></div>
                          <% if investment.description.present? %>
                            <div class="text-gray-500 dark:text-gray-400 truncate max-w-xs"><%= investment.description %></div>
                          <% end %>
                        </div>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                        <%= number_with_precision(investment.quantity, precision: 3) if investment.quantity %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                        <%= number_to_currency(investment.price) if investment.price %>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <span class="<%= investment.amount && investment.amount < 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                          <%= number_to_currency(investment.amount) if investment.amount %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>

        <% if @investments.count > 50 %>
          <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 border-t border-gray-200 dark:border-gray-600">
            <p class="text-sm text-gray-700 dark:text-gray-300">
              Showing first 50 of <%= @investments.count %> total transactions
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No investment data found</h3>
          <p class="mt-2 text-gray-500 dark:text-gray-400">
            Upload some investment files to see your transaction data here.
          </p>
          <div class="mt-6 space-x-4">
            <%= link_to "Upload Fidelity Data", fidelity_investments_data_uploads_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
            <%= link_to "Upload Principal Data", principal_investments_data_uploads_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
