<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to data_uploads_path, class: "inline-flex items-center text-purple-600 hover:text-purple-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Data Uploads
      <% end %>

      <div class="flex justify-between items-center mt-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">👥 Contacts</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Showing <%= @contacts.count %> of <%= @total_contacts %> contacts
            <% if @filtered_source.present? %>
              • Filtered by: <%= @filtered_source.titleize %>
            <% end %>
            <% if @search_term.present? %>
              • Search: "<%= @search_term %>"
            <% end %>
          </p>
        </div>
        <div class="space-x-3">
          <%= link_to "Find Duplicates", contact_duplicates_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" %>
          <%= link_to "Upload More", contacts_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Contacts</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_contacts %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m4 0V9a2 2 0 012-2h2a2 2 0 012 2v12M13 7a1 1 0 11-2 0 1 1 0 012 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">With Organizations</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= current_user.contacts.where.not(organization: [nil, '']).count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">With Email</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= current_user.contacts.where.not(emails: [nil, '']).count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">With Phone</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= current_user.contacts.where.not(phones: [nil, '']).count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <%= form_with url: view_contacts_data_uploads_path, method: :get, local: true, class: "space-y-4 md:space-y-0 md:flex md:items-center md:space-x-4" do |form| %>
          <!-- Search -->
          <div class="flex-1">
            <%= form.text_field :search,
                value: @search_term,
                placeholder: "Search contacts by name, organization, or email...",
                class: "block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
          </div>

          <!-- Source Filter -->
          <div>
            <%= form.select :source,
                options_for_select([['All Sources', '']] + @sources.map { |source, count| ["#{source.titleize} (#{count})", source] }, @filtered_source),
                {},
                { class: "border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" } %>
          </div>

          <!-- Submit -->
          <div class="flex space-x-2">
            <%= form.submit "Filter", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
            <%= link_to "Clear", view_contacts_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Contacts List -->
    <% if @contacts.any? %>
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
        <ul class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @contacts.each do |contact| %>
            <li>
              <%= link_to show_contact_data_uploads_path(contact), class: "block hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <!-- Avatar placeholder -->
                      <div class="flex-shrink-0 h-12 w-12">
                        <% if contact.photo_url.present? || contact.photo_data.present? %>
                          <div class="h-12 w-12 rounded-full bg-purple-100 dark:bg-purple-900 flex items-center justify-center">
                            <span class="text-lg font-medium text-purple-600 dark:text-purple-400">
                              <%= contact.initials %>
                            </span>
                          </div>
                        <% else %>
                          <div class="h-12 w-12 rounded-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                            <span class="text-sm font-medium text-gray-600 dark:text-gray-300">
                              <%= contact.initials %>
                            </span>
                          </div>
                        <% end %>
                      </div>

                      <div class="ml-4">
                        <div class="flex items-center">
                          <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                            <%= contact.full_name %>
                          </p>
                          <% if contact.source.present? %>
                            <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
                              <%= contact.source.titleize %>
                            </span>
                          <% end %>
                        </div>

                        <div class="mt-1 flex items-center space-x-4">
                          <% if contact.organization.present? %>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                              <svg class="inline h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m4 0V9a2 2 0 012-2h2a2 2 0 012 2v12M13 7a1 1 0 11-2 0 1 1 0 012 0z"></path>
                              </svg>
                              <%= contact.organization %>
                              <% if contact.job_title.present? %>
                                • <%= contact.job_title %>
                              <% end %>
                            </p>
                          <% elsif contact.job_title.present? %>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                              <%= contact.job_title %>
                            </p>
                          <% end %>

                          <% if contact.primary_email.present? %>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                              <svg class="inline h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                              </svg>
                              <%= contact.primary_email %>
                            </p>
                          <% end %>

                          <% if contact.primary_phone.present? %>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                              <svg class="inline h-3 w-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                              </svg>
                              <%= contact.primary_phone %>
                            </p>
                          <% end %>

                          <% if contact.linkedin_url.present? %>
                            <p class="text-sm text-blue-600 dark:text-blue-400">
                              <svg class="inline h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                              </svg>
                              LinkedIn
                            </p>
                          <% end %>
                        </div>
                      </div>
                    </div>

                    <div class="flex items-center">
                      <p class="text-sm text-gray-400 dark:text-gray-500">
                        Added <%= time_ago_in_words(contact.imported_at || contact.created_at) %> ago
                      </p>
                      <svg class="ml-2 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </div>
                  </div>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Pagination -->
      <% if @total_pages > 1 %>
        <div class="bg-white dark:bg-gray-800 px-4 py-3 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 sm:px-6 rounded-b-lg">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if @has_prev %>
              <%= link_to view_contacts_data_uploads_path(page: @current_page - 1, source: @filtered_source, search: @search_term),
                  class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
                Previous
              <% end %>
            <% end %>
            <% if @has_next %>
              <%= link_to view_contacts_data_uploads_path(page: @current_page + 1, source: @filtered_source, search: @search_term),
                  class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
                Next
              <% end %>
            <% end %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Showing page <span class="font-medium"><%= @current_page %></span> of <span class="font-medium"><%= @total_pages %></span>
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <% if @has_prev %>
                  <%= link_to view_contacts_data_uploads_path(page: @current_page - 1, source: @filtered_source, search: @search_term),
                      class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                  <% end %>
                <% end %>

                <% ([1, @current_page - 1, @current_page, @current_page + 1, @total_pages].uniq.select { |p| p >= 1 && p <= @total_pages }).each do |page_num| %>
                  <% if page_num == @current_page %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-purple-500 bg-purple-50 text-sm font-medium text-purple-600">
                      <%= page_num %>
                    </span>
                  <% else %>
                    <%= link_to view_contacts_data_uploads_path(page: page_num, source: @filtered_source, search: @search_term),
                        class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
                      <%= page_num %>
                    <% end %>
                  <% end %>
                <% end %>

                <% if @has_next %>
                  <%= link_to view_contacts_data_uploads_path(page: @current_page + 1, source: @filtered_source, search: @search_term),
                      class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  <% end %>
                <% end %>
              </nav>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No contacts found</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if @search_term.present? || @filtered_source.present? %>
            Try adjusting your search or filters.
          <% else %>
            Get started by uploading your contact data.
          <% end %>
        </p>
        <div class="mt-6">
          <%= link_to "Upload Contacts", contacts_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
