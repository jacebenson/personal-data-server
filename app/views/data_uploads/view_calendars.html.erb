<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📅 Calendar Events</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">View and manage your imported calendar events</p>
    </div>

    <!-- Statistics Summary -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg mb-8">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">📊 Calendar Statistics</h3>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          <div class="text-center">
            <p class="text-2xl font-bold text-purple-600 dark:text-purple-400"><%= number_with_delimiter(@total_events) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Events</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= number_with_delimiter(@upcoming_events) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Upcoming</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= @calendars.count %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Calendars</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-orange-600 dark:text-orange-400"><%= number_with_delimiter(@events_this_month) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">This Month</p>
          </div>
          <div class="text-center">
            <% if @busiest_day %>
              <p class="text-lg font-bold text-red-600 dark:text-red-400"><%= Date.parse(@busiest_day).strftime("%b %d") %></p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Busiest Day</p>
            <% else %>
              <p class="text-lg font-bold text-gray-400">-</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Busiest Day</p>
            <% end %>
          </div>
        </div>

        <% if @date_range[:earliest] && @date_range[:latest] %>
          <div class="mt-4 text-center">
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Events from
              <span class="font-medium"><%= @date_range[:earliest].strftime("%B %Y") %></span>
              to
              <span class="font-medium"><%= @date_range[:latest].strftime("%B %Y") %></span>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Filters and Actions -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg mb-8">
      <div class="p-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
          <!-- Filters -->
          <div class="flex flex-wrap gap-4">
            <!-- Calendar Filter -->
            <div>
              <%= form_with url: view_calendars_data_uploads_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
                <%= form.hidden_field :time_filter, value: @time_filter %>
                <%= form.select :calendar,
                    options_from_collection_for_select(@calendars, :first, :first, @filtered_calendar),
                    { prompt: "All Calendars" },
                    { class: "px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", onchange: "this.form.submit();" } %>
              <% end %>
            </div>

            <!-- Time Filter -->
            <div>
              <%= form_with url: view_calendars_data_uploads_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
                <%= form.hidden_field :calendar, value: @filtered_calendar %>
                <%= form.select :time_filter,
                    options_for_select([
                      ["All Events", ""],
                      ["Upcoming", "upcoming"],
                      ["Past", "past"],
                      ["Today", "today"],
                      ["This Week", "this_week"],
                      ["This Month", "this_month"]
                    ], @time_filter),
                    {},
                    { class: "px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", onchange: "this.form.submit();" } %>
              <% end %>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex space-x-2">
            <%= link_to calendars_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Import More
            <% end %>

            <% if @total_events > 0 %>
              <%= link_to clear_calendars_data_uploads_path, method: :delete,
                  confirm: "Are you sure you want to delete all #{number_with_delimiter(@total_events)} calendar events? This action cannot be undone.",
                  class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-gray-700 dark:text-red-300 dark:border-red-600 dark:hover:bg-red-900/20" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Clear All
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Calendar Events List -->
    <% if @calendar_events.any? %>
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
        <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @calendar_events.each do |event| %>
            <li>
              <%= link_to show_calendar_event_data_uploads_path(event), class: "block hover:bg-gray-50 dark:hover:bg-gray-700" do %>
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center">
                        <% if event.all_day? %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 mr-3">
                            All Day
                          </span>
                        <% end %>
                        <% if event.recurring? %>
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200 mr-3">
                            Recurring
                          </span>
                        <% end %>
                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                          <%= event.summary %>
                        </p>
                      </div>
                      <div class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-400">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <span class="mr-4">
                          <%= event.start_time.strftime("%b %d, %Y") %>
                          <% unless event.all_day? %>
                            at <%= event.start_time.strftime("%l:%M %p") %>
                          <% end %>
                        </span>

                        <% if event.location.present? %>
                          <svg class="flex-shrink-0 mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                          </svg>
                          <span class="mr-4 truncate"><%= event.location %></span>
                        <% end %>

                        <% if event.calendar_name.present? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                            <%= event.calendar_name %>
                          </span>
                        <% end %>
                      </div>
                      <% if event.description.present? %>
                        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 truncate">
                          <%= truncate(event.description, length: 100) %>
                        </p>
                      <% end %>
                    </div>
                    <div class="flex items-center">
                      <% if event.start_time > Time.current %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                          Upcoming
                        </span>
                      <% else %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                          Past
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Pagination -->
      <% if @total_pages > 1 %>
        <div class="bg-white dark:bg-gray-800 px-4 py-3 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 sm:px-6 mt-0">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if @has_prev %>
              <%= link_to view_calendars_data_uploads_path(page: @current_page - 1, calendar: @filtered_calendar, time_filter: @time_filter), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                Previous
              <% end %>
            <% end %>
            <% if @has_next %>
              <%= link_to view_calendars_data_uploads_path(page: @current_page + 1, calendar: @filtered_calendar, time_filter: @time_filter), class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                Next
              <% end %>
            <% end %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Showing
                <span class="font-medium"><%= (@current_page - 1) * 50 + 1 %></span>
                to
                <span class="font-medium"><%= [@current_page * 50, @total_count].min %></span>
                of
                <span class="font-medium"><%= number_with_delimiter(@total_count) %></span>
                events
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <% if @has_prev %>
                  <%= link_to view_calendars_data_uploads_path(page: @current_page - 1, calendar: @filtered_calendar, time_filter: @time_filter), class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% end %>

                <% ([1, @current_page - 2].max..[[@current_page + 2, @total_pages].min, @total_pages].min).each do |page| %>
                  <% if page == @current_page %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-purple-500 bg-purple-50 text-sm font-medium text-purple-600 dark:bg-purple-900 dark:text-purple-200">
                      <%= page %>
                    </span>
                  <% else %>
                    <%= link_to view_calendars_data_uploads_path(page: page, calendar: @filtered_calendar, time_filter: @time_filter), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                      <%= page %>
                    <% end %>
                  <% end %>
                <% end %>

                <% if @has_next %>
                  <%= link_to view_calendars_data_uploads_path(page: @current_page + 1, calendar: @filtered_calendar, time_filter: @time_filter), class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% end %>
              </nav>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No calendar events</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by importing calendar data.</p>
        <div class="mt-6">
          <%= link_to calendars_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" do %>
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Import Calendar Data
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Actions -->
    <div class="mt-8 flex justify-between">
      <%= link_to calendars_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
        ← Back to Calendar Upload
      <% end %>

      <%= link_to data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
        All Data Uploads
      <% end %>
    </div>
  </div>
</div>
