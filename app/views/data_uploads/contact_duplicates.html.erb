<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to view_contacts_data_uploads_path, class: "inline-flex items-center text-purple-600 hover:text-purple-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Contacts
      <% end %>

      <div class="flex justify-between items-center mt-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">🔄 Contact Duplicates</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Found <%= @duplicate_groups.length %> potential duplicate groups from <%= @merge_results[:total_contacts] %> total contacts
          </p>
        </div>

        <% if @duplicate_groups.any? %>
          <div class="space-x-3">
            <%= form_with url: auto_merge_contacts_data_uploads_path, method: :post, local: true, class: "inline-block" do |form| %>
              <%= form.submit "Auto-Merge All",
                  data: {
                    confirm: "This will automatically merge all duplicate contacts. This action cannot be undone. Continue?"
                  },
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 cursor-pointer" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Contacts</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @merge_results[:total_contacts] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Duplicate Groups</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @duplicate_groups.length %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Potential Savings</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @duplicate_groups.sum { |group| group.length - 1 } %> duplicates
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Duplicate Groups -->
    <% if @duplicate_groups.any? %>
      <div class="space-y-6">
        <% @duplicate_groups.each_with_index do |group, index| %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-medium text-gray-900 dark:text-white">
                  Duplicate Group #<%= index + 1 %>
                  <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                    <%= group.length %> contacts
                  </span>
                </h3>

                <%= form_with url: merge_contacts_data_uploads_path, method: :post, local: true, class: "inline" do |form| %>
                  <% group.each do |contact| %>
                    <%= form.hidden_field :contact_ids, value: contact.id, multiple: true %>
                  <% end %>
                  <%= form.submit "Merge Group",
                      data: { confirm: "Merge these #{group.length} contacts? This cannot be undone." },
                      class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
                <% end %>
              </div>
            </div>

            <div class="p-6">
              <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-4">
                <% group.each_with_index do |contact, contact_index| %>
                  <div class="border border-gray-200 dark:border-gray-600 rounded-lg p-4 <%= contact_index == 0 ? 'bg-green-50 dark:bg-green-900/20 border-green-300 dark:border-green-600' : '' %>">
                    <% if contact_index == 0 %>
                      <div class="flex items-center mb-2">
                        <svg class="h-4 w-4 text-green-600 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span class="text-xs font-medium text-green-800 dark:text-green-200">Primary (Best Match)</span>
                      </div>
                    <% end %>

                    <div class="flex items-start">
                      <div class="flex-shrink-0 h-10 w-10">
                        <div class="h-10 w-10 rounded-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">
                            <%= contact.initials %>
                          </span>
                        </div>
                      </div>

                      <div class="ml-3 flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                          <%= link_to contact.full_name, show_contact_data_uploads_path(contact),
                              class: "hover:text-purple-600 dark:hover:text-purple-400" %>
                        </p>

                        <div class="mt-1 space-y-1">
                          <% if contact.organization.present? %>
                            <p class="text-xs text-gray-500 dark:text-gray-400">
                              🏢 <%= contact.organization %>
                            </p>
                          <% end %>

                          <% if contact.primary_email.present? %>
                            <p class="text-xs text-gray-500 dark:text-gray-400">
                              📧 <%= contact.primary_email %>
                            </p>
                          <% end %>

                          <% if contact.primary_phone.present? %>
                            <p class="text-xs text-gray-500 dark:text-gray-400">
                              📞 <%= contact.primary_phone %>
                            </p>
                          <% end %>

                          <div class="flex items-center justify-between mt-2">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                              Score: <%= contact.completeness_score %>
                            </span>

                            <span class="text-xs text-gray-400">
                              <%= time_ago_in_words(contact.created_at) %> ago
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- Match Reason -->
              <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-md">
                <h4 class="text-sm font-medium text-blue-900 dark:text-blue-200 mb-1">Why these contacts match:</h4>
                <div class="text-sm text-blue-800 dark:text-blue-300">
                  <% match_reasons = [] %>

                  <!-- Check for email matches -->
                  <% emails = group.map(&:email_list).flatten.compact %>
                  <% if emails.length != emails.uniq.length %>
                    <% match_reasons << "Shared email addresses" %>
                  <% end %>

                  <!-- Check for phone matches -->
                  <% phones = group.map(&:phone_list).flatten.compact %>
                  <% if phones.length != phones.uniq.length %>
                    <% match_reasons << "Shared phone numbers" %>
                  <% end %>

                  <!-- Check for name matches -->
                  <% names = group.map { |c| "#{c.given_name} #{c.family_name}".strip }.compact.uniq %>
                  <% if names.length == 1 && names.first.present? %>
                    <% match_reasons << "Same name (#{names.first})" %>
                  <% end %>

                  <% if match_reasons.empty? %>
                    <span>Similar contact information</span>
                  <% else %>
                    <span><%= match_reasons.join(", ") %></span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- No Duplicates Found -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No duplicate contacts found!</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          All your contacts appear to be unique. Great job keeping your contacts organized!
        </p>
        <div class="mt-6">
          <%= link_to "Back to Contacts", view_contacts_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
