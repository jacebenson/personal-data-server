<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📅 Add Remote Calendar</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Connect a remote calendar source via ICS URL</p>
    </div>

    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Calendar Details</h3>
      </div>
      
      <div class="p-6">
        <%= form_with model: @calendar, url: create_calendar_data_uploads_path, local: true, class: "space-y-6" do |form| %>
          <% if @calendar.errors.any? %>
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
                    There were some errors with your submission
                  </h3>
                  <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                    <ul class="list-disc space-y-1 pl-5">
                      <% @calendar.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :name, placeholder: "My Calendar", class: "mt-1 block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
          </div>

          <div>
            <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.text_area :description, rows: 3, placeholder: "Optional description", class: "mt-1 block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
          </div>

          <div>
            <%= form.label :source_url, "Calendar URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.url_field :source_url, placeholder: "https://calendar.google.com/calendar/ical/...", class: "mt-1 block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">The ICS URL of your remote calendar</p>
          </div>

          <div>
            <%= form.label :color, "Calendar Color", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div class="mt-1 flex items-center space-x-3">
              <%= form.color_field :color, value: @calendar.color || "#3B82F6", class: "h-10 w-20 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-purple-500 focus:border-purple-500" %>
              <span class="text-sm text-gray-500 dark:text-gray-400">Choose a color to identify this calendar</span>
            </div>
          </div>

          <div class="flex items-center">
            <%= form.check_box :auto_sync, class: "h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 dark:border-gray-600 rounded" %>
            <%= form.label :auto_sync, "Enable automatic sync", class: "ml-2 block text-sm text-gray-700 dark:text-gray-300" %>
          </div>

          <div id="sync-interval" class="<%= 'hidden' unless @calendar.auto_sync? %>">
            <%= form.label :sync_interval_minutes, "Sync Interval (minutes)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.number_field :sync_interval_minutes, value: @calendar.sync_interval_minutes || 60, min: 5, class: "mt-1 block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">How often to sync this calendar (minimum 5 minutes)</p>
          </div>

          <%= form.hidden_field :source_type, value: "url" %>

          <div class="flex items-center justify-between pt-6 border-t border-gray-200 dark:border-gray-700">
            <%= link_to "Cancel", view_calendars_data_uploads_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" %>
            <%= form.submit "Create Calendar", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const autoSyncCheckbox = document.getElementById('calendar_auto_sync');
    const syncIntervalDiv = document.getElementById('sync-interval');
    
    autoSyncCheckbox.addEventListener('change', function() {
      if (this.checked) {
        syncIntervalDiv.classList.remove('hidden');
      } else {
        syncIntervalDiv.classList.add('hidden');
      }
    });
  });
</script>
