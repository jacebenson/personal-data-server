<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to financial_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Financial Data
      <% end %>

      <div class="flex items-center justify-between mt-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Bank Statement Records</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">View all imported bank statement transactions</p>
        </div>

        <div class="flex items-center space-x-3">
          <%= link_to "Upload More", ally_bank_statements_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          <%= form_with url: remove_all_transactions_data_uploads_path, method: :delete, local: true, class: "inline-block" do |form| %>
            <%= form.submit "Delete All",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 cursor-pointer",
                onclick: "return confirm('Are you sure you want to delete ALL #{@total_count} bank statement transactions? This action cannot be undone.')" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Records</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= number_with_delimiter(@total_count) %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Deposits</dt>
                <dd class="text-lg font-medium text-green-600 dark:text-green-400">$<%= number_with_precision(@total_deposits, precision: 2, delimiter: ',') %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Withdrawals</dt>
                <dd class="text-lg font-medium text-red-600 dark:text-red-400">$<%= number_with_precision(@total_withdrawals.abs, precision: 2, delimiter: ',') %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Date Range</dt>
                <dd class="text-sm font-medium text-gray-900 dark:text-white">
                  <% if @date_range[:earliest] && @date_range[:latest] %>
                    <%= @date_range[:earliest].strftime('%m/%d/%Y') %> - <%= @date_range[:latest].strftime('%m/%d/%Y') %>
                  <% else %>
                    No records
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Account Summaries -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <% @account_summaries.each do |account, data| %>
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white"><%= account %></h3>
                <p class="text-sm text-gray-500 dark:text-gray-400"><%= pluralize(data[:count], 'transaction') %></p>
              </div>
              <div class="flex items-center space-x-2">
                <%= link_to view_ally_bank_statements_data_uploads_path(account: account),
                    class: "inline-flex items-center px-3 py-1 rounded-md text-xs font-medium text-blue-700 bg-blue-100 hover:bg-blue-200 dark:bg-blue-900 dark:text-blue-200 dark:hover:bg-blue-800" do %>
                  <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                  View
                <% end %>
                <%= form_with url: remove_account_transactions_data_uploads_path(account: account), method: :delete, local: true, class: "inline-block" do |form| %>
                  <%= form.submit "Delete",
                      class: "inline-flex items-center px-3 py-1 rounded-md text-xs font-medium text-red-700 bg-red-100 hover:bg-red-200 dark:bg-red-900 dark:text-red-200 dark:hover:bg-red-800 cursor-pointer",
                      onclick: "return confirm('Are you sure you want to delete all #{data[:count]} transactions from the #{account} account? This action cannot be undone.')" %>
                <% end %>
              </div>
            </div>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-3 gap-4">
              <div class="text-center">
                <div class="text-2xl font-bold text-green-600 dark:text-green-400">
                  +$<%= number_with_precision(data[:deposits], precision: 2, delimiter: ',') %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">Deposits</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-red-600 dark:text-red-400">
                  -$<%= number_with_precision(data[:withdrawals], precision: 2, delimiter: ',') %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">Withdrawals</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold <%= data[:net] >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  <%= data[:net] >= 0 ? '+' : '' %>$<%= number_with_precision(data[:net], precision: 2, delimiter: ',') %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">Net</div>
              </div>
            </div>

            <!-- Progress bar showing deposit vs withdrawal ratio -->
            <div class="mt-4">
              <div class="flex text-sm text-gray-600 dark:text-gray-400 mb-1">
                <span>Activity Breakdown</span>
              </div>
              <% total_activity = data[:deposits] + data[:withdrawals] %>
              <% if total_activity > 0 %>
                <% deposit_percentage = (data[:deposits] / total_activity * 100).round(1) %>
                <% withdrawal_percentage = (data[:withdrawals] / total_activity * 100).round(1) %>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3 overflow-hidden">
                  <div class="h-full flex">
                    <div class="bg-green-500 transition-all duration-300" style="width: <%= deposit_percentage %>%"></div>
                    <div class="bg-red-500 transition-all duration-300" style="width: <%= withdrawal_percentage %>%"></div>
                  </div>
                </div>
                <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <span><%= deposit_percentage %>% deposits</span>
                  <span><%= withdrawal_percentage %>% withdrawals</span>
                </div>
              <% else %>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
                  <div class="bg-gray-400 h-full rounded-full" style="width: 100%"></div>
                </div>
                <div class="text-center text-xs text-gray-500 dark:text-gray-400 mt-1">No activity</div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Records Table -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Bank Statement Transactions</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              Showing <%= ((@current_page - 1) * 50) + 1 %>-<%= [@current_page * 50, @total_count].min %> of <%= @total_count %> records
            </p>
          </div>

          <!-- Account Filter Buttons -->
          <div class="flex flex-wrap gap-2">
            <%= link_to "All", view_ally_bank_statements_data_uploads_path,
                class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium #{ params[:account].blank? ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }" %>
            <% @account_summaries.keys.each do |account| %>
              <%= link_to account, view_ally_bank_statements_data_uploads_path(account: account),
                  class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium #{ params[:account] == account ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Date
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Description
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Amount
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Category
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Account
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @bank_statements.each do |statement| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <div>
                    <%= statement.date.strftime('%m/%d/%Y') %>
                    <% if statement.date.hour != 0 || statement.date.min != 0 %>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        <%= statement.date.strftime('%I:%M %p') %>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-300">
                  <div class="max-w-xs truncate" title="<%= statement.description %>">
                    <%= statement.description %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <% if statement.amount >= 0 %>
                    <span class="text-green-600 dark:text-green-400">+$<%= number_with_precision(statement.amount, precision: 2, delimiter: ',') %></span>
                  <% else %>
                    <span class="text-red-600 dark:text-red-400">-$<%= number_with_precision(statement.amount.abs, precision: 2, delimiter: ',') %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <% if statement.category.present? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                      <%= statement.category %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">-</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <%= statement.account %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Simple Pagination -->
      <div class="bg-white dark:bg-gray-800 px-4 py-3 border-t border-gray-200 dark:border-gray-700 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if @has_prev %>
              <%= link_to "Previous", view_ally_bank_statements_data_uploads_path(page: @current_page - 1, account: @filtered_account), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% else %>
              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-400 bg-gray-100 dark:bg-gray-800 cursor-not-allowed">Previous</span>
            <% end %>
            <% if @has_next %>
              <%= link_to "Next", view_ally_bank_statements_data_uploads_path(page: @current_page + 1, account: @filtered_account), class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% else %>
              <span class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-400 bg-gray-100 dark:bg-gray-800 cursor-not-allowed">Next</span>
            <% end %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Showing
                <span class="font-medium"><%= ((@current_page - 1) * 50) + 1 %></span>
                to
                <span class="font-medium"><%= [@current_page * 50, @total_count].min %></span>
                of
                <span class="font-medium"><%= @total_count %></span>
                results
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <!-- Previous button -->
                <% if @has_prev %>
                  <%= link_to view_ally_bank_statements_data_uploads_path(page: @current_page - 1, account: @filtered_account), class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% else %>
                  <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 cursor-not-allowed">
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                <% end %>

                <!-- Page numbers -->
                <% start_page = [@current_page - 2, 1].max %>
                <% end_page = [start_page + 4, @total_pages].min %>
                <% start_page = [end_page - 4, 1].max if end_page - start_page < 4 %>

                <% (start_page..end_page).each do |page| %>
                  <% if page == @current_page %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-blue-500 bg-blue-50 dark:bg-blue-900 text-sm font-medium text-blue-600 dark:text-blue-300">
                      <%= page %>
                    </span>
                  <% else %>
                    <%= link_to page, view_ally_bank_statements_data_uploads_path(page: page, account: @filtered_account), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600" %>
                  <% end %>
                <% end %>

                <!-- Next button -->
                <% if @has_next %>
                  <%= link_to view_ally_bank_statements_data_uploads_path(page: @current_page + 1, account: @filtered_account), class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% else %>
                  <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 cursor-not-allowed">
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                <% end %>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
