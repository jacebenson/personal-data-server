<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to financial_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Financial Data
      <% end %>

      <div class="flex items-center justify-between mt-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Bank Statement Records</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">View all imported bank statement transactions</p>
        </div>

        <div class="flex items-center space-x-3">
          <%= link_to "Upload More", ally_bank_statements_data_uploads_path,
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          <button type="button" id="balance-adjustment-btn"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"></path>
            </svg>
            Add Balance
          </button>
          
          <!-- Temporary test form -->
          <%= form_with url: add_balance_adjustment_data_uploads_path, method: :post, local: true, class: "inline-block" do |form| %>
            <%= form.hidden_field :account_name, value: @account_summaries.keys.first %>
            <%= form.hidden_field :balance_amount, value: "1000.00" %>
            <%= form.hidden_field :adjustment_date, value: Date.current.strftime('%Y-%m-%d') %>
            <%= form.submit "Test Balance Adj",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 cursor-pointer" %>
          <% end %>
          
          <%= form_with url: remove_all_transactions_data_uploads_path, method: :delete, local: true, class: "inline-block" do |form| %>
            <%= form.submit "Delete All",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 cursor-pointer",
                onclick: "return confirm('Are you sure you want to delete ALL #{@total_count} bank statement transactions? This action cannot be undone.')" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Account Balances - Focus on Current Balance -->
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Current Account Balances</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @account_summaries.each do |account, data| %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 <%= data[:net] >= 0 ? 'border-green-500' : 'border-red-500' %>">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate"><%= account %></h3>
                <div class="flex items-center space-x-1">
                  <%= link_to view_ally_bank_statements_data_uploads_path(account: account),
                      class: "p-1 text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>
                </div>
              </div>
              
              <!-- Current Balance - Most Important -->
              <div class="text-center mb-4">
                <div class="text-3xl font-bold <%= data[:net] >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  $<%= number_with_precision(data[:net], precision: 2, delimiter: ',') %>
                </div>
                <div class="text-sm text-gray-500 dark:text-gray-400">Current Balance</div>
              </div>

              <!-- Quick Stats -->
              <div class="grid grid-cols-2 gap-3 text-sm">
                <div class="text-center">
                  <div class="text-green-600 dark:text-green-400 font-semibold">
                    +$<%= number_with_precision(data[:deposits], precision: 0, delimiter: ',') %>
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">Total In</div>
                </div>
                <div class="text-center">
                  <div class="text-red-600 dark:text-red-400 font-semibold">
                    -$<%= number_with_precision(data[:withdrawals], precision: 0, delimiter: ',') %>
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">Total Out</div>
                </div>
              </div>
              
              <!-- Transaction Count -->
              <div class="mt-3 text-center">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                  <%= pluralize(data[:count], 'transaction') %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Activity (Last 30 Days) -->
    <%
      thirty_days_ago = 30.days.ago
      recent_transactions = current_user.bank_statements.where('date >= ?', thirty_days_ago).order(date: :desc)
      recent_by_account = recent_transactions.group_by(&:account)
    %>
    
    <% if recent_transactions.any? %>
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Recent Activity (Last 30 Days)</h2>
        
        <!-- Recent Summary Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Transactions</div>
                <div class="text-lg font-semibold text-gray-900 dark:text-white"><%= recent_transactions.count %></div>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path>
                </svg>
              </div>
              <div class="ml-3">
                <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Income</div>
                <div class="text-lg font-semibold text-green-600 dark:text-green-400">+$<%= number_with_precision(recent_transactions.where('amount > 0').sum(:amount), precision: 0, delimiter: ',') %></div>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path>
                </svg>
              </div>
              <div class="ml-3">
                <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Spending</div>
                <div class="text-lg font-semibold text-red-600 dark:text-red-400">-$<%= number_with_precision(recent_transactions.where('amount < 0').sum(:amount).abs, precision: 0, delimiter: ',') %></div>
              </div>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
              </div>
              <div class="ml-3">
                <% recent_net = recent_transactions.sum(:amount) %>
                <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Net Change</div>
                <div class="text-lg font-semibold <%= recent_net >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  <%= recent_net >= 0 ? '+' : '' %>$<%= number_with_precision(recent_net, precision: 0, delimiter: ',') %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Transactions by Account (Collapsible) -->
        <div class="space-y-4">
          <% recent_by_account.each do |account, transactions| %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
              <details class="group">
                <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg">
                  <div class="flex items-center space-x-3">
                    <svg class="w-4 h-4 text-gray-400 group-open:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white"><%= account %></h3>
                    <span class="text-sm text-gray-500 dark:text-gray-400">(<%= pluralize(transactions.count, 'transaction') %>)</span>
                  </div>
                  <div class="text-right">
                    <% account_net = transactions.sum(&:amount) %>
                    <div class="text-lg font-semibold <%= account_net >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                      <%= account_net >= 0 ? '+' : '' %>$<%= number_with_precision(account_net, precision: 2, delimiter: ',') %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">30-day change</div>
                  </div>
                </summary>
                
                <div class="px-4 pb-4">
                  <div class="max-h-80 overflow-y-auto">
                    <table class="min-w-full">
                      <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                          <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Date</th>
                          <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Description</th>
                          <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Amount</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        <% transactions.first(10).each do |transaction| %>
                          <tr>
                            <td class="px-3 py-2 text-sm text-gray-900 dark:text-gray-300"><%= transaction.date.strftime('%m/%d') %></td>
                            <td class="px-3 py-2 text-sm text-gray-900 dark:text-gray-300">
                              <div class="max-w-xs truncate" title="<%= transaction.description %>"><%= transaction.description %></div>
                            </td>
                            <td class="px-3 py-2 text-sm text-right font-medium">
                              <% if transaction.amount >= 0 %>
                                <span class="text-green-600 dark:text-green-400">+$<%= number_with_precision(transaction.amount, precision: 2, delimiter: ',') %></span>
                              <% else %>
                                <span class="text-red-600 dark:text-red-400">-$<%= number_with_precision(transaction.amount.abs, precision: 2, delimiter: ',') %></span>
                              <% end %>
                            </td>
                          </tr>
                        <% end %>
                        <% if transactions.count > 10 %>
                          <tr>
                            <td colspan="3" class="px-3 py-2 text-center text-sm text-gray-500 dark:text-gray-400">
                              ... and <%= transactions.count - 10 %> more transactions
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </details>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Balance Adjustment Modal -->
    <div id="balance-adjustment-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Account Balance Adjustment</h3>
            <button type="button" id="close-modal" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
          
          <div class="mt-4">
            <%= form_with url: add_balance_adjustment_data_uploads_path, method: :post, local: true, class: "space-y-4" do |form| %>
              <div>
                <label for="account_name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Account Name
                </label>
                <select name="account_name" id="account_name" required
                    class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
                  <option value="">Select an account...</option>
                  <% @account_summaries.keys.each do |account| %>
                    <option value="<%= account %>"><%= account %></option>
                  <% end %>
                </select>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Choose the account to adjust the balance for
                </p>
              </div>

              <div>
                <label for="current_balance_display" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Current Balance (calculated)
                </label>
                <input type="text" id="current_balance_display" readonly
                    class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-600 dark:text-white shadow-sm bg-gray-100"
                    placeholder="Select an account first">
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  This shows the current calculated balance based on transactions
                </p>
              </div>

              <div>
                <label for="balance_amount" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Actual Account Balance
                </label>
                <input type="text" name="balance_amount" id="balance_amount" required
                    placeholder="1234.56"
                    class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Enter the actual balance from your bank statement or app
                </p>
              </div>

              <div>
                <label for="adjustment_date" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Balance Date
                </label>
                <input type="date" name="adjustment_date" id="adjustment_date" required
                    value="<%= Date.current.strftime('%Y-%m-%d') %>"
                    class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Date as of which this balance is accurate
                </p>
              </div>

              <div class="flex items-center justify-end space-x-3 mt-6">
                <button type="button" id="cancel-modal"
                    class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                  Cancel
                </button>
                <button type="submit"
                    class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                  Add Adjustment
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Records Table -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Bank Statement Transactions</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              Showing <%= ((@current_page - 1) * 50) + 1 %>-<%= [@current_page * 50, @total_count].min %> of <%= @total_count %> records
            </p>
          </div>

          <!-- Account Filter Buttons -->
          <div class="flex flex-wrap gap-2">
            <%= link_to "All", view_ally_bank_statements_data_uploads_path,
                class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium #{ params[:account].blank? ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }" %>
            <% @account_summaries.keys.each do |account| %>
              <%= link_to account, view_ally_bank_statements_data_uploads_path(account: account),
                  class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium #{ params[:account] == account ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Date
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Description
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Amount
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Category
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                Account
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @bank_statements.each do |statement| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <div>
                    <%= statement.date.strftime('%m/%d/%Y') %>
                    <% if statement.date.hour != 0 || statement.date.min != 0 %>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        <%= statement.date.strftime('%I:%M %p') %>
                      </div>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-300">
                  <div class="max-w-xs truncate" title="<%= statement.description %>">
                    <%= statement.description %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <% if statement.amount >= 0 %>
                    <span class="text-green-600 dark:text-green-400">+$<%= number_with_precision(statement.amount, precision: 2, delimiter: ',') %></span>
                  <% else %>
                    <span class="text-red-600 dark:text-red-400">-$<%= number_with_precision(statement.amount.abs, precision: 2, delimiter: ',') %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <% if statement.category.present? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                      <%= statement.category %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">-</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-300">
                  <%= statement.account %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Simple Pagination -->
      <div class="bg-white dark:bg-gray-800 px-4 py-3 border-t border-gray-200 dark:border-gray-700 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if @has_prev %>
              <%= link_to "Previous", view_ally_bank_statements_data_uploads_path(page: @current_page - 1, account: @filtered_account), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% else %>
              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-400 bg-gray-100 dark:bg-gray-800 cursor-not-allowed">Previous</span>
            <% end %>
            <% if @has_next %>
              <%= link_to "Next", view_ally_bank_statements_data_uploads_path(page: @current_page + 1, account: @filtered_account), class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% else %>
              <span class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-400 bg-gray-100 dark:bg-gray-800 cursor-not-allowed">Next</span>
            <% end %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Showing
                <span class="font-medium"><%= ((@current_page - 1) * 50) + 1 %></span>
                to
                <span class="font-medium"><%= [@current_page * 50, @total_count].min %></span>
                of
                <span class="font-medium"><%= @total_count %></span>
                results
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <!-- Previous button -->
                <% if @has_prev %>
                  <%= link_to view_ally_bank_statements_data_uploads_path(page: @current_page - 1, account: @filtered_account), class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% else %>
                  <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 cursor-not-allowed">
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                <% end %>

                <!-- Page numbers -->
                <% start_page = [@current_page - 2, 1].max %>
                <% end_page = [start_page + 4, @total_pages].min %>
                <% start_page = [end_page - 4, 1].max if end_page - start_page < 4 %>

                <% (start_page..end_page).each do |page| %>
                  <% if page == @current_page %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-blue-500 bg-blue-50 dark:bg-blue-900 text-sm font-medium text-blue-600 dark:text-blue-300">
                      <%= page %>
                    </span>
                  <% else %>
                    <%= link_to page, view_ally_bank_statements_data_uploads_path(page: page, account: @filtered_account), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600" %>
                  <% end %>
                <% end %>

                <!-- Next button -->
                <% if @has_next %>
                  <%= link_to view_ally_bank_statements_data_uploads_path(page: @current_page + 1, account: @filtered_account), class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% else %>
                  <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 cursor-not-allowed">
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                <% end %>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('balance-adjustment-modal');
    const openModalBtn = document.getElementById('balance-adjustment-btn');
    const closeModalBtn = document.getElementById('close-modal');
    const cancelModalBtn = document.getElementById('cancel-modal');
    const accountSelect = document.getElementById('account_name');
    const currentBalanceDisplay = document.getElementById('current_balance_display');

    // Account balances (calculated from server data)
    const accountBalances = {
      <% @account_summaries.each do |account, data| %>
        '<%= account %>': <%= data[:deposits] - data[:withdrawals] %>,
      <% end %>
    };

    // Open modal
    openModalBtn.addEventListener('click', function() {
      modal.classList.remove('hidden');
    });

    // Close modal
    function closeModal() {
      modal.classList.add('hidden');
      // Reset form
      accountSelect.value = '';
      currentBalanceDisplay.value = '';
      document.getElementById('balance_amount').value = '';
    }

    closeModalBtn.addEventListener('click', closeModal);
    cancelModalBtn.addEventListener('click', closeModal);

    // Close modal when clicking outside
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Update current balance when account is selected
    accountSelect.addEventListener('change', function() {
      const selectedAccount = this.value;
      if (selectedAccount && accountBalances[selectedAccount] !== undefined) {
        const balance = accountBalances[selectedAccount];
        currentBalanceDisplay.value = '$' + balance.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      } else {
        currentBalanceDisplay.value = '';
      }
    });

    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>
