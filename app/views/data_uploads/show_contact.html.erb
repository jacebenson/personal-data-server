<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to view_contacts_data_uploads_path, class: "inline-flex items-center text-purple-600 hover:text-purple-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Contacts
      <% end %>
    </div>

    <!-- Contact Header -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="px-6 py-4">
        <div class="flex items-center">
          <!-- Avatar -->
          <div class="flex-shrink-0 h-20 w-20">
            <% if @contact.photo_url.present? || @contact.photo_data.present? %>
              <div class="h-20 w-20 rounded-full bg-purple-100 dark:bg-purple-900 flex items-center justify-center">
                <span class="text-2xl font-medium text-purple-600 dark:text-purple-400">
                  <%= @contact.initials %>
                </span>
              </div>
            <% else %>
              <div class="h-20 w-20 rounded-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                <span class="text-xl font-medium text-gray-600 dark:text-gray-300">
                  <%= @contact.initials %>
                </span>
              </div>
            <% end %>
          </div>

          <div class="ml-6 flex-1">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
              <%= @contact.full_name %>
            </h1>

            <div class="mt-2 space-y-1">
              <% if @contact.organization.present? %>
                <p class="text-lg text-gray-600 dark:text-gray-400">
                  <svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m4 0V9a2 2 0 012-2h2a2 2 0 012 2v12M13 7a1 1 0 11-2 0 1 1 0 012 0z"></path>
                  </svg>
                  <%= @contact.organization %>
                  <% if @contact.job_title.present? %>
                    • <%= @contact.job_title %>
                  <% end %>
                </p>
              <% elsif @contact.job_title.present? %>
                <p class="text-lg text-gray-600 dark:text-gray-400">
                  <%= @contact.job_title %>
                </p>
              <% end %>

              <div class="flex items-center space-x-4 text-sm">
                <% if @contact.source.present? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
                    Source: <%= @contact.source.titleize %>
                  </span>
                <% end %>

                <span class="text-gray-500 dark:text-gray-400">
                  Added <%= time_ago_in_words(@contact.imported_at || @contact.created_at) %> ago
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Information -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Left Column -->
      <div class="space-y-6">
        <!-- Contact Details -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Contact Information</h3>
          </div>
          <div class="px-6 py-4 space-y-4">
            <!-- Email Addresses -->
            <% if @contact.email_list.any? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Email Addresses</h4>
                <div class="space-y-2">
                  <% @contact.email_list.each do |email| %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                      <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                      <a href="mailto:<%= email %>" class="hover:text-purple-600 dark:hover:text-purple-400">
                        <%= email %>
                      </a>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- Phone Numbers -->
            <% if @contact.phone_list.any? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Phone Numbers</h4>
                <div class="space-y-2">
                  <% @contact.phone_list.each do |phone| %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                      <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                      </svg>
                      <a href="tel:<%= phone %>" class="hover:text-purple-600 dark:hover:text-purple-400">
                        <%= phone %>
                      </a>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- URLs/Websites -->
            <% if @contact.urls.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Websites</h4>
                <div class="space-y-2">
                  <% @contact.urls.split(',').each do |url| %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                      <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                      </svg>
                      <a href="<%= url.strip %>" target="_blank" class="hover:text-purple-600 dark:hover:text-purple-400">
                        <%= url.strip %>
                      </a>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Address -->
        <% if @contact.formatted_address.present? %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Address</h3>
            </div>
            <div class="px-6 py-4">
              <div class="flex items-start text-sm text-gray-600 dark:text-gray-400">
                <svg class="h-4 w-4 mr-2 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span class="whitespace-pre-line"><%= @contact.formatted_address %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Right Column -->
      <div class="space-y-6">
        <!-- Personal Information -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Personal Information</h3>
          </div>
          <div class="px-6 py-4 space-y-4">
            <!-- Full Name Breakdown -->
            <% if @contact.given_name.present? || @contact.family_name.present? || @contact.middle_name.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Name Components</h4>
                <dl class="space-y-1 text-sm">
                  <% if @contact.name_prefix.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">Prefix:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.name_prefix %></dd>
                    </div>
                  <% end %>
                  <% if @contact.given_name.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">First:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.given_name %></dd>
                    </div>
                  <% end %>
                  <% if @contact.middle_name.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">Middle:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.middle_name %></dd>
                    </div>
                  <% end %>
                  <% if @contact.family_name.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">Last:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.family_name %></dd>
                    </div>
                  <% end %>
                  <% if @contact.name_suffix.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">Suffix:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.name_suffix %></dd>
                    </div>
                  <% end %>
                  <% if @contact.nickname.present? %>
                    <div class="flex">
                      <dt class="w-20 text-gray-500 dark:text-gray-400">Nickname:</dt>
                      <dd class="text-gray-900 dark:text-white"><%= @contact.nickname %></dd>
                    </div>
                  <% end %>
                </dl>
              </div>
            <% end %>

            <!-- Birthday -->
            <% if @contact.birthday.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Birthday</h4>
                <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                  <svg class="h-4 w-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <%= @contact.birthday.strftime("%B %d, %Y") %>
                </div>
              </div>
            <% end %>

            <!-- Categories -->
            <% if @contact.categories.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Categories</h4>
                <div class="flex flex-wrap gap-2">
                  <% @contact.categories.split(',').each do |category| %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                      <%= category.strip %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- Department -->
            <% if @contact.department.present? %>
              <div>
                <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-2">Department</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400"><%= @contact.department %></p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Social Profiles -->
        <% social_links = @contact.social_profile_links %>
        <% if social_links.any? %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Social Profiles</h3>
            </div>
            <div class="px-6 py-4">
              <div class="space-y-3">
                <% social_links.each do |link| %>
                  <div class="flex items-center text-sm">
                    <% if link[:platform].downcase.include?('linkedin') %>
                      <svg class="h-4 w-4 mr-3 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                    <% elsif link[:platform].downcase.include?('twitter') || link[:platform].downcase.include?('x') %>
                      <svg class="h-4 w-4 mr-3 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                      </svg>
                    <% else %>
                      <svg class="h-4 w-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                      </svg>
                    <% end %>
                    <span class="w-20 capitalize text-gray-500 dark:text-gray-400"><%= link[:platform] %>:</span>
                    <a href="<%= link[:url] %>" target="_blank" rel="noopener noreferrer"
                       class="ml-2 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 hover:underline">
                      <%= link[:url] %>
                    </a>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% elsif @contact.social_profiles.present? %>
          <!-- Fallback for old JSON format -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Social Profiles</h3>
            </div>
            <div class="px-6 py-4">
              <div class="space-y-2">
                <% begin %>
                  <% JSON.parse(@contact.social_profiles).each do |platform, profile_url| %>
                    <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                      <span class="w-20 capitalize text-gray-500 dark:text-gray-400"><%= platform %>:</span>
                      <a href="<%= profile_url %>" target="_blank" class="hover:text-purple-600 dark:hover:text-purple-400">
                        <%= profile_url %>
                      </a>
                    </div>
                  <% end %>
                <% rescue JSON::ParserError %>
                  <div class="text-sm text-gray-600 dark:text-gray-400">
                    <%= simple_format(@contact.social_profiles) %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Notes -->
        <% if @contact.notes.present? %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Notes</h3>
            </div>
            <div class="px-6 py-4">
              <p class="text-sm text-gray-600 dark:text-gray-400 whitespace-pre-line"><%= @contact.notes %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Metadata -->
    <div class="mt-6 bg-gray-100 dark:bg-gray-700 shadow rounded-lg">
      <div class="px-6 py-4">
        <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-3">Metadata</h3>
        <dl class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
          <div>
            <dt class="text-gray-500 dark:text-gray-400">Contact ID:</dt>
            <dd class="text-gray-900 dark:text-white font-mono text-xs"><%= @contact.uid %></dd>
          </div>
          <% if @contact.source_file.present? %>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Source File:</dt>
              <dd class="text-gray-900 dark:text-white"><%= @contact.source_file %></dd>
            </div>
          <% end %>
          <% if @contact.last_modified.present? %>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Last Modified:</dt>
              <dd class="text-gray-900 dark:text-white"><%= @contact.last_modified.strftime("%B %d, %Y at %I:%M %p") %></dd>
            </div>
          <% end %>
          <div>
            <dt class="text-gray-500 dark:text-gray-400">Imported:</dt>
            <dd class="text-gray-900 dark:text-white">
              <%= (@contact.imported_at || @contact.created_at).strftime("%B %d, %Y at %I:%M %p") %>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
