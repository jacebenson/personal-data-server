<div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 mb-8">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center">
      <div class="p-3 bg-red-100 dark:bg-red-900 rounded-lg mr-4">
        <svg class="w-8 h-8 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Health Data</h2>
        <p class="text-gray-600 dark:text-gray-400">Medical records, vital signs, and health tracking</p>
      </div>
    </div>
    <%= link_to health_index_path, class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition duration-200" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4"></path>
      </svg>
      View Health Records
    <% end %>
  </div>

  <% if HealthPatient.exists? %>
    <% patient = HealthPatient.first %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Patient Info -->
      <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
        <div class="flex items-center">
          <svg class="w-6 h-6 text-red-600 dark:text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <h3 class="text-sm font-medium text-red-900 dark:text-red-200">Patient</h3>
        </div>
        <p class="mt-2 text-xl font-semibold text-red-900 dark:text-red-100"><%= patient.full_name %></p>
        <p class="text-sm text-red-700 dark:text-red-300">Age: <%= patient.age %> • <%= patient.gender&.capitalize %></p>
      </div>

      <!-- Allergies -->
      <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
        <div class="flex items-center">
          <svg class="w-6 h-6 text-red-600 dark:text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
          <h3 class="text-sm font-medium text-red-900 dark:text-red-200">Allergies</h3>
        </div>
        <p class="mt-2 text-xl font-semibold text-red-900 dark:text-red-100"><%= patient.health_allergies.count %></p>
        <p class="text-sm text-red-700 dark:text-red-300">
          <% active_count = patient.health_allergies.where(status: 'active').count %>
          <%= active_count %> active
        </p>
      </div>

      <!-- Medications -->
      <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
        <div class="flex items-center">
          <svg class="w-6 h-6 text-red-600 dark:text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5.657 5.657a2 2 0 002.828 0l5.657-5.657a2 2 0 00.586-1.414V6L21 4z"></path>
          </svg>
          <h3 class="text-sm font-medium text-red-900 dark:text-red-200">Medications</h3>
        </div>
        <p class="mt-2 text-xl font-semibold text-red-900 dark:text-red-100"><%= patient.health_medications.count %></p>
        <p class="text-sm text-red-700 dark:text-red-300">
          <% active_meds = patient.health_medications.where(status: 'active').count %>
          <%= active_meds %> active
        </p>
      </div>

      <!-- Recent Encounters -->
      <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4">
        <div class="flex items-center">
          <svg class="w-6 h-6 text-red-600 dark:text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <h3 class="text-sm font-medium text-red-900 dark:text-red-200">Encounters</h3>
        </div>
        <p class="mt-2 text-xl font-semibold text-red-900 dark:text-red-100"><%= patient.health_encounters.count %></p>
        <% if patient.health_encounters.any? %>
          <% latest = patient.health_encounters.order(encounter_date: :desc).first %>
          <p class="text-sm text-red-700 dark:text-red-300">
            Latest: <%= latest.encounter_date.strftime("%m/%d/%Y") if latest.encounter_date %>
          </p>
        <% else %>
          <p class="text-sm text-red-700 dark:text-red-300">No encounters</p>
        <% end %>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to import_health_index_path, class: "inline-flex items-center px-3 py-2 border border-red-300 text-sm leading-4 font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-gray-800 dark:text-red-400 dark:border-red-600 dark:hover:bg-red-900/20" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
        </svg>
        Import Health Data
      <% end %>
    </div>
  <% else %>
    <!-- No Health Data State -->
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 48 48">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M34 40h10v-4a6 6 0 00-10.712-3.714M34 40H14m20 0v-4a9.971 9.971 0 00-.712-3.714M14 40H4v-4a6 6 0 0110.713-3.714M14 40v-4c0-1.313.253-2.566.713-3.714m0 0A10.003 10.003 0 0124 26c4.21 0 7.813 2.602 9.288 6.286M30 14a6 6 0 11-12 0 6 6 0 0112 0zm12 6a4 4 0 11-8 0 4 4 0 018 0zm-28 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No health data imported yet</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by importing your medical records from healthcare providers or health tracking apps.</p>
      <div class="mt-6">
        <%= link_to import_health_index_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
          </svg>
          Import Health Data
        <% end %>
      </div>
    </div>
  <% end %>
</div>
