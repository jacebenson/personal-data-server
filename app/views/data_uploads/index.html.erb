<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Data Uploads</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload and transform your personal data files</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Bank Statements Upload -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Ally Bank Statements</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Upload CSV files from Ally Bank</p>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <%= link_to "Upload Ally Bank Statements", ally_bank_statements_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <% if current_user.bank_statements.any? %>
              <%= link_to "View Records", view_ally_bank_statements_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
              <%= link_to "Manage Duplicates", manage_duplicates_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Investment Statements -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Investment Statements</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Upload investment data from Fidelity or Principal</p>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <%= link_to "Upload Fidelity Transactions", fidelity_investments_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
            <%= link_to "Upload Fidelity Portfolio", fidelity_portfolio_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-500 hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
            <%= link_to "Upload Principal OFX", principal_investments_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
            <% if current_user.investments.any? %>
              <%= link_to "View Records", view_investments_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Social Security Earnings -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Social Security Earnings</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Upload lifetime earnings from SSA.gov</p>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <%= link_to "Upload SSA XML", social_security_earnings_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" %>
            <% if current_user.social_security_earnings.any? %>
              <%= link_to "View Lifetime Earnings", view_social_security_earnings_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="mt-12">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Recent Data</h3>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Ally Bank Statements</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.bank_statements.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                Last upload: <%= current_user.bank_statements.maximum(:created_at)&.strftime("%B %d, %Y") || "Never" %>
              </p>
              <% if current_user.bank_statements.any? %>
                <div class="mt-2">
                  <%= link_to view_ally_bank_statements_data_uploads_path, class: "text-blue-600 hover:text-blue-500 text-sm font-medium" do %>
                    View all records →
                  <% end %>
                </div>
              <% end %>
            </div>
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Investment Records</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.investments.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                Last upload: <%= current_user.investments.maximum(:created_at)&.strftime("%B %d, %Y") || "Never" %>
              </p>
              <% if current_user.investments.any? %>
                <div class="mt-2">
                  <%= link_to view_investments_data_uploads_path, class: "text-green-600 hover:text-green-500 text-sm font-medium" do %>
                    View all records →
                  <% end %>
                </div>
              <% end %>
            </div>
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Social Security Earnings</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.social_security_earnings.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                <% if current_user.social_security_earnings.any? %>
                  Years: <%= current_user.social_security_earnings.minimum(:year) %>-<%= current_user.social_security_earnings.maximum(:year) %>
                <% else %>
                  No data uploaded
                <% end %>
              </p>
              <% if current_user.social_security_earnings.any? %>
                <div class="mt-2">
                  <%= link_to view_social_security_earnings_data_uploads_path, class: "text-orange-600 hover:text-orange-500 text-sm font-medium" do %>
                    View lifetime earnings →
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
