<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Data Uploads</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload and manage your personal data files</p>
    </div>

    <!-- Category Overview -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Financial Data Category -->
      <%= link_to financial_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-8">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="h-12 w-12 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center">
                  <span class="text-2xl">💰</span>
                </div>
              </div>
              <div class="ml-6 flex-1">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400">Financial Data</h3>
                <p class="text-gray-600 dark:text-gray-400">Bank statements, investments, and earnings data</p>
                <div class="mt-3 grid grid-cols-3 gap-4 text-sm">
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= current_user.bank_statements.count %></p>
                    <p class="text-gray-500 dark:text-gray-400">Bank Records</p>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= current_user.investments.count %></p>
                    <p class="text-gray-500 dark:text-gray-400">Investments</p>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= current_user.social_security_earnings.count %></p>
                    <p class="text-gray-500 dark:text-gray-400">SSA Years</p>
                  </div>
                </div>
              </div>
              <div class="ml-4">
                <svg class="h-5 w-5 text-gray-400 group-hover:text-green-600 dark:group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Personal Data Category -->
      <%= link_to personal_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-8">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="h-12 w-12 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center">
                  <span class="text-2xl">👤</span>
                </div>
              </div>
              <div class="ml-6 flex-1">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">Personal Data</h3>
                <p class="text-gray-600 dark:text-gray-400">Communications, health, contacts, and calendar data</p>
                <div class="mt-3">
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.contacts.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">Contacts</p>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.calendar_events.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">Events</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="ml-4">
                <svg class="h-5 w-5 text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>
      <% end %>


      <!-- Entertainment Category -->
      <%= link_to entertainment_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-8">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="h-12 w-12 bg-red-100 dark:bg-red-900 rounded-lg flex items-center justify-center">
                  <span class="text-2xl">🎬</span>
                </div>
              </div>
              <div class="ml-6 flex-1">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400">Entertainment</h3>
                <p class="text-gray-600 dark:text-gray-400">Netflix, YouTube, podcasts, and media consumption</p>
                <div class="mt-3">
                  <div class="grid grid-cols-4 gap-4">
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.entertainment_contents.netflix.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">Netflix</p>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.entertainment_contents.youtube.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">YouTube</p>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.podcast_feeds.active.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">Podcast Feeds</p>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-white"><%= current_user.entertainment_contents.audible_books.count %></p>
                      <p class="text-gray-500 dark:text-gray-400">Audible</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="ml-4">
                <svg class="h-5 w-5 text-gray-400 group-hover:text-red-600 dark:group-hover:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Quick Upload Actions -->
    <div class="mb-12">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Quick Upload</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Direct access to upload forms</p>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
            <%= link_to ally_bank_statements_data_uploads_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-300 dark:hover:border-blue-600 transition-colors" do %>
              <svg class="h-6 w-6 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Bank Statements</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload Ally CSV files</p>
              </div>
            <% end %>

            <%= link_to fidelity_data_data_uploads_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-green-50 dark:hover:bg-green-900/20 hover:border-green-300 dark:hover:border-green-600 transition-colors" do %>
              <svg class="h-6 w-6 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Investment Data</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload Fidelity Transactions & Positions</p>
              </div>
            <% end %>

            <%= link_to social_security_index_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-orange-50 dark:hover:bg-orange-900/20 hover:border-orange-300 dark:hover:border-orange-600 transition-colors" do %>
              <svg class="h-6 w-6 text-orange-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">SSA Earnings</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload Social Security XML</p>
              </div>
            <% end %>

            <%= link_to amazon_orders_data_uploads_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-yellow-50 dark:hover:bg-yellow-900/20 hover:border-yellow-300 dark:hover:border-yellow-600 transition-colors" do %>
              <svg class="h-6 w-6 text-yellow-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Amazon Orders</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload Digital & Retail CSV</p>
              </div>
            <% end %>

            <%= link_to communications_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-purple-50 dark:hover:bg-purple-900/20 hover:border-purple-300 dark:hover:border-purple-600 transition-colors" do %>
              <svg class="h-6 w-6 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Communications</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload MBOX & LinkedIn Messages</p>
              </div>
            <% end %>

            <%= link_to calendars_data_uploads_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/20 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors" do %>
              <svg class="h-6 w-6 text-indigo-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Calendar Data</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload ICS Files & URLs</p>
              </div>
            <% end %>

            <%= link_to contacts_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-teal-50 dark:hover:bg-teal-900/20 hover:border-teal-300 dark:hover:border-teal-600 transition-colors" do %>
              <svg class="h-6 w-6 text-teal-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Contacts</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload vCard Files & ZIP</p>
              </div>
            <% end %>

            <%= link_to netflix_entertainment_index_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 hover:border-red-300 dark:hover:border-red-600 transition-colors" do %>
              <svg class="h-6 w-6 text-red-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Netflix Data</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Upload Netflix CSV</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="mt-12">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Recent Data</h3>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Ally Bank Statements</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.bank_statements.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                Last upload: <%= current_user.bank_statements.maximum(:created_at)&.strftime("%B %d, %Y") || "Never" %>
              </p>
              <% if current_user.bank_statements.any? %>
                <div class="mt-2">
                  <%= link_to view_ally_bank_statements_data_uploads_path, class: "text-blue-600 hover:text-blue-500 text-sm font-medium" do %>
                    View all records →
                  <% end %>
                </div>
              <% end %>
            </div>
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Investment Records</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.investments.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                Last upload: <%= current_user.investments.maximum(:created_at)&.strftime("%B %d, %Y") || "Never" %>
              </p>
              <% if current_user.investments.any? %>
                <div class="mt-2">
                  <%= link_to view_investments_data_uploads_path, class: "text-green-600 hover:text-green-500 text-sm font-medium" do %>
                    View all records →
                  <% end %>
                </div>
              <% end %>
            </div>
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Social Security Earnings</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.social_security_earnings.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                <% if current_user.social_security_earnings.any? %>
                  Years: <%= current_user.social_security_earnings.minimum(:year) %>-<%= current_user.social_security_earnings.maximum(:year) %>
                <% else %>
                  No data uploaded
                <% end %>
              </p>
              <% if current_user.social_security_earnings.any? %>
                <div class="mt-2">
                  <%= link_to view_earnings_social_security_index_path, class: "text-orange-600 hover:text-orange-500 text-sm font-medium" do %>
                    View lifetime earnings →
                  <% end %>
                </div>
              <% end %>
            </div>
            <div>
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Amazon Orders</h4>
              <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-white">
                <%= current_user.amazon_orders.count %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                Last upload: <%= current_user.amazon_orders.maximum(:created_at)&.strftime("%B %d, %Y") || "Never" %>
              </p>
              <% if current_user.amazon_orders.any? %>
                <div class="mt-2">
                  <%= link_to view_amazon_orders_data_uploads_path, class: "text-yellow-600 hover:text-yellow-500 text-sm font-medium" do %>
                    View all orders →
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
