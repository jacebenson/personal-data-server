<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Personal Dashboard</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Your personal data at a glance</p>
    </div>

    <!-- Health Data Section - Full Width -->
    <div class="mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center">
            <div class="h-8 w-8 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-3">
              <span class="text-xl">🏥</span>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Health Data</h3>
          </div>
        </div>
        <div class="p-6">
          <% health_patient = HealthPatient.first %>
          <% if health_patient %>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
              <!-- Weight Chart -->
              <div>
                <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Weight Over Time</h4>
                <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg p-4">
                  <% weight_records = health_patient.health_vital_signs.where.not(weight: [nil, "", 0]).where.not(measurement_date: [nil, ""]).where("measurement_date >= ?", 6.months.ago.to_date).order(:measurement_date) %>
                  <% if weight_records.any? %>
                    <% 
                      # Debug: show raw data
                      Rails.logger.debug "Weight records count: #{weight_records.count}"
                      weight_records.each do |record|
                        weight_kg = record.weight.to_f
                        weight_lbs = (weight_kg * 2.20462).round(1)
                        Rails.logger.debug "Record #{record.id}: #{record.measurement_date} - #{weight_kg}kg = #{weight_lbs}lbs"
                      end
                      
                      # Prepare data for chart
                      chart_data = weight_records.map do |record|
                        weight_kg = record.weight.to_f
                        weight_lbs = (weight_kg * 2.20462).round(1)
                        date = Date.parse(record.measurement_date)
                        [date.strftime("%m/%d/%y"), weight_lbs]
                      end
                      
                      # Also show current stats
                      latest_weight = weight_records.last
                      first_weight = weight_records.first
                      latest_weight_kg = latest_weight.weight.to_f
                      latest_weight_lbs = (latest_weight_kg * 2.20462).round(1)
                      first_weight_lbs = (first_weight.weight.to_f * 2.20462).round(1)
                      
                      Rails.logger.debug "Latest weight: #{latest_weight.measurement_date} - #{latest_weight_kg}kg = #{latest_weight_lbs}lbs"
                      Rails.logger.debug "First weight: #{first_weight.measurement_date} - #{first_weight.weight.to_f}kg = #{first_weight_lbs}lbs"
                    %>
                    
                    <!-- Chart -->
                    <%= line_chart chart_data, 
                        height: "200px",
                        min: 200,
                        colors: ["#3B82F6"],
                        suffix: " lbs",
                        curve: false,
                        library: {
                          backgroundColor: "transparent",
                          borderColor: "#3B82F6",
                          borderWidth: 2,
                          pointBackgroundColor: "#3B82F6",
                          pointBorderColor: "#FFFFFF",
                          pointBorderWidth: 2,
                          pointRadius: 4,
                          tension: 0.1
                        } %>
                    
                    <!-- Current stats overlay -->
                    <div class="mt-2 text-center">
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        Current: <%= latest_weight_lbs %> lbs
                        <% if weight_records.count > 1 %>
                          <% weight_change_lbs = latest_weight_lbs - first_weight_lbs %>
                          <span class="ml-2 <%= weight_change_lbs > 0 ? 'text-red-600' : 'text-green-600' %>">
                            (<%= weight_change_lbs > 0 ? '+' : '' %><%= weight_change_lbs.round(1) %> lbs)
                          </span>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="flex items-center justify-center h-full">
                      <p class="text-gray-500 dark:text-gray-400">No weight data available</p>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <!-- Sleep Chart -->
              <div>
                <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">CPAP Usage (Last 7 Days)</h4>
                <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center relative">
                  <div class="text-center">
                    <svg class="h-12 w-12 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                      Bar chart with 8hr goal line<br>
                      <%= health_patient.health_sleep_data.where(session_date: 7.days.ago..Date.current).count %> sleep sessions
                    </p>
                  </div>
                  <!-- 8 hour goal line placeholder -->
                  <div class="absolute top-1/2 left-4 right-4 border-t-2 border-dashed border-red-400 opacity-50"></div>
                  <span class="absolute top-1/2 right-2 text-xs text-red-500 bg-white dark:bg-gray-800 px-1">8hrs</span>
                </div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-12">
              <p class="text-gray-500 dark:text-gray-400">No health data available</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Other Categories -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Financial Data Category -->
      <%= link_to financial_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-6">
            <div class="flex items-center mb-4">
              <div class="h-10 w-10 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-3">
                <span class="text-xl">�</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400">Money</h3>
            </div>
            <div class="space-y-3">
              <div>
                <p class="text-2xl font-bold text-gray-900 dark:text-white">
                  $<%= number_with_delimiter((current_user.investments.sum(:amount) / 1000).round(0)) %>k / $1.2M
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">(goal)</p>
              </div>
              <div>
                <p class="text-lg font-semibold text-gray-900 dark:text-white">
                  $<%= number_with_delimiter(current_user.bank_statements.where(account: 'Ally Personal Checking').sum(:amount).round(0)) %> in your pocket
                </p>
              </div>
            </div>
            <div class="mt-4 flex justify-end">
              <svg class="h-5 w-5 text-gray-400 group-hover:text-green-600 dark:group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Personal Data Category -->
      <%= link_to personal_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-6">
            <div class="flex items-center mb-4">
              <div class="h-10 w-10 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-3">
                <span class="text-xl">📅</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">Events + Msgs</h3>
            </div>
            <div class="space-y-2">
              <% today_events = current_user.calendar_events.today.chronological.limit(2) %>
              <% if today_events.any? %>
                <% today_events.each do |event| %>
                  <div class="text-sm">
                    <span class="font-medium text-gray-900 dark:text-white">
                      <%= event.start_time&.strftime("%l:%M%p")&.downcase || "All day" %>
                    </span>
                    <span class="text-gray-600 dark:text-gray-300 ml-1"><%= event.summary %></span>
                    <% if event.location.present? %>
                      <span class="text-gray-500 dark:text-gray-400 ml-1">@ <%= event.location %></span>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-500 dark:text-gray-400">No events today</p>
              <% end %>
            </div>
            <div class="mt-4 flex justify-end">
              <svg class="h-5 w-5 text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Entertainment Category -->
      <%= link_to entertainment_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="p-6">
            <div class="flex items-center mb-4">
              <div class="h-10 w-10 bg-red-100 dark:bg-red-900 rounded-lg flex items-center justify-center mr-3">
                <span class="text-xl">�</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400">Entertainment</h3>
            </div>
            <div class="space-y-2">
              <div class="flex items-center text-sm">
                <span class="text-lg mr-2">👀</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  <%= current_user.entertainment_contents.where(
                    content_type: ['netflix', 'youtube'],
                    date_consumed: Date.current.beginning_of_day..Date.current.end_of_day
                  ).count %>
                </span>
                <span class="text-gray-600 dark:text-gray-300 ml-1">videos today</span>
              </div>
              <div class="flex items-center text-sm">
                <span class="text-lg mr-2">👂</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  <%= current_user.entertainment_contents.where(
                    content_type: 'podcast',
                    date_consumed: 1.week.ago.beginning_of_day..Time.current
                  ).count %>
                </span>
                <span class="text-gray-600 dark:text-gray-300 ml-1">new podcast ep.</span>
              </div>
            </div>
            <div class="mt-4 flex justify-end">
              <svg class="h-5 w-5 text-gray-400 group-hover:text-red-600 dark:group-hover:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>
