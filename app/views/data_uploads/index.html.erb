<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Personal Dashboard</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Your personal data at a glance</p>
      </div>
      <!-- Privacy Toggle -->
      <div class="flex items-center space-x-3">
        <span class="text-sm text-gray-600 dark:text-gray-400">Privacy Mode</span>
        <button id="privacy-toggle" type="button" class="relative inline-flex h-6 w-11 items-center rounded-full bg-gray-200 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:bg-gray-600 cursor-pointer">
          <span class="sr-only">Toggle privacy mode</span>
          <span id="privacy-toggle-switch" class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-1"></span>
        </button>
        <span class="text-sm text-gray-600 dark:text-gray-400">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        </span>
      </div>
    </div>

    <!-- Health Data Section - Full Width -->
    <div class="mb-8">
      <%= link_to health_index_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="h-8 w-8 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-3">
                  <span class="text-xl">🏥</span>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400">Health</h3>
              </div>
              <svg class="h-5 w-5 text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        <div class="p-6">
          <% health_patient = HealthPatient.first %>
          <% if health_patient %>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
              <!-- Weight Chart -->
              <div>
                <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Weight Over Time</h4>
                <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg p-4">
                  <% weight_records = health_patient.health_vital_signs.where.not(weight: [nil, "", 0]).where.not(measurement_date: [nil, ""]).where("measurement_date >= ?", 6.months.ago.to_date).order(:measurement_date) %>
                  <% if weight_records.any? %>
                    <% 
                      # Debug: show raw data
                      Rails.logger.debug "Weight records count: #{weight_records.count}"
                      weight_records.each do |record|
                        weight_kg = record.weight.to_f
                        weight_lbs = (weight_kg * 2.20462).round(1)
                        Rails.logger.debug "Record #{record.id}: #{record.measurement_date} - #{weight_kg}kg = #{weight_lbs}lbs"
                      end
                      
                      # Prepare data for chart
                      chart_data = weight_records.map do |record|
                        weight_kg = record.weight.to_f
                        weight_lbs = (weight_kg * 2.20462).round(1)
                        date = Date.parse(record.measurement_date)
                        [date.strftime("%m/%d/%y"), weight_lbs]
                      end
                      
                      # Also show current stats
                      latest_weight = weight_records.last
                      first_weight = weight_records.first
                      latest_weight_kg = latest_weight.weight.to_f
                      latest_weight_lbs = (latest_weight_kg * 2.20462).round(1)
                      first_weight_lbs = (first_weight.weight.to_f * 2.20462).round(1)
                      
                      Rails.logger.debug "Latest weight: #{latest_weight.measurement_date} - #{latest_weight_kg}kg = #{latest_weight_lbs}lbs"
                      Rails.logger.debug "First weight: #{first_weight.measurement_date} - #{first_weight.weight.to_f}kg = #{first_weight_lbs}lbs"
                    %>
                    
                    <!-- Chart -->
                    <%= line_chart chart_data, 
                        height: "200px",
                        min: 350,
                        colors: ["#3B82F6"],
                        suffix: " lbs",
                        curve: false,
                        discrete: true,
                        library: {
                          backgroundColor: "transparent",
                          borderColor: "#3B82F6",
                          borderWidth: 2,
                          pointBackgroundColor: "#3B82F6",
                          pointBorderColor: "#FFFFFF",
                          pointBorderWidth: 2,
                          pointRadius: 4,
                          tension: 0.1,
                          scales: {
                            y: {
                              display: false
                            }
                          }
                        } %>
                    
                    <!-- Current stats overlay -->
                    <div class="mt-2 text-center">
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        Current: <span class="privacy-sensitive"><%= latest_weight_lbs %> lbs</span>
                        <% if weight_records.count > 1 %>
                          <% weight_change_lbs = latest_weight_lbs - first_weight_lbs %>
                          <span class="ml-2 <%= weight_change_lbs > 0 ? 'text-red-600' : 'text-green-600' %>">
                            (<span class="privacy-sensitive"><%= weight_change_lbs > 0 ? '+' : '' %><%= weight_change_lbs.round(1) %> lbs</span>)
                          </span>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="flex items-center justify-center h-full">
                      <p class="text-gray-500 dark:text-gray-400">No weight data available</p>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <!-- Sleep Chart -->
              <div>
                <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Sleep</h4>
                <div class="h-64 bg-gray-100 dark:bg-gray-700 rounded-lg p-4">
                  <% sleep_records = health_patient.health_sleep_data.where(session_date: 30.days.ago..Date.current).order(:session_date) %>
                  <% if sleep_records.any? %>
                    <% 
                      # Prepare data for chart - convert scientific notation to hours
                      chart_data = sleep_records.map do |record|
                        usage_hours = record.usage_hours.to_f
                        date = Date.parse(record.session_date.to_s)
                        [date.strftime("%m/%d"), usage_hours.round(1)]
                      end
                      
                      # Get latest stats
                      latest_record = sleep_records.last
                      latest_hours = latest_record.usage_hours.to_f
                      hours = latest_hours.to_i
                      minutes = ((latest_hours - hours) * 60).round
                      
                      # Calculate average
                      avg_hours = sleep_records.average(:usage_hours).to_f
                    %>
                    
                    <!-- Chart with 8-hour goal line -->
                    <div class="relative">
                      <%= column_chart chart_data, 
                          height: "180px",
                          max: 10,
                          colors: ["#3B82F6"],
                          suffix: "h" %>
                      
                      <!-- 8-hour goal line overlay -->
                      <div class="absolute inset-0 pointer-events-none">
                        <div class="absolute left-12 right-4 border-t-2 border-dashed border-red-500 opacity-75" style="top: <%= 180 - (8.0 / 10.0 * 180) %>px;">
                        </div>
                        <span class="absolute right-1 text-xs text-red-600 bg-white dark:bg-gray-700 px-1 rounded" style="top: <%= 180 - (8.0 / 10.0 * 180) - 10 %>px;">8h goal</span>
                      </div>
                    </div>
                    
                    <!-- Current stats -->
                    <div class="mt-2 flex justify-between text-sm">
                      <div class="text-gray-900 dark:text-white">
                        <span class="font-medium">Last: <%= hours %>h <%= minutes %>m</span>
                      </div>
                      <div class="text-gray-600 dark:text-gray-300">
                        Avg: <%= avg_hours.round(1) %>h
                      </div>
                    </div>
                  <% else %>
                    <div class="flex items-center justify-center h-full">
                      <p class="text-gray-500 dark:text-gray-400">No sleep data available</p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-12">
              <p class="text-gray-500 dark:text-gray-400">No health data available</p>
            </div>
          <% end %>
        </div>
      </div>
      <% end %>
    </div>

    <!-- Other Categories -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Financial Data Category -->
      <%= link_to financial_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="h-8 w-8 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-3">
                  <span class="text-xl">💸</span>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400">Money</h3>
              </div>
              <svg class="h-5 w-5 text-gray-400 group-hover:text-green-600 dark:group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
          <div class="p-6">
            <div class="space-y-3">
              <div>
                <p class="text-2xl font-bold text-gray-900 dark:text-white">
                  <span class="privacy-sensitive">$<%= number_with_delimiter((current_user.investments.sum(:amount) / 1000).round(0)) %>k</span> / <span class="privacy-sensitive">$1.2M</span>
                </p>
              </div>
              <div>
                <p class="text-lg font-semibold text-gray-900 dark:text-white">
                  <span class="privacy-sensitive">$<%= number_with_delimiter(current_user.bank_statements.where(account: 'Ally Personal Checking').sum(:amount).round(0)) %></span> in your pocket
                </p>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Personal Data Category -->
      <%= link_to personal_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="h-8 w-8 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-3">
                  <span class="text-xl">📅</span>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">Events + Msgs</h3>
              </div>
              <svg class="h-5 w-5 text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
          <div class="p-6">
            <div class="space-y-2">
              <% today_events = current_user.calendar_events.today.chronological.limit(2) %>
              <% if today_events.any? %>
                <% today_events.each do |event| %>
                  <div class="text-sm">
                    <span class="font-medium text-gray-900 dark:text-white">
                      <%= event.start_time&.strftime("%l:%M%p")&.downcase || "All day" %>
                    </span>
                    <span class="text-gray-600 dark:text-gray-300 ml-1"><%= event.summary %></span>
                    <% if event.location.present? %>
                      <span class="text-gray-500 dark:text-gray-400 ml-1">@ <%= event.location %></span>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-500 dark:text-gray-400">No events today</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Entertainment Category -->
      <%= link_to entertainment_path, class: "group block" do %>
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="h-8 w-8 bg-red-100 dark:bg-red-900 rounded-lg flex items-center justify-center mr-3">
                  <span class="text-xl">🎬</span>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-red-600 dark:group-hover:text-red-400">Entertainment</h3>
              </div>
              <svg class="h-5 w-5 text-gray-400 group-hover:text-red-600 dark:group-hover:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
          <div class="p-6">
            <div class="space-y-2">
              <div class="flex items-center text-sm">
                <span class="text-lg mr-2">👀</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  <%= current_user.entertainment_contents.where(
                    content_type: ['netflix', 'youtube'],
                    date_consumed: Date.current.beginning_of_day..Date.current.end_of_day
                  ).count %>
                </span>
                <span class="text-gray-600 dark:text-gray-300 ml-1">videos today</span>
              </div>
              <div class="flex items-center text-sm">
                <span class="text-lg mr-2">👂</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  <%= current_user.entertainment_contents.where(
                    content_type: 'podcast',
                    date_consumed: 1.week.ago.beginning_of_day..Time.current
                  ).count %>
                </span>
                <span class="text-gray-600 dark:text-gray-300 ml-1">new podcast ep.</span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>

<style>
  .privacy-sensitive {
    transition: filter 0.3s ease;
  }
  
  .privacy-mode .privacy-sensitive {
    filter: blur(4px);
    user-select: none;
  }
  
  .privacy-mode .privacy-sensitive:hover {
    filter: blur(2px);
  }
  
  /* Chart axis blurring in privacy mode */
  .privacy-mode .chartkick-chart svg text {
    filter: blur(4px);
  }
  
  .privacy-mode .chartkick-chart .highcharts-axis-labels text {
    filter: blur(4px);
  }
  
  /* Toggle switch styles */
  .privacy-active {
    background-color: #3B82F6 !important;
  }
  
  .privacy-active .toggle-switch {
    transform: translateX(1.25rem);
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const privacyToggle = document.getElementById('privacy-toggle');
  const privacySwitch = document.getElementById('privacy-toggle-switch');
  const body = document.body;
  
  if (!privacyToggle || !privacySwitch) {
    console.error('Privacy toggle elements not found');
    return;
  }
  
  // Load saved privacy state
  const isPrivacyMode = localStorage.getItem('privacyMode') === 'true';
  
  if (isPrivacyMode) {
    enablePrivacyMode();
  }
  
  privacyToggle.addEventListener('click', function(e) {
    e.preventDefault();
    console.log('Privacy toggle clicked'); // Debug log
    
    if (body.classList.contains('privacy-mode')) {
      disablePrivacyMode();
    } else {
      enablePrivacyMode();
    }
  });
  
  function enablePrivacyMode() {
    console.log('Enabling privacy mode'); // Debug log
    body.classList.add('privacy-mode');
    privacyToggle.classList.add('privacy-active');
    privacySwitch.style.transform = 'translateX(1.25rem)';
    localStorage.setItem('privacyMode', 'true');
  }
  
  function disablePrivacyMode() {
    console.log('Disabling privacy mode'); // Debug log
    body.classList.remove('privacy-mode');
    privacyToggle.classList.remove('privacy-active');
    privacySwitch.style.transform = 'translateX(0.25rem)';
    localStorage.setItem('privacyMode', 'false');
  }
});
</script>
