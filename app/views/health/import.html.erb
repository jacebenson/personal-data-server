<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to health_index_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Health Records
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Upload Health Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Choose your data source and upload your health information</p>
    </div>

    <!-- Import Options Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
      
      <!-- Epic XML Import Card -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="bg-blue-600 px-6 py-4">
          <div class="flex items-center">
            <svg class="h-8 w-8 text-white mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            <h3 class="text-lg font-semibold text-white">Epic XML Import</h3>
          </div>
          <p class="mt-2 text-blue-100 text-sm">Healthcare Provider Records</p>
        </div>
        
        <div class="p-6">
          <%= form_with url: process_import_health_index_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>
            <%= form.hidden_field :file_type, value: "xml" %>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Upload XML File
              </label>
              <%= form.file_field :xml_file,
                  accept: ".xml,.XML",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
            </div>
            
            <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-blue-800 dark:text-blue-200 mb-2">What's Included:</h4>
              <ul class="text-xs text-blue-700 dark:text-blue-300 space-y-1">
                <li>• Patient demographics</li>
                <li>• Allergies & reactions</li>
                <li>• Medications & prescriptions</li>
                <li>• Medical problems & diagnoses</li>
                <li>• Immunization records</li>
                <li>• Vital signs & measurements</li>
                <li>• Healthcare encounters</li>
              </ul>
            </div>
            
            <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-yellow-800 dark:text-yellow-200 mb-1">How to Export:</h4>
              <p class="text-xs text-yellow-700 dark:text-yellow-300">
                Access your patient portal (Epic MyChart, Cerner, etc.) and look for "Download My Data", "Export Health Records", or "Continuity of Care Document (CCD)".
              </p>
            </div>
            
            <%= form.submit "Upload Epic XML",
                class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          <% end %>
        </div>
      </div>

      <!-- Shotsy CSV Import Card -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="bg-green-600 px-6 py-4">
          <div class="flex items-center">
            <svg class="h-8 w-8 text-white mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
            <h3 class="text-lg font-semibold text-white">Shotsy CSV Import</h3>
          </div>
          <p class="mt-2 text-green-100 text-sm">GLP-1 Medication Tracking</p>
        </div>
        
        <div class="p-6">
          <%= form_with url: process_import_health_index_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>
            <%= form.hidden_field :file_type, value: "shotsy" %>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Upload Shotsy CSV
              </label>
              <%= form.file_field :csv_file,
                  accept: ".csv,.CSV",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 dark:file:bg-green-900 dark:file:text-green-300" %>
            </div>
            
            <div class="bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-green-800 dark:text-green-200 mb-2">What's Included:</h4>
              <ul class="text-xs text-green-700 dark:text-green-300 space-y-1">
                <li>• GLP-1 medication tracking</li>
                <li>• Weight measurements & BMI</li>
                <li>• Injection site & pain levels</li>
                <li>• Side effect monitoring</li>
                <li>• Nutrition data</li>
                <li>• Daily notes & adherence</li>
              </ul>
            </div>
            
            <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-yellow-800 dark:text-yellow-200 mb-1">How to Export:</h4>
              <p class="text-xs text-yellow-700 dark:text-yellow-300">
                In the Shotsy app, go to Settings → Export Data → Download CSV to get your complete medication tracking data.
              </p>
            </div>
            
            <%= form.submit "Upload Shotsy CSV",
                class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
          <% end %>
        </div>
      </div>

      <!-- ResMed CSV Import Card -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="bg-purple-600 px-6 py-4">
          <div class="flex items-center">
            <svg class="h-8 w-8 text-white mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
            <h3 class="text-lg font-semibold text-white">ResMed CSV Import</h3>
          </div>
          <p class="mt-2 text-purple-100 text-sm">CPAP Sleep Data</p>
        </div>
        
        <div class="p-6">
          <%= form_with url: process_import_health_index_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>
            <%= form.hidden_field :file_type, value: "resmed" %>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Upload ResMed CSV
              </label>
              <%= form.file_field :csv_file,
                  accept: ".csv,.CSV",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 dark:file:bg-purple-900 dark:file:text-purple-300" %>
            </div>
            
            <div class="bg-purple-50 dark:bg-purple-900 border border-purple-200 dark:border-purple-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-purple-800 dark:text-purple-200 mb-2">What's Included:</h4>
              <ul class="text-xs text-purple-700 dark:text-purple-300 space-y-1">
                <li>• Sleep session duration</li>
                <li>• AHI scores & sleep quality</li>
                <li>• Mask fit & leak measurements</li>
                <li>• CPAP compliance tracking</li>
                <li>• Therapy settings & modes</li>
                <li>• Usage hours & patterns</li>
              </ul>
            </div>
            
            <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-md p-3">
              <h4 class="text-sm font-medium text-yellow-800 dark:text-yellow-200 mb-1">How to Export:</h4>
              <p class="text-xs text-yellow-700 dark:text-yellow-300">
                In the ResMed myAir app, goto settings, then "Download my data", and they will email you a CSV file with your sleep data.
              </p>
            </div>
            
            <%= form.submit "Upload ResMed CSV",
                class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Privacy Notice -->
    <div class="bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-green-800 dark:text-green-200">Privacy & Security</h3>
          <div class="mt-2 text-sm text-green-700 dark:text-green-300">
            <ul class="list-disc list-inside space-y-1">
              <li>Your health data is stored securely and privately</li>
              <li>Data is processed locally and not shared with third parties</li>
              <li>Existing records are preserved and deduplicated automatically</li>
              <li>Large files may take several minutes to process</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
