<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to health_index_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Health Records
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Upload Health Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload CCD/CCDA XML files from healthcare providers or Shotsy CSV tracking data</p>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Upload Health File</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Select XML files from healthcare providers or CSV files from health tracking apps
        </p>
      </div>

      <div class="p-6">
        <%= form_with url: process_import_health_index_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
          <!-- File Type Selection -->
          <div>
            <fieldset class="space-y-4">
              <legend class="text-sm font-medium text-gray-700 dark:text-gray-300">Select file type:</legend>
              
              <div class="space-y-4">
                <!-- XML Upload Option -->
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                  <div class="flex items-start">
                    <div class="flex items-center h-5">
                      <input id="xml_option" name="file_type" type="radio" value="xml" checked 
                             class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 dark:border-gray-600">
                    </div>
                    <div class="ml-3 flex-1">
                      <label for="xml_option" class="font-medium text-gray-700 dark:text-gray-300">
                        Healthcare Provider XML (CCD/CCDA)
                      </label>
                      <p class="text-sm text-gray-500 dark:text-gray-400">
                        Upload XML files exported from healthcare provider portals (Epic, Cerner, etc.)
                      </p>
                      <div class="mt-2" id="xml_upload_area">
                        <%= form.file_field :xml_file,
                            accept: ".xml,.XML",
                            class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- CSV Upload Option -->
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                  <div class="flex items-start">
                    <div class="flex items-center h-5">
                      <input id="csv_option" name="file_type" type="radio" value="csv" 
                             class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 dark:border-gray-600">
                    </div>
                    <div class="ml-3 flex-1">
                      <label for="csv_option" class="font-medium text-gray-700 dark:text-gray-300">
                        Shotsy CSV Export
                      </label>
                      <p class="text-sm text-gray-500 dark:text-gray-400">
                        Upload CSV data exported from the Shotsy app (GLP-1 medication tracking, weight, etc.)
                      </p>
                      <div class="mt-2" id="csv_upload_area" style="display: none;">
                        <%= form.file_field :csv_file,
                            accept: ".csv,.CSV",
                            class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 dark:file:bg-green-900 dark:file:text-green-300" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </fieldset>
          </div>

          <!-- Expected Format Info -->
          <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">Supported Health Data Formats</h3>
                <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
                  <div class="space-y-3">
                    <div>
                      <p class="font-semibold">XML Files (Healthcare Providers):</p>
                      <ul class="list-disc list-inside mt-1 space-y-1">
                        <li>Patient demographic information</li>
                        <li>Allergies and adverse reactions</li>
                        <li>Current and past medications</li>
                        <li>Medical problems and diagnoses</li>
                        <li>Immunization records</li>
                        <li>Vital signs and measurements</li>
                        <li>Healthcare encounters and visits</li>
                      </ul>
                      <p class="mt-1"><strong>Supported formats:</strong> HL7 CCD, HL7 CCDA, Patient Health Summary documents</p>
                    </div>
                    
                    <div>
                      <p class="font-semibold">CSV Files (Shotsy App):</p>
                      <ul class="list-disc list-inside mt-1 space-y-1">
                        <li>GLP-1 medication tracking (Semaglutide, Ozempic, etc.)</li>
                        <li>Weight measurements and BMI</li>
                        <li>Injection site and pain level tracking</li>
                        <li>Side effect monitoring (nausea, appetite, etc.)</li>
                        <li>Nutrition data (calories, protein)</li>
                        <li>Daily notes and medication adherence</li>
                      </ul>
                      <p class="mt-1"><strong>Expected columns:</strong> Date, Shot, Avg Level (mg), Weight, Site, Pain Level, Side Effects</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Healthcare Provider Info -->
          <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-200">How to Export Data</h3>
                <div class="mt-2 text-sm text-yellow-700 dark:text-yellow-300 space-y-2">
                  <div>
                    <p class="font-semibold">Healthcare Provider XML:</p>
                    <p>Most providers offer data exports through patient portals. Look for "Download My Data", "Export Health Records", or "Continuity of Care Document (CCD)". Common systems: Epic MyChart, Cerner HealtheLife.</p>
                  </div>
                  <div>
                    <p class="font-semibold">Shotsy CSV:</p>
                    <p>In the Shotsy app, go to Settings → Export Data → Download CSV. This will include all your GLP-1 medication tracking, weight data, and side effect monitoring.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Privacy Notice -->
          <div class="bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-green-800 dark:text-green-200">Privacy & Security</h3>
                <div class="mt-2 text-sm text-green-700 dark:text-green-300">
                  <ul class="list-disc list-inside space-y-1">
                    <li>Your health data is stored securely and privately</li>
                    <li>Data is processed locally and not shared with third parties</li>
                    <li>Existing records are preserved and deduplicated automatically</li>
                    <li>Large files may take several minutes to process</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex justify-end">
            <%= form.submit "Upload Health Data",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const xmlOption = document.getElementById('xml_option');
  const csvOption = document.getElementById('csv_option');
  const xmlUploadArea = document.getElementById('xml_upload_area');
  const csvUploadArea = document.getElementById('csv_upload_area');
  const xmlFileInput = document.querySelector('#xml_file');
  const csvFileInput = document.querySelector('#csv_file');

  function toggleUploadAreas() {
    if (xmlOption.checked) {
      xmlUploadArea.style.display = 'block';
      csvUploadArea.style.display = 'none';
      csvFileInput.value = '';
      xmlFileInput.required = true;
      csvFileInput.required = false;
    } else if (csvOption.checked) {
      xmlUploadArea.style.display = 'none';
      csvUploadArea.style.display = 'block';
      xmlFileInput.value = '';
      xmlFileInput.required = false;
      csvFileInput.required = true;
    }
  }

  xmlOption.addEventListener('change', toggleUploadAreas);
  csvOption.addEventListener('change', toggleUploadAreas);
  
  // Initialize on page load
  toggleUploadAreas();
});
</script>
