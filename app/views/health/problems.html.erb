<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="md:flex md:items-center md:justify-between">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Problems - <%= @patient.full_name %>
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        Patient DOB: <%= @patient.formatted_birth_date || 'Not specified' %>
        <span class="mx-2">•</span>
        Gender: <%= @patient.gender&.capitalize || 'Not specified' %>
      </p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4 space-x-3">
      <%= link_to "← Back to Overview", health_path(@patient),
          class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200" %>
    </div>
  </div>

  <!-- Active Problems -->
  <div class="mt-8">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Active Problems (<%= @active_problems.count %>)</h2>
    <% if @active_problems.any? %>
      <div class="bg-white shadow overflow-hidden sm:rounded-md mb-8">
        <ul class="divide-y divide-gray-200">
          <% @active_problems.each do |problem| %>
            <li class="px-6 py-4">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-lg font-medium text-gray-900">
                    <%= problem.problem_name %>
                  </p>
                  <div class="mt-2 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-500">
                    <% if problem.onset_date.present? %>
                      <span class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
                        </svg>
                        Onset: <span class="ml-1 font-medium"><%= problem.onset_date.strftime("%m/%d/%Y") %></span>
                      </span>
                    <% end %>
                    <% if problem.code.present? %>
                      <span class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                        </svg>
                        Code: <span class="ml-1 font-medium"><%= problem.code %></span>
                      </span>
                    <% end %>
                  </div>
                  <% if problem.status.present? %>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%=
                        case problem.status&.downcase
                        when 'active'
                          'bg-red-100 text-red-800'
                        when 'resolved'
                          'bg-green-100 text-green-800'
                        when 'inactive'
                          'bg-gray-100 text-gray-800'
                        else
                          'bg-blue-100 text-blue-800'
                        end
                      %>">
                        <%= problem.status.capitalize %>
                      </span>
                    </div>
                  <% end %>
                  <% if problem.code_system.present? %>
                    <div class="mt-3 text-sm text-gray-600">
                      <p><strong>Code System:</strong> <%= problem.code_system %></p>
                    </div>
                  <% end %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="text-center py-8 mb-8">
        <svg class="mx-auto h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No active problems</h3>
        <p class="mt-1 text-sm text-gray-500">No active problems are on file for this patient.</p>
      </div>
    <% end %>

    <!-- Resolved Problems -->
    <% if @resolved_problems.any? %>
      <h2 class="text-lg font-medium text-gray-900 mb-4">Resolved Problems (<%= @resolved_problems.count %>)</h2>
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <ul class="divide-y divide-gray-200">
          <% @resolved_problems.each do |problem| %>
            <li class="px-6 py-4 bg-gray-50">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-lg font-medium text-gray-700">
                    <%= problem.problem_name %>
                  </p>
                  <div class="mt-2 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-500">
                    <% if problem.onset_date.present? %>
                      <span class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
                        </svg>
                        Onset: <span class="ml-1 font-medium"><%= problem.onset_date.strftime("%m/%d/%Y") %></span>
                      </span>
                    <% end %>
                    <% if problem.resolved_date.present? %>
                      <span class="flex items-center">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        Resolved: <span class="ml-1 font-medium"><%= Date.parse(problem.resolved_date).strftime("%m/%d/%Y") rescue problem.resolved_date %></span>
                      </span>
                    <% end %>
                  </div>
                  <% if problem.status.present? %>
                    <div class="mt-2">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= problem.status.capitalize %>
                      </span>
                    </div>
                  <% end %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</div>
