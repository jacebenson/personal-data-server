<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">👤 Personal Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your personal information and digital footprint</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Communications (Email & Messages) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg opacity-60">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Communications</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">MBOX emails, LinkedIn, Discord messages</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-400"><%= @communications_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
              Coming Soon
            </button>
          </div>
        </div>
      </div>

      <!-- Health Data (Epic XML) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg opacity-60">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Health Records</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Epic MyChart XML exports</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-400"><%= @health_records_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
              Coming Soon
            </button>
          </div>
        </div>
      </div>

      <!-- Contacts (VCards, LinkedIn) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg opacity-60">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Contacts</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">VCard files, LinkedIn connections</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-400"><%= @contacts_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
              Coming Soon
            </button>
          </div>
        </div>
      </div>

      <!-- Calendars (iCal) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg opacity-60">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Calendar Data</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">iCal calendar exports</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-400"><%= @calendar_events_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
              Coming Soon
            </button>
          </div>
        </div>
      </div>

      <!-- Content (YouTube, Goodreads) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg opacity-60">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 1v16a1 1 0 001 1h8a1 1 0 001-1V5H7zm3 3h4m-4 4h4m-4 4h4"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Content & Media</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">YouTube watch history, Goodreads data</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-400"><%= @content_items_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <button disabled class="w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-400 bg-gray-100 cursor-not-allowed">
              Coming Soon
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Coming Soon Features -->
    <div class="mt-12">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Planned Features</h3>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-3">Data Sources</h4>
              <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                <li>• MBOX email archives</li>
                <li>• LinkedIn data exports</li>
                <li>• Discord message history</li>
                <li>• Epic MyChart medical records</li>
                <li>• VCard contact files</li>
                <li>• iCal calendar exports</li>
                <li>• YouTube watch history</li>
                <li>• Goodreads reading data</li>
              </ul>
            </div>
            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-3">Features</h4>
              <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                <li>• Timeline view of all personal data</li>
                <li>• Search across all data types</li>
                <li>• Data visualization and insights</li>
                <li>• Privacy-focused local processing</li>
                <li>• Export capabilities</li>
                <li>• Data relationship mapping</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Quick Actions</h3>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <%= link_to data_uploads_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700" do %>
              <svg class="h-6 w-6 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">All Uploads</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">View all upload options</p>
              </div>
            <% end %>

            <%= link_to financial_path, class: "flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700" do %>
              <svg class="h-6 w-6 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Financial Data</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">View financial categories</p>
              </div>
            <% end %>

            <div class="flex items-center p-4 border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-700">
              <svg class="h-6 w-6 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <div>
                <p class="font-medium text-gray-900 dark:text-white">Search & Analytics</p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Coming Soon</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
