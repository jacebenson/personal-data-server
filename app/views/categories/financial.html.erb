<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
            <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Financial", path: nil }
    ] %>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">💰 Financial Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your financial information and view reports</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Bank Statements -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Ally Bank Statements</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">CSV files from Ally Bank</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @bank_statements_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  Last upload: <%= @last_bank_upload&.strftime("%B %d, %Y") || "Never" %>
                </p>
              </div>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% if @bank_statements_count > 0 %>
              <%= link_to "View All Records", view_ally_bank_statements_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
            <%= link_to "Upload New Statements", ally_bank_statements_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <% if @bank_statements_count > 0 %>
              <%= link_to "Manage Duplicates", manage_duplicates_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Investment Data -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Investment Data</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Fidelity & Principal data</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @investments_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  Last upload: <%= @last_investment_upload&.strftime("%B %d, %Y") || "Never" %>
                </p>
              </div>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% if @investments_count > 0 %>
              <%= link_to "View All Records", view_investments_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
            <%= link_to "Upload Fidelity Data", fidelity_data_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700" %>
            <%= link_to "Upload Principal OFX", principal_investments_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700" %>
          </div>
        </div>
      </div>

      <!-- Social Security Earnings -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">SSA Earnings</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Social Security earnings history</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @ssa_earnings_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  <% if @ssa_earnings_count > 0 %>
                    Last upload: <%= @last_ssa_upload&.strftime("%B %d, %Y") || "Never" %>
                  <% else %>
                    No data uploaded
                  <% end %>
                </p>
              </div>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% if @ssa_earnings_count > 0 %>
              <%= link_to "View Lifetime Earnings", view_earnings_social_security_index_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
            <%= link_to "Upload SSA XML", social_security_index_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700" %>
          </div>
        </div>
      </div>

      <!-- Amazon Shopping -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Amazon Shopping</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Order history and purchase data</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @amazon_orders_count %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  <% if @amazon_orders_count > 0 %>
                    Last upload: <%= @last_amazon_upload&.strftime("%B %d, %Y") || "Never" %>
                  <% else %>
                    No data uploaded
                  <% end %>
                </p>
              </div>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% if @amazon_orders_count > 0 %>
              <%= link_to "View All Orders", view_amazon_orders_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
            <%= link_to "Upload Amazon Orders", amazon_orders_data_uploads_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-yellow-600 hover:bg-yellow-700" %>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
