<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-6">

                            
                            
    
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">💼 LinkedIn Messages</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        View and search your imported LinkedIn messages
      </p>
    </div>
    
   

    <!-- Search and Filters -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <%= form_with url: linkedin_messages_path, method: :get, local: true, class: "space-y-4" do |form| %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
              <%= form.text_field :search_subject, 
                  value: @search_subject,
                  placeholder: "Search content...",
                  class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
            </div>
            <div>
              <%= form.text_field :search_from, 
                  value: @search_from,
                  placeholder: "Search participants...",
                  class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
            </div>
            <div>
              <%= form.date_field :search_date_from, 
                  value: @search_date_from,
                  class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
              <label class="text-xs text-gray-500 dark:text-gray-400">From Date</label>
            </div>
            <div>
              <%= form.date_field :search_date_to, 
                  value: @search_date_to,
                  class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
              <label class="text-xs text-gray-500 dark:text-gray-400">To Date</label>
            </div>
          </div>
          
          <div class="flex items-center space-x-3">
            <%= form.submit "Search", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            
            <% if @search_subject.present? || @search_from.present? || @search_date_from.present? || @search_date_to.present? %>
              <%= link_to linkedin_messages_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                Clear Filters
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Results Summary -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">
              <%= number_with_delimiter(@total_count) %> Messages
              <% if @search_subject.present? || @search_from.present? || @search_date_from.present? || @search_date_to.present? %>
                <span class="text-sm text-gray-500 dark:text-gray-400">(filtered)</span>
              <% end %>
            </h3>
            <% if @date_range[:earliest] && @date_range[:latest] %>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Date range: <%= @date_range[:earliest].strftime("%B %d, %Y") %> - <%= @date_range[:latest].strftime("%B %d, %Y") %>
              </p>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-4">
            <%= link_to linkedin_conversations_path, class: "text-blue-600 hover:text-blue-500 text-sm font-medium" do %>
              View as Conversations →
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Smart Search Results / "Did You Mean?" -->
    <% if @search_from.present? && @search_result_info&.dig(:suggested_name) %>
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg mb-6">
        <div class="px-6 py-4">
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0">
              <% case @search_result_info[:strategy] %>
              <% when :perfect_prefix_match %>
                <span class="text-green-600 dark:text-green-400 text-lg">🎯</span>
              <% when :good_prefix_match %>
                <span class="text-blue-600 dark:text-blue-400 text-lg">✅</span>
              <% when :partial_match %>
                <span class="text-yellow-600 dark:text-yellow-400 text-lg">⚠️</span>
              <% else %>
                <span class="text-gray-600 dark:text-gray-400 text-lg">🔍</span>
              <% end %>
            </div>
            <div class="flex-1">
              <p class="text-sm text-blue-800 dark:text-blue-200">
                <% if @search_result_info[:strategy] == :perfect_prefix_match || @search_result_info[:strategy] == :good_prefix_match %>
                  <strong>Showing messages from:</strong> <span class="font-semibold">"<%= @search_result_info[:suggested_name] %>"</span>
                  <% if @search_result_info[:best_matches].length > 1 %>
                    and <%= @search_result_info[:best_matches].length - 1 %> other
                    <%= 'match'.pluralize(@search_result_info[:best_matches].length - 1) %>
                  <% end %>
                <% else %>
                  <strong>Searched for:</strong> <span class="font-semibold">"<%= @search_result_info[:suggested_name] %>"</span> instead of "<%= @search_from %>"
                <% end %>
              </p>
              <% if @search_result_info[:best_matches].length > 1 %>
                <details class="mt-2">
                  <summary class="text-xs text-blue-700 dark:text-blue-300 cursor-pointer hover:underline">
                    Show all <%= @search_result_info[:best_matches].length %> matches
                  </summary>
                  <div class="mt-2 space-y-1">
                    <% @search_result_info[:best_matches].each do |match| %>
                      <div class="text-xs text-blue-700 dark:text-blue-300">
                        • <%= link_to match[:name], linkedin_messages_path(@search_params.merge(search_from: match[:name])), 
                            class: "font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-200 hover:underline cursor-pointer" %>
                        <span class="text-blue-600 dark:text-blue-400">(score: <%= match[:score].round(2) %>, <%= match[:type] %>)</span>
                      </div>
                    <% end %>
                  </div>
                </details>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Search Debug Information -->
    <% if (@search_subject.present? || @search_from.present? || @search_date_from.present? || @search_date_to.present?) && (@debug_contact_emails || @debug_search_conditions) %>
      <div class="mb-6 bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4">
        <details class="group cursor-pointer bg-yellow-100 dark:bg-yellow-800 rounded-lg p-4">
          <summary class="cursor-pointer text-yellow-800 dark:text-yellow-200 font-semibold">
            Search Debug Information <span class="text-xs text-gray-500 dark:text-gray-400">(click to expand)</span>
          </summary>
          
          <% if @search_from.present? %>
            <div class="text-xs text-yellow-700 dark:text-yellow-300 space-y-2 mt-3">
              <div><strong>Search term:</strong> "<%= @search_from %>"</div>
              <div><strong>Total contacts in database:</strong> <%= @debug_total_contacts %></div>
              
              <!-- Smart Search Results -->
              <% if @debug_detailed && @debug_detailed[:smart_search_results] %>
                <div class="border border-purple-300 dark:border-purple-600 bg-purple-50 dark:bg-purple-900/20 p-3 rounded">
                  <div class="font-semibold text-purple-800 dark:text-purple-200">🔍 Smart Search Analysis</div>
                  <div class="mt-2 space-y-1">
                    <div><strong>Strategy:</strong> <%= @debug_detailed[:strategy_explanation] %></div>
                    <div><strong>Max Score:</strong> <%= @debug_detailed[:smart_search_results][:max_score] %></div>
                    <div><strong>Threshold Used:</strong> <%= @debug_detailed[:smart_search_results][:threshold_used] %></div>
                    <div><strong>Best Matches:</strong> <%= @debug_detailed[:best_matches_count] %> / <%= @debug_detailed[:total_matches_found] %> total</div>
                    
                    <% if @debug_detailed[:smart_search_results][:best_matches].any? %>
                      <div class="mt-2">
                        <strong>🏆 Top Matches (used for search):</strong>
                        <% @debug_detailed[:smart_search_results][:best_matches].each do |match| %>
                          <div class="ml-2 text-purple-700 dark:text-purple-300">
                            • <%= link_to match[:name], linkedin_messages_path(@search_params.merge(search_from: match[:name])), 
                                class: "font-medium text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-200 hover:underline cursor-pointer" %>
                            <span class="text-purple-600 dark:text-purple-400">(score: <%= match[:score].round(2) %>, type: <%= match[:type] %>)</span>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                    
                    <% if @debug_detailed[:smart_search_results][:all_matches].length > @debug_detailed[:smart_search_results][:best_matches].length %>
                      <details class="mt-2">
                        <summary class="cursor-pointer text-purple-600 dark:text-purple-400 hover:underline">
                          Show all <%= @debug_detailed[:smart_search_results][:all_matches].length %> matches
                        </summary>
                        <div class="mt-1 ml-2">
                          <% @debug_detailed[:smart_search_results][:all_matches].each do |match| %>
                            <div class="text-purple-600 dark:text-purple-400">
                              • <%= link_to match[:name], linkedin_messages_path(@search_params.merge(search_from: match[:name])), 
                                  class: "text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-200 hover:underline cursor-pointer" %>
                              <span class="text-purple-500 dark:text-purple-500">(score: <%= match[:score].round(2) %>, <%= match[:type] %>)</span>
                            </div>
                          <% end %>
                        </div>
                      </details>
                    <% end %>
                  </div>
                </div>
              <% end %>
              
              <% if @debug_detailed %>
                <div class="border-t border-yellow-200 dark:border-yellow-700 pt-2">
                  <strong>Legacy Contact Search Logic:</strong>
                  
                  <% if @debug_detailed[:search_words] && @debug_detailed[:search_words].length > 1 %>
                    <div class="ml-2">
                      <strong>Search words:</strong> <%= @debug_detailed[:search_words].join(", ") %>
                    </div>
                  <% end %>
                  
                  <% if @debug_detailed[:exact_matches]&.any? %>
                    <div class="ml-2 mt-1">
                      <strong>📍 Exact matches (highest priority):</strong>
                      <% @debug_detailed[:exact_matches].each do |contact| %>
                        <div class="ml-2 text-green-700 dark:text-green-300">
                          ✓ ID <%= contact.id %>: 
                          <%= contact.display_name.presence || "#{contact.given_name} #{contact.family_name}".strip %> - 
                          <%= contact.emails %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <% if @debug_detailed[:word_start_matches]&.any? %>
                    <div class="ml-2 mt-1">
                      <strong>� Word-start matches (each word matches beginning of fields):</strong>
                      <% @debug_detailed[:word_start_matches].each do |contact| %>
                        <div class="ml-2 text-purple-700 dark:text-purple-300">
                          ✓ ID <%= contact.id %>: 
                          <%= contact.display_name.presence || "#{contact.given_name} #{contact.family_name}".strip %> - 
                          <%= contact.emails %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <% if @debug_detailed[:word_matches]&.any? %>
                    <div class="ml-2 mt-1">
                      <strong>🔍 Word-anywhere matches (all words must appear somewhere):</strong>
                      <% @debug_detailed[:word_matches].each do |contact| %>
                        <div class="ml-2 text-blue-700 dark:text-blue-300">
                          ✓ ID <%= contact.id %>: 
                          <%= contact.display_name.presence || "#{contact.given_name} #{contact.family_name}".strip %> - 
                          <%= contact.emails %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <% if @debug_detailed[:full_term_matches]&.any? %>
                    <div class="ml-2 mt-1">
                      <strong>📝 Partial matches (any field contains full term):</strong>
                      <% @debug_detailed[:full_term_matches].each do |contact| %>
                        <div class="ml-2 text-gray-600 dark:text-gray-400">
                          - ID <%= contact.id %>: 
                          <%= contact.display_name.presence || "#{contact.given_name} #{contact.family_name}".strip %> - 
                          <%= contact.emails %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <div class="ml-2 mt-1">
                    <strong>Total contacts with emails:</strong> <%= @debug_detailed[:total_contacts_with_emails] %>
                  </div>
                </div>
              <% end %>
              
              <div class="border-t border-yellow-200 dark:border-yellow-700 pt-2">
                <% if @debug_contact_names && @debug_contact_names.any? %>
                  <div><strong>Matching contact names:</strong> <%= @debug_contact_names.join(", ") %></div>
                <% else %>
                  <div><strong>Matching contact names:</strong> <em>None found</em></div>
                <% end %>
                
                <% if @debug_contact_emails && @debug_contact_emails.any? %>
                  <div><strong>Found contact emails:</strong> <%= @debug_contact_emails.join(", ") %></div>
                <% else %>
                  <div><strong>Found contact emails:</strong> <em>None found</em></div>
                <% end %>
                
                <% if @contact_matching_strategy %>
                  <div><strong>Contact matching strategy used:</strong> 
                    <span class="px-2 py-1 rounded text-xs 
                      <% case @contact_matching_strategy %>
                      <% when 'exact_match' %>
                        bg-green-100 text-green-800 dark:bg-green-800 dark:text-green-100
                      <% when 'word_start_match' %>
                        bg-purple-100 text-purple-800 dark:bg-purple-800 dark:text-purple-100
                      <% when 'word_anywhere_match' %>
                        bg-blue-100 text-blue-800 dark:bg-blue-800 dark:text-blue-100
                      <% when 'partial_match' %>
                        bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-100
                      <% when 'direct_name_only' %>
                        bg-red-100 text-red-800 dark:bg-red-800 dark:text-red-100
                      <% end %>">
                      <%= @contact_matching_strategy.humanize %>
                    </span>
                  </div>
                <% end %>
                
                <% if @matched_contact_emails && @matched_contact_emails.any? %>
                  <div><strong>Using contact emails for LinkedIn search:</strong> <%= @matched_contact_emails.join(", ") %></div>
                <% end %>
                
                <% if @matched_contact_names && @matched_contact_names.any? %>
                  <div><strong>Using contact names for LinkedIn search:</strong> <%= @matched_contact_names.join(", ") %></div>
                <% end %>
              </div>
              
              <% if @debug_search_conditions %>
                <div class="border-t border-yellow-200 dark:border-yellow-700 pt-2">
                  <div><strong>LinkedIn Search SQL condition:</strong> <code class="bg-yellow-100 dark:bg-yellow-800 px-1 rounded text-xs"><%= @debug_search_conditions[0] %></code></div>
                  <div><strong>Search parameters:</strong> <code class="bg-yellow-100 dark:bg-yellow-800 px-1 rounded text-xs"><%= @debug_search_conditions[1..-1].inspect %></code></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </details>
      </div>
    <% end %>

    <!-- Sidebar and Content -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Sidebar with folders and participants -->
      <div class="lg:col-span-1">
        <!-- Top Participants -->
        <% if @top_participants.any? %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Top Participants</h3>
            </div>
            <div class="p-6">
              <div class="space-y-3">
                <% @top_participants.each do |participant, count| %>
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <%= link_to linkedin_messages_path(@search_params.merge(search_from: participant)), 
                          class: "text-sm text-blue-600 hover:text-blue-500 truncate" do %>
                        <%= participant %>
                      <% end %>
                    </div>
                    <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">
                      <%= number_with_delimiter(count) %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Folders -->
        <% if @folders.any? %>
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Folders</h3>
            </div>
            <div class="p-6">
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <%= link_to linkedin_messages_path(@search_params), 
                      class: "text-sm #{@filtered_folder.blank? ? 'text-blue-600 font-medium' : 'text-gray-600 dark:text-gray-400 hover:text-blue-500'}" do %>
                    All Messages
                  <% end %>
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    <%= number_with_delimiter(@total_count) %>
                  </span>
                </div>
                
                <% @folders.each do |folder, count| %>
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <%= link_to linkedin_messages_path(@search_params.merge(folder: folder)), 
                          class: "text-sm #{@filtered_folder == folder ? 'text-blue-600 font-medium' : 'text-gray-600 dark:text-gray-400 hover:text-blue-500'} truncate" do %>
                        <%= folder.present? ? folder : "Uncategorized" %>
                      <% end %>
                    </div>
                    <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">
                      <%= number_with_delimiter(count) %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Main Content -->
      <div class="lg:col-span-3">
        <% if @linkedin_messages.any? %>
          <!-- Messages List -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @linkedin_messages.each do |message| %>
                <div class="p-6 hover:bg-gray-50 dark:hover:bg-gray-700">
                  <div class="flex items-start justify-between">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center space-x-3 mb-2">
                        <span class="text-sm font-medium text-gray-900 dark:text-white">
                          <%= message.from_name %>
                        </span>
                        <span class="text-gray-400">→</span>
                        <span class="text-sm text-gray-600 dark:text-gray-400">
                          <%= message.to_name %>
                        </span>
                        <% if message.conversation_title.present? %>
                          <span class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded">
                            <%= truncate(message.conversation_title, length: 30) %>
                          </span>
                        <% end %>
                      </div>
                      
                      <% if message.subject.present? %>
                        <p class="text-sm text-gray-900 dark:text-white font-medium mb-2">
                          <%= truncate(message.subject, length: 100) %>
                        </p>
                      <% end %>
                      
                      <% if message.content.present? %>
                        <p class="text-sm text-gray-600 dark:text-gray-400">
                          <%= truncate(strip_tags(message.content), length: 200) %>
                        </p>
                      <% end %>
                      
                      <% if message.folder.present? %>
                        <div class="mt-2">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                            <%= message.folder %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                    
                    <div class="flex flex-col items-end space-y-2 ml-4">
                      <span class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                        <%= message.sent_at.strftime("%b %d, %Y %I:%M %p") %>
                      </span>
                      
                      <div class="flex space-x-2">
                        <%= link_to linkedin_message_path(message), class: "text-blue-600 hover:text-blue-500 text-xs font-medium" do %>
                          View
                        <% end %>
                        
                        <% if message.conversation_id.present? %>
                          <%= link_to linkedin_conversation_path(message.conversation_id), class: "text-green-600 hover:text-green-500 text-xs font-medium" do %>
                            Thread
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Pagination -->
          <% if @total_pages > 1 %>
            <div class="bg-white dark:bg-gray-800 shadow rounded-lg mt-6">
              <div class="px-6 py-4">
                <div class="flex items-center justify-between">
                  <div class="flex-1 flex justify-between sm:hidden">
                    <% if @has_prev %>
                      <%= link_to linkedin_messages_path(@search_params.merge(page: @current_page - 1)), 
                          class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                        Previous
                      <% end %>
                    <% end %>
                    <% if @has_next %>
                      <%= link_to linkedin_messages_path(@search_params.merge(page: @current_page + 1)), 
                          class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                        Next
                      <% end %>
                    <% end %>
                  </div>
                  
                  <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                    <div>
                      <p class="text-sm text-gray-700 dark:text-gray-300">
                        Showing page <span class="font-medium"><%= @current_page %></span> of 
                        <span class="font-medium"><%= @total_pages %></span>
                        (<span class="font-medium"><%= number_with_delimiter(@total_count) %></span> total messages)
                      </p>
                    </div>
                    
                    <div>
                      <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                        <% if @has_prev %>
                          <%= link_to linkedin_messages_path(@search_params.merge(page: @current_page - 1)), 
                              class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                            <span class="sr-only">Previous</span>
                            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                          <% end %>
                        <% end %>
                        
                        <% (([@current_page - 2, 1].max)..([@current_page + 2, @total_pages].min)).each do |page| %>
                          <% if page == @current_page %>
                            <span class="relative inline-flex items-center px-4 py-2 border border-blue-500 bg-blue-50 text-sm font-medium text-blue-600 dark:bg-blue-900 dark:text-blue-300">
                              <%= page %>
                            </span>
                          <% else %>
                            <%= link_to linkedin_messages_path(@search_params.merge(page: page)), 
                                class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                              <%= page %>
                            <% end %>
                          <% end %>
                        <% end %>
                        
                        <% if @has_next %>
                          <%= link_to linkedin_messages_path(@search_params.merge(page: @current_page + 1)), 
                              class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                            <span class="sr-only">Next</span>
                            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                            </svg>
                          <% end %>
                        <% end %>
                      </nav>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <!-- Empty State -->
          <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
            <div class="p-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2 2v-5m16 0h-2M4 13h2m13-7v2a1 1 0 01-1 1h-2a1 1 0 01-1-1V6a1 1 0 011-1h2a1 1 0 011 1z" />
              </svg>
              <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No messages found</h3>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                <% if @search_subject.present? || @search_from.present? || @search_date_from.present? || @search_date_to.present? %>
                  Try adjusting your search criteria or clearing the filters.
                <% else %>
                  Get started by importing your LinkedIn message data.
                <% end %>
              </p>
              <div class="mt-6">
                <% if @search_subject.present? || @search_from.present? || @search_date_from.present? || @search_date_to.present? %>
                  <%= link_to linkedin_messages_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                    Clear Filters
                  <% end %>
                <% else %>
                  <%= link_to linkedin_root_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                    Import LinkedIn Data
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
