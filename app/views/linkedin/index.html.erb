<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Personal", path: personal_path },
      { name:        <%= form_with url: upload_linkedin_index_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>"LinkedIn Messages", path: nil }
    ] %>
    
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">💼 LinkedIn Messages</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Manage your imported LinkedIn message data
      </p>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900 rounded-md flex items-center justify-center">
                <span class="text-blue-600 dark:text-blue-400 text-lg">💬</span>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Messages
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= number_with_delimiter(@total_messages) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900 rounded-md flex items-center justify-center">
                <span class="text-green-600 dark:text-green-400 text-lg">👥</span>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Conversations
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= number_with_delimiter(@total_conversations) %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900 rounded-md flex items-center justify-center">
                <span class="text-purple-600 dark:text-purple-400 text-lg">📅</span>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Date Range
                </dt>
                <dd class="text-sm font-medium text-gray-900 dark:text-white">
                  <% if @date_range[:earliest] && @date_range[:latest] %>
                    <%= @date_range[:earliest].strftime("%m/%y") %> - <%= @date_range[:latest].strftime("%m/%y") %>
                  <% else %>
                    No data
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-yellow-100 dark:bg-yellow-900 rounded-md flex items-center justify-center">
                <span class="text-yellow-600 dark:text-yellow-400 text-lg">⏱️</span>
              </div>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Recent Activity
                </dt>
                <dd class="text-sm font-medium text-gray-900 dark:text-white">
                  <% if @date_range[:latest] %>
                    <%= time_ago_in_words(@date_range[:latest]) %> ago
                  <% else %>
                    No activity
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- View Messages -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center mb-4">
            <div class="h-10 w-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-3">
              <span class="text-xl">📄</span>
            </div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">View Messages</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Browse, search, and filter your LinkedIn messages
          </p>
          <%= link_to messages_linkedin_index_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            View All Messages
          <% end %>
        </div>
      </div>

      <!-- View Conversations -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center mb-4">
            <div class="h-10 w-10 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-3">
              <span class="text-xl">💬</span>
            </div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Conversations</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            View messages grouped by conversation thread
          </p>
          <%= link_to conversations_linkedin_index_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
            View Conversations
          <% end %>
        </div>
      </div>

      <!-- Import Data -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center mb-4">
            <div class="h-10 w-10 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-3">
              <span class="text-xl">📤</span>
            </div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Import Messages</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Upload LinkedIn message export files
          </p>
          <button onclick="document.getElementById('linkedin-upload-modal').classList.remove('hidden')" 
                  class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500">
            Import Data
          </button>
        </div>
      </div>
    </div>

    <!-- Recent Messages -->
    <% if @recent_messages.any? %>
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-8">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Recent Messages</h3>
        </div>
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_messages.each do |message| %>
            <div class="p-6 hover:bg-gray-50 dark:hover:bg-gray-700">
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center space-x-3">
                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                      <%= message.from_name %>
                    </p>
                    <span class="text-gray-400">→</span>
                    <p class="text-sm text-gray-600 dark:text-gray-400 truncate">
                      <%= message.to_name %>
                    </p>
                  </div>
                  <% if message.subject.present? %>
                    <p class="text-sm text-gray-900 dark:text-white mt-1 font-medium">
                      <%= truncate(message.subject, length: 80) %>
                    </p>
                  <% end %>
                  <% if message.content.present? %>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">
                      <%= truncate(strip_tags(message.content), length: 150) %>
                    </p>
                  <% end %>
                </div>
                <div class="flex flex-col items-end space-y-1">
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    <%= message.sent_at.strftime("%b %d, %Y") %>
                  </span>
                  <%= link_to linkedin_path(message), class: "text-blue-600 hover:text-blue-500 text-xs font-medium" do %>
                    View →
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="px-6 py-3 border-t border-gray-200 dark:border-gray-700">
          <%= link_to messages_linkedin_index_path, class: "text-blue-600 hover:text-blue-500 text-sm font-medium" do %>
            View all messages →
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Data Management -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Data Management</h3>
      </div>
      <div class="p-6">
        <div class="flex items-center justify-between">
          <div>
            <h4 class="text-sm font-medium text-gray-900 dark:text-white">Clear All Data</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Permanently delete all LinkedIn messages and conversations
            </p>
          </div>
          <% if @total_messages > 0 %>
            <%= link_to clear_linkedin_index_path, 
                method: :delete, 
                data: { confirm: "Are you sure you want to delete all #{number_with_delimiter(@total_messages)} LinkedIn messages? This action cannot be undone." },
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-red-900 dark:text-red-300 dark:hover:bg-red-800" do %>
              Clear All Data
            <% end %>
          <% else %>
            <span class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-500 dark:text-gray-400">
              No data to clear
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- LinkedIn Upload Modal -->
<div id="linkedin-upload-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
    <div class="mt-3">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Import LinkedIn Messages</h3>
        <button onclick="document.getElementById('linkedin-upload-modal').classList.add('hidden')" 
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
          <span class="sr-only">Close</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <%= form_with url: linkedin_upload_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            LinkedIn Messages CSV File
          </label>
          <%= form.file_field :file, 
              accept: ".csv", 
              required: true,
              class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
          <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
            Upload your LinkedIn messages export CSV file
          </p>
        </div>
        
        <div class="flex justify-end space-x-3 pt-4">
          <button type="button" 
                  onclick="document.getElementById('linkedin-upload-modal').classList.add('hidden')"
                  class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600">
            Cancel
          </button>
          <%= form.submit "Import Messages", 
              class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
