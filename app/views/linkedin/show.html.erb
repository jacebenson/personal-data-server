<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Personal", path: personal_path },
      { name: "LinkedIn", path: linkedin_path },
      { name: "Messages", path: linkedin_messages_path },
      { name: "Message", path: nil }
    ] %>
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">LinkedIn Message</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Message details and content
          </p>
        </div>
        <div class="flex space-x-3">
          <%= link_to messages_linkedin_index_path, 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
            ← Back to Messages
          <% end %>
          
          <% if @linkedin_message.conversation_id.present? %>
            <%= link_to linkedin_conversation_path(@linkedin_message.conversation_id), 
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              View Full Conversation
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Message Details -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <!-- Header -->
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="h-10 w-10 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
              <span class="text-blue-600 dark:text-blue-400 font-medium text-lg">
                <%= @linkedin_message.from_name.first.upcase %>
              </span>
            </div>
            <div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">
                <%= @linkedin_message.from_name %>
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                to <%= @linkedin_message.to_name %>
              </p>
            </div>
          </div>
          
          <div class="text-right">
            <p class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @linkedin_message.sent_at.strftime("%B %d, %Y") %>
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              <%= @linkedin_message.sent_at.strftime("%I:%M %p") %>
            </p>
          </div>
        </div>
      </div>

      <!-- Subject -->
      <% if @linkedin_message.subject.present? %>
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Subject</h4>
          <p class="mt-1 text-lg text-gray-900 dark:text-white">
            <%= @linkedin_message.subject %>
          </p>
        </div>
      <% end %>

      <!-- Content -->
      <div class="px-6 py-6">
        <% if @linkedin_message.content.present? %>
          <div class="prose dark:prose-invert max-w-none">
            <%= simple_format(@linkedin_message.content, class: "text-gray-900 dark:text-white whitespace-pre-wrap") %>
          </div>
        <% else %>
          <p class="text-gray-500 dark:text-gray-400 italic">No message content available</p>
        <% end %>
      </div>

      <!-- Metadata -->
      <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
          <% if @linkedin_message.conversation_title.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Conversation</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <%= @linkedin_message.conversation_title %>
              </dd>
            </div>
          <% end %>

          <% if @linkedin_message.conversation_id.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Conversation ID</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white font-mono">
                <%= @linkedin_message.conversation_id %>
              </dd>
            </div>
          <% end %>

          <% if @linkedin_message.folder.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Folder</dt>
              <dd class="mt-1">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                  <%= @linkedin_message.folder %>
                </span>
              </dd>
            </div>
          <% end %>

          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Message Type</dt>
            <dd class="mt-1">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @linkedin_message.is_draft? ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' : 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' %>">
                <%= @linkedin_message.is_draft? ? 'Draft' : 'Sent' %>
              </span>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Added to System</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">
              <%= @linkedin_message.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last Updated</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">
              <%= @linkedin_message.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Related Messages -->
    <% if @linkedin_message.conversation_id.present? %>
      <%
        related_messages = current_user.linkedin_messages
                                      .where(conversation_id: @linkedin_message.conversation_id)
                                      .where.not(id: @linkedin_message.id)
                                      .order(:sent_at)
                                      .limit(5)
      %>
      
      <% if related_messages.any? %>
        <div class="mt-8 bg-white dark:bg-gray-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Other Messages in this Conversation</h3>
          </div>
          
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            <% related_messages.each do |message| %>
              <div class="p-6 hover:bg-gray-50 dark:hover:bg-gray-700">
                <div class="flex items-start justify-between">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center space-x-3 mb-2">
                      <span class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= message.from_name %>
                      </span>
                      <span class="text-gray-400">→</span>
                      <span class="text-sm text-gray-600 dark:text-gray-400">
                        <%= message.to_name %>
                      </span>
                    </div>
                    
                    <% if message.subject.present? %>
                      <p class="text-sm text-gray-900 dark:text-white font-medium mb-2">
                        <%= truncate(message.subject, length: 80) %>
                      </p>
                    <% end %>
                    
                    <% if message.content.present? %>
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        <%= truncate(strip_tags(message.content), length: 150) %>
                      </p>
                    <% end %>
                  </div>
                  
                  <div class="flex flex-col items-end space-y-2 ml-4">
                    <span class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                      <%= message.sent_at.strftime("%b %d, %Y") %>
                    </span>
                    
                    <%= link_to linkedin_path(message), class: "text-blue-600 hover:text-blue-500 text-xs font-medium" do %>
                      View Message →
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          
          <div class="px-6 py-3 border-t border-gray-200 dark:border-gray-700">
            <%= link_to linkedin_conversation_path(@linkedin_message.conversation_id), 
                class: "text-blue-600 hover:text-blue-500 text-sm font-medium" do %>
              View complete conversation →
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
