<!-- LinkedIn Connections Card -->
<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
  <div class="p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">LinkedIn Connections</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Professional network connections</p>
        <div class="mt-2">
          <p class="text-2xl font-semibold text-blue-600 dark:text-blue-400"><%= number_with_delimiter(@linkedin_contacts_count) %></p>
          <% if @linkedin_contacts_count > 0 %>
            <div class="mt-1 text-xs text-gray-500 dark:text-gray-400 space-y-1">
              <% if @linkedin_contacts_with_companies > 0 %>
                <div>🏢 <%= number_with_delimiter(@linkedin_contacts_with_companies) %> with companies</div>
              <% end %>
              <% if @linkedin_contacts_with_job_titles > 0 %>
                <div>💼 <%= number_with_delimiter(@linkedin_contacts_with_job_titles) %> with job titles</div>
              <% end %>
              <% if @linkedin_last_import %>
                <div>📅 Last import: <%= @linkedin_last_import.strftime("%B %d, %Y") %></div>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-gray-500 dark:text-gray-400">No LinkedIn connections imported</p>
          <% end %>
        </div>
      </div>
    </div>
    <div class="mt-6 space-y-3">
      <% if @linkedin_contacts_count > 0 %>
        <%= link_to "View LinkedIn Connections", contacts_path(source: 'linkedin'),
            class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
      <%= link_to "Upload LinkedIn Connections", contacts_path(anchor: 'linkedin-upload'),
          class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700" %>
    </div>
  </div>
</div>
