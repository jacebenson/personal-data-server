<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Personal", path: personal_path },
      { name: "LinkedIn", path: linkedin_root_path },
      { name: "Conversations", path: linkedin_conversations_path },
      { name: @conversation_title, path: nil }
    ] %>
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= @conversation_title %>
          </h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            <%= pluralize(@conversation_messages.count, 'message') %> in this conversation
          </p>
        </div>
        
        <div class="flex space-x-3">
          <%= link_to linkedin_conversations_path, 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
            ← Back to Conversations
          <% end %>
        </div>
      </div>
    </div>

    <!-- Conversation Info -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Conversation Details</h3>
            <div class="mt-2 flex items-center space-x-4 text-sm text-gray-600 dark:text-gray-400">
              <span><%= pluralize(@conversation_messages.count, 'message') %></span>
              <span>•</span>
              <span><%= pluralize(@participants.count, 'participant') %></span>
              <span>•</span>
              <span>
                <%= @conversation_messages.minimum(:sent_at).strftime("%b %d, %Y") %> - 
                <%= @conversation_messages.maximum(:sent_at).strftime("%b %d, %Y") %>
              </span>
            </div>
          </div>
        </div>
        
        <% if @participants.any? %>
          <div class="mt-4">
            <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Participants</h4>
            <div class="mt-2 flex flex-wrap gap-2">
              <% @participants.each do |participant| %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                  <%= participant %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Messages Timeline -->
    <% if @conversation_messages.any? %>
      <div class="space-y-6">
        <% @conversation_messages.group_by { |msg| msg.sent_at.to_date }.each do |date, day_messages| %>
          <!-- Date Header -->
          <div class="relative">
            <div class="absolute inset-0 flex items-center" aria-hidden="true">
              <div class="w-full border-t border-gray-300 dark:border-gray-600"></div>
            </div>
            <div class="relative flex justify-center">
              <span class="bg-gray-50 dark:bg-gray-900 px-3 text-sm text-gray-500 dark:text-gray-400">
                <%= date.strftime("%A, %B %d, %Y") %>
              </span>
            </div>
          </div>
          
          <!-- Messages for this day -->
          <div class="space-y-4">
            <% day_messages.each do |message| %>
              <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
                <!-- Message Header and Content -->
                <div class="px-6 py-4">
                  <div class="flex items-start justify-between">
                    <div class="flex-1 mr-4">
                      <span class="text-sm font-medium text-gray-900 dark:text-white"><%= message.from_name %></span>
                      <span class="text-sm text-gray-600 dark:text-gray-400">@ <%= message.sent_at.strftime("%I:%M %p") %>:</span>
                      <% if message.content.present? %>
                        <% 
                          # Start with HTML tag removal
                          cleaned_content = strip_tags(message.content)
                          
                          # 1. Convert LinkedIn activity URLs to embedded iframes (FIRST - highest priority)
                          linkedin_activity_regex = /https:\/\/www\.linkedin\.com\/posts\/[^\/\s]+activity-(\d+)[-\w]*(?:\?[^\s]*)?/
                          linked_content = cleaned_content.gsub(linkedin_activity_regex) do |url|
                            activity_number = $1  # Captured group from regex
                            # Use a placeholder that won't be matched by URL regex
                            "LINKEDIN_IFRAME_#{activity_number}_PLACEHOLDER"
                          end
                          
                          # 2. Convert other URLs to clickable links (will not match our placeholder)
                          url_regex = /https?:\/\/[^\s]+/
                          linked_content = linked_content.gsub(url_regex) do |url|
                            "<a href=\"#{url}\" target=\"_blank\" rel=\"noopener\" class=\"text-blue-600 dark:text-blue-400 hover:underline\">#{url}</a>"
                          end
                          
                          # 3. Replace LinkedIn placeholders with actual iframes (after URL processing)
                          linked_content = linked_content.gsub(/LINKEDIN_IFRAME_(\d+)_PLACEHOLDER/) do |placeholder|
                            activity_number = $1
                            # Find the original URL from the cleaned content to display as copyable link
                            original_url_match = cleaned_content.match(/https:\/\/www\.linkedin\.com\/posts\/[^\/\s]+activity-#{activity_number}[-\w]*(?:\?[^\s]*)?/)
                            original_url = original_url_match ? original_url_match[0] : "https://www.linkedin.com/posts/activity-#{activity_number}"
                            
                            %Q{<div class="my-4">
                              <div class="mb-2 p-2 bg-gray-100 dark:bg-gray-700 rounded border">
                                <span class="text-xs text-gray-600 dark:text-gray-400">LinkedIn Post:</span>
                                <input type="text" value="#{original_url}" readonly 
                                       class="w-full text-xs bg-transparent border-none p-1 text-blue-600 dark:text-blue-400 font-mono select-all cursor-pointer" 
                                       onclick="this.select(); document.execCommand('copy');" 
                                       title="Click to select and copy">
                              </div>
                              <iframe src="https://www.linkedin.com/embed/feed/update/urn:li:activity:#{activity_number}" 
                                      height="600" width="504" frameborder="0" allowfullscreen="" 
                                      title="Embedded LinkedIn post" class="mx-auto">
                              </iframe>
                            </div>}
                          end
                          
                          # 4. Convert phone numbers to tel: links
                          # More specific regex that avoids matching numbers within existing links
                          # Uses negative lookbehind to avoid matching numbers that come after href=" or inside URLs
                          phone_regex = /(?<!href=")(?<!\/)\b(\+?1?[-.\s]?)?\(?([0-9]{3})\)?[-.\s]?([0-9]{3})[-.\s]?([0-9]{4})\b(?![^<]*<\/a>)/
                          linked_content = linked_content.gsub(phone_regex) do |phone|
                            # Clean phone number for tel: link (remove non-digits except +)
                            clean_phone = phone.gsub(/[^\d+]/, '')
                            "<a href=\"tel:#{clean_phone}\" class=\"text-blue-600 dark:text-blue-400 hover:underline\">#{phone}</a>"
                          end
                          
                          # 5. Remove &nbsp; entities (lowest priority)
                          linked_content = linked_content.gsub('&nbsp;', ' ').strip
                        %>
                        <span class="text-sm text-gray-900 dark:text-white ml-2"><%= raw(linked_content) %></span>
                      <% else %>
                        <span class="text-sm text-gray-500 dark:text-gray-400 italic ml-2">No message content available</span>
                      <% end %>
                    </div>
                    
                    <%= link_to linkedin_message_path(message), class: "text-blue-600 hover:text-blue-500 text-xs font-medium flex-shrink-0" do %>
                      view details
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No messages found</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            This conversation appears to be empty or the messages could not be loaded.
          </p>
          <div class="mt-6">
            <%= link_to linkedin_conversations_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Back to Conversations
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Conversation Statistics -->
    <% if @conversation_messages.any? %>
      <div class="mt-8 bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Conversation Statistics</h3>
        </div>
        
        <div class="p-6">
          <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Messages</dt>
              <dd class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">
                <%= number_with_delimiter(@conversation_messages.count) %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Duration</dt>
              <dd class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">
                <%= distance_of_time_in_words(@conversation_messages.minimum(:sent_at), @conversation_messages.maximum(:sent_at)) %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Most Active Day</dt>
              <dd class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">
                <%
                  most_active_date = @conversation_messages.group_by { |msg| msg.sent_at.to_date }
                                                          .max_by { |date, messages| messages.count }
                                                          &.first
                %>
                <%= most_active_date&.strftime("%b %d, %Y") || "N/A" %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Conversation ID</dt>
              <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white break-all">
                <%= @conversation_id %>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    <% end %>
  </div>
</div>
