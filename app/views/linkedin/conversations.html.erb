<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Personal", path: personal_path },
      { name: "LinkedIn", path: linkedin_path },
      { name: "Conversations", path: nil }
    ] %>
    
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">💬 LinkedIn Conversations</h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            View your LinkedIn messages grouped by conversation
          </p>
        </div>
        
        <div class="flex space-x-3">
          <%= link_to linkedin_index_path, 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
            ← Back to LinkedIn
          <% end %>
          
          <%= link_to messages_linkedin_index_path, 
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            View All Messages
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">
              <%= number_with_delimiter(@conversations.length) %> Conversations
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Showing the most recent conversation threads
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Conversations List -->
    <% if @conversations.any? %>
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @conversations.each do |conversation_id, conversation_title, message_count, last_message_at| %>
            <div class="p-6 hover:bg-gray-50 dark:hover:bg-gray-700">
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center space-x-3 mb-2">
                    <div class="h-10 w-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
                      <span class="text-blue-600 dark:text-blue-400 text-lg">💬</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-lg font-medium text-gray-900 dark:text-white truncate">
                        <%= conversation_title.present? ? conversation_title : "Conversation #{conversation_id}" %>
                      </h3>
                      <div class="flex items-center space-x-2 text-sm text-gray-600 dark:text-gray-400">
                        <span><%= pluralize(message_count, 'message') %></span>
                        <span>•</span>
                        <span>Last activity: <%= time_ago_in_words(last_message_at) %> ago</span>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Preview of conversation participants -->
                  <%
                    participants = current_user.linkedin_messages
                                              .where(conversation_id: conversation_id)
                                              .distinct
                                              .pluck(:from_name, :to_name)
                                              .flatten
                                              .uniq
                                              .compact
                                              .first(5)
                  %>
                  
                  <% if participants.any? %>
                    <div class="mt-3">
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        <span class="font-medium">Participants:</span>
                        <%= participants.join(', ') %>
                        <% if participants.length == 5 %>
                          <span class="text-gray-500">and others...</span>
                        <% end %>
                      </p>
                    </div>
                  <% end %>
                  
                  <!-- Recent message preview -->
                  <%
                    recent_message = current_user.linkedin_messages
                                                .where(conversation_id: conversation_id)
                                                .order(sent_at: :desc)
                                                .first
                  %>
                  
                  <% if recent_message&.content.present? %>
                    <div class="mt-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-md">
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        <span class="font-medium"><%= recent_message.from_name %>:</span>
                        <%= truncate(strip_tags(recent_message.content), length: 120) %>
                      </p>
                    </div>
                  <% end %>
                </div>
                
                <div class="flex flex-col items-end space-y-2 ml-6">
                  <span class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">
                    <%= Date.parse(last_message_at.to_s).strftime("%b %d, %Y") %>
                  </span>
                  
                  <div class="flex space-x-2">
                    <%= link_to linkedin_conversation_path(conversation_id), 
                        class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                      View Thread
                    <% end %>
                  </div>
                  
                  <div class="flex items-center">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                      <%= message_count %> messages
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No conversations found</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Import your LinkedIn message data to see conversation threads.
          </p>
          <div class="mt-6">
            <%= link_to linkedin_index_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Import LinkedIn Data
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Help Section -->
    <div class="mt-8 bg-blue-50 dark:bg-blue-900 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">About Conversations</h3>
          <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
            <p>
              Conversations group related LinkedIn messages together based on their conversation ID. 
              This helps you see the full context of message exchanges with your connections.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
