<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
      
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📚 Upload Audible Library Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload your Audible library CSV file from your Amazon account</p>
    </div>

    <!-- Instructions -->
    <div class="mb-8 p-4 bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">How to get your Audible library data:</h3>
          <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
            <ol class="list-decimal list-inside space-y-1">
              <li>Go to <a href="https://www.amazon.com/hz/privacy-central/data-requests/preview.html" target="_blank" class="underline">amazon.com/hz/privacy-central/data-requests/preview.html</a></li>
              <li>Sign in to your Amazon account</li>
              <li>Request your data and select "Audible" from the list</li>
              <li>Amazon will prepare your data (this may take several days)</li>
              <li>Download the ZIP file when it's ready</li>
              <li>Extract the ZIP and navigate to <strong>Audible.Library/</strong></li>
              <li>Upload the <strong>Audible.Library.csv</strong> file below</li>
            </ol>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Upload Audible Library CSV File</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Select the Audible.Library.csv file from your Audible data export
        </p>
      </div>

      <div class="p-6">
        <%= form_with url: upload_entertainment_audible_libraries_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
          <!-- File Upload -->
          <div>
            <%= form.label :file, "Audible Library CSV File", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".csv",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Upload the Audible.Library.csv file from your Audible data export
            </p>
          </div>

          <!-- Expected Format Info -->
          <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-md p-4">
            <h4 class="font-medium text-green-900 dark:text-green-200 mb-2">Expected CSV format:</h4>
            <div class="text-sm text-green-800 dark:text-green-300 space-y-1">
              <p><strong>Required columns:</strong></p>
              <ul class="list-disc list-inside ml-4 space-y-1">
                <li><strong>Product Name</strong> - Name of the audiobook</li>
                <li><strong>ASIN</strong> - Amazon product identifier</li>
                <li><strong>Date Added</strong> - Date added to library in YYYY-MM-DD format</li>
              </ul>
              <p class="mt-2"><strong>Optional columns (for enhanced data):</strong></p>
              <ul class="list-disc list-inside ml-4 space-y-1">
                <li><strong>Downloaded</strong> - Whether the book was downloaded</li>
                <li><strong>Origin Type</strong> - How the book was acquired (Purchase, etc.)</li>
                <li><strong>Order Number</strong> - Amazon order number</li>
                <li><strong>Date First Downloaded</strong> - First download date</li>
              </ul>
              <p class="mt-2"><strong>Example:</strong></p>
              <div class="bg-white dark:bg-gray-800 rounded p-2 mt-1 font-mono text-xs">
                Date Added,Product Name,ASIN,Downloaded,Origin Type<br>
                "2025-07-06","The Lightning Thief: Percy Jackson","B002V0JZOO","Yes","Purchase"<br>
                "2025-05-27","Why We Sleep: Unlocking the Power of Sleep","B0752ZQR33","Yes","Purchase"
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex justify-between">
            <%= link_to "Cancel", entertainment_path,
                class: "py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            <%= form.submit "Upload Audible Library",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Current Stats (if any data exists) -->
    <% if current_user.entertainment_contents.audible_library.any? %>
      <div class="mt-8 bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Current Audible Library Data</h3>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="text-center">
              <p class="text-2xl font-semibold text-blue-600"><%= current_user.entertainment_contents.audible_library.count %></p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Total library items</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-semibold text-blue-600">
                <%= current_user.entertainment_contents.audible_library.minimum(:date_consumed)&.strftime("%Y") || "N/A" %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Earliest addition</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-semibold text-blue-600">
                <%= current_user.entertainment_contents.audible_library.maximum(:date_consumed)&.strftime("%Y") || "N/A" %>
              </p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Latest addition</p>
            </div>
          </div>
          <div class="mt-6">
            <%= link_to "View All Library Items", entertainment_audible_libraries_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700" %>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
