<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
  <div class="p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Audible Listening</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Listening sessions</p>
        <div class="mt-2">
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @audible_books_count %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400">
            <% if @audible_books_count > 0 %>
              Last upload: <%= @last_audible_upload&.strftime("%B %d, %Y") || "Never" %>
            <% else %>
              No data uploaded
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="mt-6 space-y-3">
      <% if @audible_books_count > 0 %>
        <%= link_to "View All Records", view_audible_entertainment_index_path,
            class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
      <%= link_to "Upload Listening Data", audible_entertainment_index_path,
          class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" %>
      <% if @audible_books_count > 0 %>
        <%= link_to "Clear All Data", clear_audible_entertainment_index_path, method: :delete,
            confirm: "Are you sure you want to delete all Audible listening records?",
            class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
    </div>
  </div>
</div>
