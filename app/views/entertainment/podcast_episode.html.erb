<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-4">
          <li>
            <%= link_to "Entertainment", entertainment_index_path, class: "text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <%= link_to "Podcasts", podcasts_entertainment_index_path, class: "ml-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <%= link_to @podcast_feed.title, podcast_episodes_entertainment_index_path(@podcast_feed), class: "ml-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="ml-4 text-gray-900 dark:text-white"><%= truncate(@episode.title, length: 50) %></span>
            </div>
          </li>
        </ol>
      </nav>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <!-- Episode Header -->
        <div class="flex items-start space-x-6 mb-6">
          <% if @podcast_feed.image_url.present? %>
            <img src="<%= @podcast_feed.image_url %>" alt="<%= @podcast_feed.title %>" class="h-24 w-24 rounded-lg object-cover shadow">
          <% else %>
            <div class="h-24 w-24 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center shadow">
              <svg class="h-12 w-12 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 616 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
          <% end %>
          
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2"><%= @episode.title %></h1>
            <p class="text-lg text-gray-600 dark:text-gray-400 mb-2">
              <%= link_to @podcast_feed.title, podcast_episodes_entertainment_index_path(@podcast_feed), 
                  class: "hover:text-purple-600 dark:hover:text-purple-400" %>
            </p>
            
            <div class="flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400">
              <% if @episode.published_at %>
                <span>📅 <%= @episode.published_at.strftime("%B %d, %Y") %></span>
              <% end %>
              <% if @episode.formatted_duration %>
                <span>🎵 <%= @episode.formatted_duration %></span>
              <% end %>
              <% if @episode.formatted_file_size %>
                <span>📦 <%= @episode.formatted_file_size %></span>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Episode Status & Actions -->
        <div class="flex items-center justify-between mb-6 p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
          <div class="flex items-center space-x-4">
            <% if @episode.listened? %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Listened
              </span>
              <% if @episode.listened_at %>
                <span class="text-sm text-gray-600 dark:text-gray-400">
                  Listened <%= time_ago_in_words(@episode.listened_at) %> ago
                </span>
              <% end %>
            <% else %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Unlistened
              </span>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-3">
            <%= link_to toggle_episode_listened_entertainment_index_path(@podcast_feed, @episode), 
                data: { turbo_method: :patch },
                class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
              <% if @episode.listened? %>
                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Mark as Unlistened
              <% else %>
                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Mark as Listened
              <% end %>
            <% end %>
            
            <% if @episode.audio_url.present? %>
              <a href="<%= @episode.audio_url %>" target="_blank" 
                 class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700">
                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h8m-9-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Play Episode
              </a>
            <% end %>
          </div>
        </div>

        <!-- Episode Description -->
        <% if @episode.description.present? %>
          <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Description</h3>
            <div class="prose prose-gray dark:prose-invert max-w-none">
              <%= simple_format(ActionView::Base.full_sanitizer.sanitize(@episode.description)) %>
            </div>
          </div>
        <% end %>

        <!-- Episode Metadata -->
        <% episode_metadata = @episode.parsed_metadata %>
        <% if episode_metadata.any? %>
          <div class="mb-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Additional Information</h3>
            <dl class="grid grid-cols-1 gap-x-4 gap-y-3 sm:grid-cols-2">
              <% if episode_metadata['author'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Author</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['author'] %></dd>
                </div>
              <% end %>
              <% if episode_metadata['subtitle'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Subtitle</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['subtitle'] %></dd>
                </div>
              <% end %>
              <% if episode_metadata['season'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Season</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['season'] %></dd>
                </div>
              <% end %>
              <% if episode_metadata['episode'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Episode Number</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['episode'] %></dd>
                </div>
              <% end %>
              <% if episode_metadata['episode_type'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Type</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['episode_type'].humanize %></dd>
                </div>
              <% end %>
              <% if episode_metadata['explicit'].present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Explicit</dt>
                  <dd class="text-sm text-gray-900 dark:text-white"><%= episode_metadata['explicit'].humanize %></dd>
                </div>
              <% end %>
            </dl>
          </div>
        <% end %>

        <!-- Episode Links -->
        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
          <div class="flex flex-wrap gap-4">
            <% if @episode.website_url.present? %>
              <a href="<%= @episode.website_url %>" target="_blank" 
                 class="inline-flex items-center text-sm text-purple-600 hover:text-purple-500">
                <svg class="mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                Episode Website
              </a>
            <% end %>
            
            <% if @podcast_feed.website_url.present? %>
              <a href="<%= @podcast_feed.website_url %>" target="_blank" 
                 class="inline-flex items-center text-sm text-purple-600 hover:text-purple-500">
                <svg class="mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 616 0v6a3 3 0 01-3 3z"></path>
                </svg>
                Podcast Website
              </a>
            <% end %>
            
            <a href="<%= @podcast_feed.feed_url %>" target="_blank" 
               class="inline-flex items-center text-sm text-purple-600 hover:text-purple-500">
              <svg class="mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h4a1 1 0 011 1v2h4a1 1 0 011 1v16a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1h4z"></path>
              </svg>
              RSS Feed
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
