<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Entertainment", path: entertainment_index_path }
    ] %>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">🎬 Entertainment Content</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Track your entertainment consumption across platforms</p>
    </div>

    <!-- Entertainment Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <%= render 'entertainment/netflix_card' %>
      <%= render 'entertainment/youtube_card' %>
      <%= render 'entertainment/audible_library_card' %>
      <%= render 'entertainment/podcasts_card' %>
    </div>

    <!-- Summary Statistics -->
    <% if @total_content_count > 0 || @podcast_feeds_count > 0 %>
      <div class="mt-8">
        <%= render 'entertainment/summary' %>
      </div>
    <% end %>

  </div>
</div>
