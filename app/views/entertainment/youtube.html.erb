<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📺 YouTube Watch History</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload your YouTube watch history from Google Takeout</p>
    </div>

    <!-- Current Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-red-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Videos</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= current_user.entertainment_contents.youtube.count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Recent Videos</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= current_user.entertainment_contents.youtube.where('date_consumed > ?', 30.days.ago).count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Last Upload</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <% last_upload = current_user.entertainment_contents.youtube.maximum(:imported_at) %>
                  <%= last_upload ? time_ago_in_words(last_upload) + " ago" : "Never" %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Section -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Upload YouTube Watch History</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Import your YouTube watch history from Google Takeout
        </p>
      </div>
      <div class="p-6">
        <%= form_with url: upload_youtube_entertainment_index_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
          <div>
            <%= form.label :file, "JSON File", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".json",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-red-50 file:text-red-700 hover:file:bg-red-100 dark:file:bg-red-900 dark:file:text-red-300" %>
            </div>
            <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
              📋 <strong>How to get your YouTube watch history:</strong><br>
              1. Go to <a href="https://takeout.google.com" target="_blank" class="text-red-600 hover:text-red-500">Google Takeout</a><br>
              2. Select "YouTube and YouTube Music"<br>
              3. Choose "history" (not "subscriptions" or "playlists")<br>
              4. Select JSON format<br>
              5. Download and extract the "watch-history.json" file
            </p>
          </div>

          <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
                  Expected JSON Format
                </h3>
                <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                  <p>Your file should contain an array of objects with this structure:</p>
                  <pre class="mt-2 text-xs bg-red-100 dark:bg-red-900/40 p-2 rounded"><code>[
  {
    "title": "Video Title",
    "link": "https://www.youtube.com/watch?v=VIDEO_ID",
    "watchDate": "Apr 17, 2012, 4:40:31 PM CDT"
  }
]</code></pre>
                </div>
              </div>
            </div>
          </div>

          <div class="flex justify-end">
            <%= form.submit "Upload Watch History",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Actions Section -->
    <% if current_user.entertainment_contents.youtube.any? %>
      <div class="mt-8 bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Actions</h3>
          <div class="flex flex-wrap gap-3">
            <%= link_to "View Watch History", view_youtube_entertainment_index_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
            <%= link_to "Clear All Records", clear_youtube_entertainment_index_path,
                data: { 
                  turbo_method: :delete,
                  turbo_confirm: "Are you sure you want to delete all YouTube watch history records?"
                },
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
