<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-4">
          <li>
            <%= link_to "Entertainment", entertainment_index_path, class: "text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <%= link_to "Podcasts", podcasts_entertainment_index_path, class: "ml-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="ml-4 text-gray-900 dark:text-white"><%= @podcast_feed.title %></span>
            </div>
          </li>
        </ol>
      </nav>
      
      <div class="mt-6 flex items-start space-x-6">
        <% if @podcast_feed.image_url.present? %>
          <img src="<%= @podcast_feed.image_url %>" alt="<%= @podcast_feed.title %>" class="h-32 w-32 rounded-lg object-cover shadow-lg">
        <% else %>
          <div class="h-32 w-32 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center shadow-lg">
            <svg class="h-16 w-16 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z"></path>
            </svg>
          </div>
        <% end %>
        
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @podcast_feed.title %></h1>
          <% if @podcast_feed.author.present? %>
            <p class="text-lg text-gray-600 dark:text-gray-400 mt-1">by <%= @podcast_feed.author %></p>
          <% end %>
          <% if @podcast_feed.description.present? %>
            <p class="text-gray-600 dark:text-gray-400 mt-2 line-clamp-3"><%= truncate(@podcast_feed.description, length: 300) %></p>
          <% end %>
          
          <div class="flex items-center space-x-6 mt-4 text-sm text-gray-500 dark:text-gray-400">
            <span><%= @total_episodes %> episodes</span>
            <span><%= @listened_count %> listened</span>
            <span><%= @unlistened_count %> unlistened</span>
            <% if @podcast_feed.website_url.present? %>
              <a href="<%= @podcast_feed.website_url %>" target="_blank" class="text-purple-600 hover:text-purple-500">🌐 Website</a>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Episode Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 00-2-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H9z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Episodes</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_episodes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Listened</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @listened_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Unlistened</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @unlistened_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Episodes List -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Episodes</h3>
          <%= link_to "View All Episodes", all_episodes_entertainment_index_path, 
              class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        </div>

        <% if @episodes.any? %>
          <div class="space-y-4">
            <% @episodes.each do |episode| %>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                <div class="flex items-start justify-between">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center space-x-2 mb-2">
                      <% if episode.listened? %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                          ✓ Listened
                        </span>
                      <% else %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                          ◯ Unlistened
                        </span>
                      <% end %>
                      <% if episode.published_at %>
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          <%= episode.published_at.strftime("%B %d, %Y") %>
                        </span>
                      <% end %>
                      <% if episode.formatted_duration %>
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          🎵 <%= episode.formatted_duration %>
                        </span>
                      <% end %>
                    </div>
                    
                    <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-2">
                      <%= link_to episode.title, podcast_episode_entertainment_index_path(@podcast_feed, episode), 
                          class: "hover:text-purple-600 dark:hover:text-purple-400" %>
                    </h4>
                    
                    <% if episode.short_description %>
                      <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2"><%= episode.short_description %></p>
                    <% end %>
                  </div>
                  
                  <div class="flex items-center space-x-2 ml-4">
                    <%= link_to toggle_episode_listened_entertainment_index_path(@podcast_feed, episode), 
                        method: :patch,
                        class: "inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600",
                        title: episode.listened? ? "Mark as unlistened" : "Mark as listened" do %>
                      <% if episode.listened? %>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      <% else %>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    
                    <% if episode.audio_url.present? %>
                      <a href="<%= episode.audio_url %>" target="_blank" 
                         class="inline-flex items-center p-2 border border-purple-300 rounded-md shadow-sm text-sm font-medium text-purple-700 bg-white hover:bg-purple-50"
                         title="Play episode">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h8m-9-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </a>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Pagination -->
          <% if @episodes.respond_to?(:current_page) && @episodes.total_pages > 1 %>
            <div class="mt-6 flex justify-center">
              <%= paginate @episodes, theme: 'twitter-bootstrap-4' %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No episodes found</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">This podcast feed hasn't been synced yet or has no episodes.</p>
            <div class="mt-6">
              <%= link_to sync_podcast_feed_entertainment_path(@podcast_feed), method: :post,
                  class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" do %>
                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Sync Episodes
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
