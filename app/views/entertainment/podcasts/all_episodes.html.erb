<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= render 'shared/breadcrumb', breadcrumbs: [
        { name: "Home", path: root_path },
        { name: "Entertainment", path: entertainment_index_path },
        { name: "Podcasts", path: entertainment_podcasts_path },
        { name: "All Episodes", path: nil }
      ] %>
      
      <div class="mt-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">🎧 All Podcast Episodes</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">All episodes from your podcast feeds in reverse chronological order</p>
      </div>
    </div>

    <!-- Search Form -->
    <div class="mb-8">
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
        <div class="p-6">
          <%= form_with url: all_episodes_entertainment_podcasts_path, method: :get, local: true, class: "space-y-4" do |form| %>
            <div class="flex flex-col sm:flex-row gap-4">
              <div class="flex-1">
                <%= form.text_field :search, 
                    value: params[:search],
                    placeholder: "Search episodes by title, description, or podcast name... (Press '/' to focus)",
                    class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500",
                    id: "episode_search" %>
              </div>
              <div class="flex gap-2">
                <%= form.submit "Search", 
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
                <% if params[:search].present? %>
                  <%= link_to "Clear", all_episodes_entertainment_podcasts_path,
                      class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
                <% end %>
              </div>
            </div>
            <% if params[:search].present? %>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                Showing results for "<%= params[:search] %>" - <%= pluralize(@total_episodes, 'episode') %> found
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Episode Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 00-2-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H9z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Episodes</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_episodes %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Listened</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @listened_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Unlistened</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_episodes - @listened_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Episodes List -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Recent Episodes</h3>
          <div class="text-sm text-gray-500 dark:text-gray-400">
            Showing newest episodes first
          </div>
        </div>

        <% if @episodes.any? %>
          <div class="space-y-6">
            <% @episodes.group_by { |e| e.published_at&.to_date }.each do |date, episodes| %>
              <div>
                <% if date %>
                  <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3 border-b border-gray-200 dark:border-gray-700 pb-1">
                    <%= date.strftime("%A, %B %d, %Y") %>
                  </h4>
                <% else %>
                  <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3 border-b border-gray-200 dark:border-gray-700 pb-1">
                    No Date
                  </h4>
                <% end %>
                
                <div class="space-y-3 ml-4">
                  <% episodes.each do |episode| %>
                    <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                      <div class="flex items-start justify-between">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center space-x-3 mb-2">
                            <% if episode.podcast_feed.image_url.present? %>
                              <img src="<%= episode.podcast_feed.image_url %>" alt="<%= episode.podcast_feed.title %>" class="h-10 w-10 rounded object-cover">
                            <% else %>
                              <div class="h-10 w-10 bg-purple-100 dark:bg-purple-900 rounded flex items-center justify-center">
                                <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 616 0v6a3 3 0 01-3 3z"></path>
                                </svg>
                              </div>
                            <% end %>
                            
                            <div class="flex-1 min-w-0">
                              <p class="text-sm font-medium text-purple-600 dark:text-purple-400 truncate">
                                <%= link_to episode.podcast_feed.title, episodes_entertainment_podcast_path(episode.podcast_feed), 
                                    class: "hover:text-purple-700 dark:hover:text-purple-300" %>
                              </p>
                            </div>
                          </div>
                          
                          <div class="flex items-center space-x-2 mb-2">
                            <% if episode.listened? %>
                              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                ✓ Listened
                              </span>
                            <% else %>
                              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                                ◯ Unlistened
                              </span>
                            <% end %>
                            <% if episode.formatted_duration %>
                              <span class="text-xs text-gray-500 dark:text-gray-400">
                                🎵 <%= episode.formatted_duration %>
                              </span>
                            <% end %>
                          </div>
                          
                          <h4 class="text-base font-medium text-gray-900 dark:text-white mb-2">
                            <%= link_to episode.title, entertainment_podcast_episode_path(episode.podcast_feed, episode), 
                                class: "hover:text-purple-600 dark:hover:text-purple-400" %>
                          </h4>
                          
                          <% if episode.short_description %>
                            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2"><%= episode.short_description %></p>
                          <% end %>
                        </div>
                        
                        <div class="flex items-center space-x-2 ml-4">
                          <%= link_to toggle_listened_entertainment_podcast_episode_path(episode.podcast_feed, episode), 
                              data: { turbo_method: :patch },
                              class: "inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600",
                              title: episode.listened? ? "Mark as unlistened" : "Mark as listened" do %>
                            <% if episode.listened? %>
                              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                              </svg>
                            <% else %>
                              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                              </svg>
                            <% end %>
                          <% end %>
                          
                          <% if episode.audio_url.present? %>
                            <a href="<%= episode.audio_url %>" target="_blank" 
                               class="inline-flex items-center p-2 border border-purple-300 rounded-md shadow-sm text-sm font-medium text-purple-700 bg-white hover:bg-purple-50"
                               title="Play episode">
                              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h8m-9-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                              </svg>
                            </a>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Simple Pagination -->
          <% if @total_pages > 1 %>
            <div class="mt-8 flex items-center justify-between">
              <div class="flex-1 flex justify-between sm:hidden">
                <% if @has_prev %>
                  <%= link_to "Previous", all_episodes_entertainment_podcasts_path(@search_params.merge(page: @current_page - 1)), 
                      class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
                <% end %>
                <% if @has_next %>
                  <%= link_to "Next", all_episodes_entertainment_podcasts_path(@search_params.merge(page: @current_page + 1)), 
                      class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
                <% end %>
              </div>
              <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm text-gray-700 dark:text-gray-300">
                    Showing page <span class="font-medium"><%= @current_page %></span> of <span class="font-medium"><%= @total_pages %></span>
                  </p>
                </div>
                <div>
                  <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px">
                    <% if @has_prev %>
                      <%= link_to all_episodes_entertainment_podcasts_path(@search_params.merge(page: @current_page - 1)),
                          class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                      <% end %>
                    <% end %>

                    <% ([1, @current_page - 1, @current_page, @current_page + 1, @total_pages].uniq.select { |p| p >= 1 && p <= @total_pages }).each do |page_num| %>
                      <% if page_num == @current_page %>
                        <span class="relative inline-flex items-center px-4 py-2 border border-purple-500 bg-purple-50 text-sm font-medium text-purple-600">
                          <%= page_num %>
                        </span>
                      <% else %>
                        <%= link_to all_episodes_entertainment_podcasts_path(@search_params.merge(page: page_num)),
                            class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
                          <%= page_num %>
                        <% end %>
                      <% end %>
                    <% end %>

                    <% if @has_next %>
                      <%= link_to all_episodes_entertainment_podcasts_path(@search_params.merge(page: @current_page + 1)),
                          class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" do %>
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </nav>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 616 0v6a3 3 0 01-3 3z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No episodes found</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">You don't have any podcast episodes yet. Try syncing your podcast feeds.</p>
            <div class="mt-6">
              <%= link_to "Manage Podcast Feeds", entertainment_podcasts_path,
                  class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  // Focus search field when '/' is pressed
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      document.getElementById('episode_search').focus();
    }
  });
</script>
