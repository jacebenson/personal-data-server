<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <!-- lets add teh breadcrumb partial -->
    <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Entertainment", path: entertainment_index_path },
      { name: "Podcasts", path: podcasts_entertainment_index_path }
    ] %>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">🎙️ Podcast Feed Management</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your podcast RSS feeds and sync their metadata</p>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Feeds</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_feeds %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Need Sync</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @needs_sync_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">With Errors</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @error_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Episodes</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @podcast_feeds.sum(:episode_count) %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Add New Feed Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Upload OPML -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Upload OPML File</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Import multiple podcast feeds from an OPML export
          </p>
        </div>
        <div class="p-6">
          <%= form_with url: upload_opml_entertainment_index_path, method: :post, multipart: true, local: true, class: "space-y-4" do |form| %>
            <div>
              <%= form.label :file, "OPML File", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <div class="mt-1">
                <%= form.file_field :file,
                    accept: ".opml,.xml",
                    required: true,
                    class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 dark:file:bg-purple-900 dark:file:text-purple-300" %>
              </div>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                Export from your podcast app (Overcast, Apple Podcasts, etc.)
              </p>
            </div>
            <div class="flex justify-end">
              <%= form.submit "Upload OPML",
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Add Single Feed -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Add Single Feed</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Add a podcast feed by RSS URL
          </p>
        </div>
        <div class="p-6">
          <%= form_with url: add_podcast_feed_entertainment_index_path, method: :post, local: true, class: "space-y-4" do |form| %>
            <div>
              <%= form.label :feed_url, "RSS Feed URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <div class="mt-1">
                <%= form.url_field :feed_url,
                    placeholder: "https://example.com/podcast/feed.xml",
                    required: true,
                    class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-purple-500 focus:ring-purple-500" %>
              </div>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                The RSS or XML feed URL for the podcast
              </p>
            </div>
            <div class="flex justify-end">
              <%= form.submit "Add Feed",
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Bulk Actions -->
    <% if @podcast_feeds.any? %>
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
        <div class="p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Bulk Actions</h3>
          <div class="flex flex-wrap gap-3">
            <%= link_to "View All Episodes", all_episodes_entertainment_index_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
            <%= link_to "Sync All Feeds", entertainment_sync_all_podcast_feeds_path,
                data: { turbo_method: :post },
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
            <%= link_to "Clear All Feeds", clear_podcast_feeds_entertainment_index_path,
                data: { 
                  turbo_method: :delete,
                  turbo_confirm: "Are you sure you want to delete all podcast feeds?"
                },
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
          </div>
        </div>
      </div>

      <!-- Podcast Feeds List -->
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Your Podcast Feeds</h3>

          <div class="space-y-4">
            <% @podcast_feeds.each do |feed| %>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                <div class="flex items-start justify-between">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center space-x-3">
                      <% if feed.image_url.present? %>
                        <img src="<%= feed.image_url %>" alt="<%= feed.title %>" class="h-12 w-12 rounded-lg object-cover">
                      <% else %>
                        <div class="h-12 w-12 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center">
                          <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z"></path>
                          </svg>
                        </div>
                      <% end %>
                      <div class="flex-1 min-w-0">
                        <h4 class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= feed.title %></h4>
                        <% if feed.author.present? %>
                          <p class="text-sm text-gray-500 dark:text-gray-400 truncate">by <%= feed.author %></p>
                        <% end %>
                        <div class="flex items-center space-x-4 mt-1">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= feed.sync_status_color %>-100 text-<%= feed.sync_status_color %>-800 dark:bg-<%= feed.sync_status_color %>-900 dark:text-<%= feed.sync_status_color %>-200">
                            <%= feed.last_sync_status.humanize %>
                          </span>
                          <% if feed.episode_count > 0 %>
                            <span class="text-xs text-gray-500 dark:text-gray-400"><%= feed.episode_count %> episodes</span>
                          <% end %>
                          <% if feed.last_synced_at %>
                            <span class="text-xs text-gray-500 dark:text-gray-400">Synced <%= time_ago_in_words(feed.last_synced_at) %> ago</span>
                          <% end %>
                        </div>
                        <% if feed.description.present? %>
                          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2"><%= truncate(feed.description, length: 120) %></p>
                        <% end %>
                        <% if feed.sync_error.present? %>
                          <p class="text-sm text-red-600 dark:text-red-400 mt-1">Error: <%= feed.sync_error %></p>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center space-x-2 ml-4">
                    <%= link_to podcast_episodes_entertainment_index_path(feed),
                        class: "inline-flex items-center p-2 border border-purple-300 rounded-md shadow-sm text-sm font-medium text-purple-700 bg-white hover:bg-purple-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500",
                        title: "View episodes" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 00-2-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H9z"></path>
                      </svg>
                    <% end %>
                    <%= link_to sync_podcast_feed_entertainment_path(feed),
                        data: { turbo_method: :post },
                        class: "inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500",
                        title: "Sync feed" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                      </svg>
                    <% end %>
                    <%= link_to toggle_podcast_feed_entertainment_path(feed),
                        data: { turbo_method: :patch },
                        class: "inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500",
                        title: feed.active? ? "Deactivate" : "Activate" do %>
                      <% if feed.active? %>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      <% else %>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h8m-9-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      <% end %>
                    <% end %>
                    <%= link_to delete_podcast_feed_entertainment_path(feed), 
                        data: { 
                          turbo_method: :delete,
                          turbo_confirm: "Are you sure you want to delete this podcast feed?"
                        },
                        class: "inline-flex items-center p-2 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500",
                        title: "Delete feed" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </div>
                <div class="mt-3 flex items-center space-x-4 text-xs text-gray-500 dark:text-gray-400">
                  <span>📡 <%= feed.domain %></span>
                  <% if feed.website_url.present? %>
                    <a href="<%= feed.website_url %>" target="_blank" class="text-purple-600 hover:text-purple-500">🌐 Website</a>
                  <% end %>
                  <a href="<%= feed.feed_url %>" target="_blank" class="text-purple-600 hover:text-purple-500">🔗 RSS Feed</a>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 016 0v6a3 3 0 01-3 3z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No podcast feeds</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by uploading an OPML file or adding a feed URL.</p>
      </div>
    <% end %>

  </div>
</div>
