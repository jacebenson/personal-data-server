<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <%= render 'shared/breadcrumb', breadcrumbs: [
        { name: "Home", path: root_path },
        { name: "Entertainment", path: entertainment_index_path },
        { name: "Netflix Viewing", path: view_netflix_entertainment_index_path }
      ] %>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📺 Netflix Viewing History</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        <% if @search.present? %>
          Search results for "<%= @search %>" - <%= pluralize(@total_count, 'title') %> found
          <% if @filter_year.present? %>
            in <%= @filter_year %>
          <% end %>
        <% else %>
          Your complete Netflix viewing activity
          <% if @filter_year.present? %>
            for <%= @filter_year %>
          <% end %>
        <% end %>
      </p>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 0v16l4-4 4 4V4M7 4H5a1 1 0 00-1 1v14a1 1 0 001 1h2"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Items</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Est. Watch Time</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @total_hours_watched %> hours</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Years Available</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @years_available.length %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">This Page</dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white"><%= @netflix_records.count %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Search & Filters</h3>
        <%= form_tag view_netflix_entertainment_index_path, method: :get, local: true, class: "space-y-4" do %>
          <!-- Search Field -->
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-1">
              <%= text_field_tag :search, 
                  @search,
                  placeholder: "Search Netflix titles... (Press '/' to focus)",
                  class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-red-500 focus:ring-red-500",
                  id: "netflix_search" %>
            </div>
            <div class="flex gap-2">
              <%= submit_tag "Search", 
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
              <% if @search.present? %>
                <%= link_to "Clear", view_netflix_entertainment_index_path(filter_year: @filter_year),
                    class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
              <% end %>
            </div>
          </div>
          <!-- Search Results Info -->
          <% if params[:search].present? %>
            <div class="text-sm text-gray-600 dark:text-gray-400">
              Showing results for "<%= params[:search] %>" - <%= pluralize(@total_count, 'title') %> found
            </div>
          <% end %>
          <!-- Year Filter -->
          <div class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-0">
              <%= select_tag :filter_year, 
                  options_for_select([["All Years", ""]] + @years_available.map { |year| [year, year] }, @filter_year),
                  class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-red-500 focus:ring-red-500",
                  onchange: "this.form.submit();" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Netflix Records Table -->
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">
            Netflix Viewing Records
            <% if @filter_year.present? || @search.present? %>
              <span class="text-sm font-normal text-gray-500 dark:text-gray-400">
                <% if @search.present? %>
                  - Results for "<%= @search %>"
                <% end %>
                <% if @filter_year.present? %>
                  - <%= @filter_year %>
                <% end %>
              </span>
            <% end %>
          </h3>
          <div class="space-x-3">
            <%= link_to "Upload More Data", netflix_entertainment_index_path, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
          </div>
        </div>

        <% if @netflix_records.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-900">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Title</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date Watched</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <% @netflix_records.each do |record| %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm font-medium text-gray-900 dark:text-white"><%= record.title %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900 dark:text-white"><%= record.formatted_date_consumed %></div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <% if @total_pages > 1 %>
            <div class="flex items-center justify-between border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-3 sm:px-6 mt-4">
              <div class="flex flex-1 justify-between sm:hidden">
                <% if @has_prev %>
                  <%= link_to "Previous", view_netflix_entertainment_index_path(page: @current_page - 1, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
                <% end %>
                <% if @has_next %>
                  <%= link_to "Next", view_netflix_entertainment_index_path(page: @current_page + 1, filter_year: @filter_year, search: @search), class: "relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
                <% end %>
              </div>
              <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm text-gray-700 dark:text-gray-300">
                    Showing page <span class="font-medium"><%= @current_page %></span> of <span class="font-medium"><%= @total_pages %></span>
                    (<span class="font-medium"><%= @total_count %></span> total records)
                  </p>
                </div>
                <div>
                  <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                    <% if @has_prev %>
                      <%= link_to view_netflix_entertainment_index_path(page: @current_page - 1, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-none focus:ring-2 focus:ring-red-500" do %>
                        <span class="sr-only">Previous</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    <% end %>

                    <!-- Page numbers (show a few around current page) -->
                    <% start_page = [@current_page - 2, 1].max %>
                    <% end_page = [start_page + 4, @total_pages].min %>
                    <% start_page = [end_page - 4, 1].max %>

                    <% (start_page..end_page).each do |page| %>
                      <% if page == @current_page %>
                        <span class="relative z-10 inline-flex items-center bg-red-600 px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"><%= page %></span>
                      <% else %>
                        <%= link_to page, view_netflix_entertainment_index_path(page: page, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-none focus:ring-2 focus:ring-red-500" %>
                      <% end %>
                    <% end %>

                    <% if @has_next %>
                      <%= link_to view_netflix_entertainment_index_path(page: @current_page + 1, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-none focus:ring-2 focus:ring-red-500" do %>
                        <span class="sr-only">Next</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    <% end %>
                  </nav>
                </div>
              </div>
            </div>
          <% end %>

        <% else %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No Netflix records found</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by uploading your Netflix viewing data.</p>
            <div class="mt-6">
              <%= link_to "Upload Netflix Data", netflix_entertainment_index_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>

<script>
  // Focus search field when '/' is pressed
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      document.getElementById('netflix_search').focus();
    }
  });
</script>
