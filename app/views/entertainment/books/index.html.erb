<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">📚 Goodreads Library</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Your imported reading data from Goodreads</p>
    </div>

    <!-- Statistics Summary -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg mb-8">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">📊 Reading Statistics</h3>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          <div class="text-center">
            <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= number_with_delimiter(@shelf_counts['read']) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Books Read</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= number_with_delimiter(@shelf_counts['currently-reading']) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Currently Reading</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-orange-600 dark:text-orange-400"><%= number_with_delimiter(@shelf_counts['to-read']) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Want to Read</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-purple-600 dark:text-purple-400"><%= number_with_delimiter(@books_read_this_year) %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Read This Year</p>
          </div>
          <div class="text-center">
            <% if @average_rating > 0 %>
              <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400"><%= number_with_precision(@average_rating, precision: 1) %>/5</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Avg Rating</p>
            <% else %>
              <p class="text-lg font-bold text-gray-400">-</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Avg Rating</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Actions -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg mb-8">
      <div class="p-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
          <!-- Filters -->
          <div class="flex flex-wrap gap-4">
            <!-- Shelf Filter -->
            <div>
              <%= form_with url: entertainment_books_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
                <%= form.hidden_field :filter_year, value: @filter_year %>
                <%= form.hidden_field :search, value: @search %>
                <%= form.select :filter,
                    options_for_select([
                      ["All Shelves", ""],
                      ["Read", "read"],
                      ["Currently Reading", "currently-reading"],
                      ["Want to Read", "to-read"]
                    ], @filter),
                    {},
                    { class: "px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-green-500 focus:border-green-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", onchange: "this.form.submit();" } %>
              <% end %>
            </div>

            <!-- Year Filter -->
            <% if @years_available.any? %>
              <div>
                <%= form_with url: entertainment_books_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
                  <%= form.hidden_field :filter, value: @filter %>
                  <%= form.hidden_field :search, value: @search %>
                  <%= form.select :filter_year,
                      options_from_collection_for_select(@years_available.map { |y| [y, y] }, :last, :first, @filter_year),
                      { prompt: "All Years" },
                      { class: "px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-green-500 focus:border-green-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", onchange: "this.form.submit();" } %>
                <% end %>
              </div>
            <% end %>

            <!-- Search -->
            <div>
              <%= form_with url: entertainment_books_path, method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
                <%= form.hidden_field :filter, value: @filter %>
                <%= form.hidden_field :filter_year, value: @filter_year %>
                <%= form.text_field :search, value: @search, placeholder: "Search books or authors...", 
                    class: "px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-green-500 focus:border-green-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400" %>
                <%= form.submit "Search", class: "px-3 py-2 bg-green-600 text-white text-sm rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500" %>
              <% end %>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex space-x-2">
            <button onclick="document.getElementById('upload-section').scrollIntoView(); document.getElementById('upload-section').classList.toggle('hidden')" 
                class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600">
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              Upload More
            </button>

            <% if @total_count > 0 %>
              <%= link_to destroy_all_entertainment_books_path, 
                data: {
                  "turbo_method": :delete,
                  "turbo_confirm": "Are you sure you want to delete all #{number_with_delimiter(@total_count)} Goodreads records? This action cannot be undone."
                },
                class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-gray-700 dark:text-red-300 dark:border-red-600 dark:hover:bg-red-900/20" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Clear All
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Books List -->
    <% if @goodreads_records.any? %>
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
        <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @goodreads_records.each do |book| %>
            <li class="px-6 py-4">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center">
                    <% case book.exclusive_shelf %>
                    <% when "read" %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 mr-3">
                        Read
                      </span>
                    <% when "currently-reading" %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 mr-3">
                        Reading
                      </span>
                    <% when "to-read" %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 mr-3">
                        Want to Read
                      </span>
                    <% end %>
                    
                    <div class="flex-1">
                      <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                        <%= book.title %>
                      </p>
                      <p class="text-sm text-gray-500 dark:text-gray-400 truncate">
                        by <%= book.author %>
                      </p>
                    </div>
                  </div>
                  
                  <div class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-400">
                    <% if book.my_rating && book.my_rating > 0 %>
                      <div class="flex items-center mr-4">
                        <% book.my_rating.times do %>
                          <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                        <% end %>
                        <% (5 - book.my_rating).times do %>
                          <svg class="h-4 w-4 text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                        <% end %>
                        <span class="ml-1"><%= book.my_rating %>/5</span>
                      </div>
                    <% end %>

                    <% if book.date_read %>
                      <span class="mr-4">Read: <%= book.date_read.strftime("%b %d, %Y") %></span>
                    <% end %>

                    <% if book.number_of_pages && book.number_of_pages > 0 %>
                      <span class="mr-4"><%= number_with_delimiter(book.number_of_pages) %> pages</span>
                    <% end %>

                    <% if book.year_published && book.year_published > 0 %>
                      <span>Published <%= book.year_published %></span>
                    <% end %>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Pagination -->
      <% if @total_pages > 1 %>
        <div class="bg-white dark:bg-gray-800 px-4 py-3 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 sm:px-6 mt-0">
          <div class="flex-1 flex justify-between sm:hidden">
            <% if @has_prev %>
              <%= link_to entertainment_books_path(page: @current_page - 1, filter: @filter, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                Previous
              <% end %>
            <% end %>
            <% if @has_next %>
              <%= link_to entertainment_books_path(page: @current_page + 1, filter: @filter, filter_year: @filter_year, search: @search), class: "ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
                Next
              <% end %>
            <% end %>
          </div>
          <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Showing
                <span class="font-medium"><%= (@current_page - 1) * 50 + 1 %></span>
                to
                <span class="font-medium"><%= [@current_page * 50, @total_count].min %></span>
                of
                <span class="font-medium"><%= number_with_delimiter(@total_count) %></span>
                books
              </p>
            </div>
            <div>
              <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <% if @has_prev %>
                  <%= link_to entertainment_books_path(page: @current_page - 1, filter: @filter, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Previous</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% end %>

                <% ([1, @current_page - 2].max..[[@current_page + 2, @total_pages].min, @total_pages].min).each do |page| %>
                  <% if page == @current_page %>
                    <span class="relative inline-flex items-center px-4 py-2 border border-green-500 bg-green-50 text-sm font-medium text-green-600 dark:bg-green-900 dark:text-green-200">
                      <%= page %>
                    </span>
                  <% else %>
                    <%= link_to entertainment_books_path(page: page, filter: @filter, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                      <%= page %>
                    <% end %>
                  <% end %>
                <% end %>

                <% if @has_next %>
                  <%= link_to entertainment_books_path(page: @current_page + 1, filter: @filter, filter_year: @filter_year, search: @search), class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600" do %>
                    <span class="sr-only">Next</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                <% end %>
              </nav>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No books found</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if @filter.present? || @search.present? %>
            Try adjusting your filters or search terms.
          <% else %>
            Get started by importing your Goodreads library.
          <% end %>
        </p>
        <div class="mt-6">
          <button onclick="document.getElementById('upload-section').scrollIntoView(); document.getElementById('upload-section').classList.toggle('hidden')" 
              class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Upload Goodreads Data
          </button>
        </div>
      </div>
    <% end %>

    <!-- Actions -->
    <div class="mt-8 flex justify-between">
      <button onclick="document.getElementById('upload-section').scrollIntoView(); document.getElementById('upload-section').classList.toggle('hidden')" 
          class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600">
        ← Upload Data
      </button>

      <%= link_to entertainment_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" do %>
        All Entertainment Data
      <% end %>
    </div>

    <!-- Upload Section (initially hidden) -->
    <div id="upload-section" class="mt-8 hidden">
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <div class="p-6">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">📚 Upload Goodreads Library Data</h2>
          
          <!-- Instructions -->
          <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">How to get your Goodreads library data:</h3>
                <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
                  <ol class="list-decimal list-inside space-y-1">
                    <li>Go to <a href="https://www.goodreads.com/review/import" target="_blank" class="underline">goodreads.com/review/import</a></li>
                    <li>Sign in to your Goodreads account</li>
                    <li>Click "Export Library" at the bottom of the page</li>
                    <li>Download the CSV file when it's ready</li>
                    <li>Upload the file below</li>
                  </ol>
                </div>
              </div>
            </div>
          </div>

          <!-- Upload Form -->
          <%= form_with url: upload_entertainment_books_path, multipart: true, local: true, class: "space-y-4" do |form| %>
            <div>
              <%= form.label :file, "Select Goodreads CSV file", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.file_field :file, 
                  accept: ".csv",
                  required: true,
                  class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
            </div>

            <div class="flex space-x-3">
              <%= form.submit "Upload Library Data", 
                  class: "px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500" %>
              
              <%= link_to "Clear All Goodreads Data", 
                  destroy_all_entertainment_books_path, 
                  method: :delete, 
                  confirm: "Are you sure you want to delete all Goodreads book data? This action cannot be undone.",
                  class: "px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
