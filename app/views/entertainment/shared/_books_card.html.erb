<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
  <div class="p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Books</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Goodreads reading data</p>
        <div class="mt-2 grid grid-cols-3 gap-3">
          <div>
            <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @books_read_count || 0 %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Read</p>
          </div>
          <div>
            <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @books_currently_reading_count || 0 %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Reading</p>
          </div>
          <div>
            <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @books_to_read_count || 0 %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">To Read</p>
          </div>
        </div>
        <div class="mt-2">
          <p class="text-xs text-gray-500 dark:text-gray-400">
            <% if (@books_read_count || 0) > 0 || (@books_currently_reading_count || 0) > 0 || (@books_to_read_count || 0) > 0 %>
              <% if @last_goodreads_upload %>
                Last upload: <%= @last_goodreads_upload.strftime("%B %d, %Y") %>
              <% else %>
                Data imported
              <% end %>
              <% if (@books_read_count || 0) > 0 && @average_rating && @average_rating > 0 %>
                • Avg rating: <%= number_with_precision(@average_rating, precision: 1) %>/5
              <% end %>
            <% else %>
              No data uploaded
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="mt-6 space-y-3">
      <div class="grid grid-cols-3 gap-2">
        <% if (@books_read_count || 0) > 0 %>
          <%= link_to "View Read", entertainment_books_path(filter: 'read'),
              class: "flex justify-center py-2 px-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        <% else %>
          <div class="flex justify-center py-2 px-2 border border-gray-200 dark:border-gray-700 rounded-md text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800">
            View Read
          </div>
        <% end %>
        <% if (@books_currently_reading_count || 0) > 0 %>
          <%= link_to "Reading", entertainment_books_path(filter: 'currently-reading'),
              class: "flex justify-center py-2 px-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        <% else %>
          <div class="flex justify-center py-2 px-2 border border-gray-200 dark:border-gray-700 rounded-md text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800">
            Reading
          </div>
        <% end %>
        <% if (@books_to_read_count || 0) > 0 %>
          <%= link_to "To Read", entertainment_books_path(filter: 'to-read'),
              class: "flex justify-center py-2 px-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        <% else %>
          <div class="flex justify-center py-2 px-2 border border-gray-200 dark:border-gray-700 rounded-md text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800">
            To Read
          </div>
        <% end %>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <%= link_to "Upload Goodreads", entertainment_books_path,
            class: "flex justify-center py-2 px-3 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        <%= link_to "View All Books", entertainment_books_path,
            class: "flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      </div>
      <% if (@books_read_count || 0) > 0 || (@books_currently_reading_count || 0) > 0 || (@books_to_read_count || 0) > 0 %>
        <%= link_to "Clear All Data", destroy_all_entertainment_books_path, method: :delete,
            confirm: "Are you sure you want to delete all Goodreads book records?",
            class: "w-full flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
    </div>
  </div>
</div>
