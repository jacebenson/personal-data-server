<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
  <div class="p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-red-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Streaming</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">YouTube & Netflix viewing</p>
        <div class="mt-2 grid grid-cols-2 gap-4">
          <div>
            <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @youtube_count || 0 %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">YouTube videos</p>
          </div>
          <div>
            <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @netflix_count || 0 %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Netflix shows</p>
          </div>
        </div>
        <div class="mt-2">
          <p class="text-xs text-gray-500 dark:text-gray-400">
            <% if (@youtube_count || 0) > 0 || (@netflix_count || 0) > 0 %>
              <% if @last_youtube_upload && @last_netflix_upload %>
                Last updates: YouTube <%= @last_youtube_upload.strftime("%b %d") %>, Netflix <%= @last_netflix_upload.strftime("%b %d") %>
              <% elsif @last_youtube_upload %>
                Last YouTube upload: <%= @last_youtube_upload.strftime("%B %d, %Y") %>
              <% elsif @last_netflix_upload %>
                Last Netflix upload: <%= @last_netflix_upload.strftime("%B %d, %Y") %>
              <% else %>
                No recent uploads
              <% end %>
            <% else %>
              No data uploaded
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="mt-6 space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <% if (@youtube_count || 0) > 0 %>
          <%= link_to "View YouTube", entertainment_youtube_index_path,
              class: "flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        <% else %>
          <div class="flex justify-center py-2 px-3 border border-gray-200 dark:border-gray-700 rounded-md text-sm font-medium text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800">
            View YouTube
          </div>
        <% end %>
        <% if (@netflix_count || 0) > 0 %>
          <%= link_to "View Netflix", entertainment_netflix_index_path,
              class: "flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
        <% else %>
          <div class="flex justify-center py-2 px-3 border border-gray-200 dark:border-gray-700 rounded-md text-sm font-medium text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800">
            View Netflix
          </div>
        <% end %>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <%= link_to "Upload YouTube", entertainment_youtube_index_path,
            class: "flex justify-center py-2 px-3 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        <%= link_to "Upload Netflix", entertainment_netflix_index_path,
            class: "flex justify-center py-2 px-3 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
      </div>
      <% if (@youtube_count || 0) > 0 || (@netflix_count || 0) > 0 %>
        <div class="grid grid-cols-2 gap-3">
          <% if (@youtube_count || 0) > 0 %>
            <%= link_to "Clear YouTube", destroy_all_entertainment_youtube_index_path, method: :delete,
                confirm: "Are you sure you want to delete all YouTube watch history records?",
                class: "flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
          <% end %>
          <% if (@netflix_count || 0) > 0 %>
            <%= link_to "Clear Netflix", destroy_all_entertainment_netflix_index_path, method: :delete,
                confirm: "Are you sure you want to delete all Netflix viewing records?",
                class: "flex justify-center py-2 px-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
