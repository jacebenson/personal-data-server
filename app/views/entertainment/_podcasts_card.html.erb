<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
  <div class="p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
        </svg>
      </div>
      <div class="ml-4 flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Podcasts</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Episodes tracked</p>
        <div class="mt-2">
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @podcast_episodes_count || 0 %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400">
            <% if (@podcast_episodes_count || 0) > 0 %>
              Last sync: <%= @last_podcast_sync&.strftime("%B %d, %Y") || "Never" %>
            <% else %>
              No episodes synced
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="mt-6 space-y-3">
      <% if (@podcast_episodes_count || 0) > 0 %>
        <%= link_to "View Episodes", all_episodes_entertainment_index_path,
            class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
      <%= link_to "Manage Podcasts", podcasts_entertainment_index_path,
          class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
      <% if (@podcast_feeds_count || 0) > 0 %>
        <%= link_to "Clear Podcast Feeds", clear_podcast_feeds_entertainment_index_path, method: :delete,
            confirm: "Are you sure you want to delete all podcast feeds?",
            class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <% end %>
    </div>
  </div>
</div>
