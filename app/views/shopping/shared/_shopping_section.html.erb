<!-- Shopping Category -->
<%= link_to shopping_path, class: "group block" do %>
    <div class="p-6">
      <div class="space-y-2">
        <div class="flex items-center text-sm">
          <span class="text-lg mr-2">📦</span>
          <span class="font-medium text-gray-900 dark:text-white privacy-sensitive">
            <%= current_user.amazon_orders.count %>
          </span>
          <span class="text-gray-600 dark:text-gray-300 ml-1">total orders</span>
        </div>
        <div class="flex items-center text-sm">
          <span class="text-lg mr-2">💰</span>
          <span class="font-medium text-gray-900 dark:text-white privacy-sensitive">
            $<%= number_with_delimiter(current_user.amazon_orders.sum('CAST(total_owed as DECIMAL)').round(0)) %>
          </span>
          <span class="text-gray-600 dark:text-gray-300 ml-1">spent</span>
        </div>
        <div class="flex items-center text-sm">
          <span class="text-lg mr-2">📅</span>
          <span class="font-medium text-gray-900 dark:text-white privacy-sensitive">
            <%= current_user.amazon_orders.where('order_date >= ?', Date.current.beginning_of_year).count %>
          </span>
          <span class="text-gray-600 dark:text-gray-300 ml-1">this year</span>
        </div>
      </div>
    </div>
<% end %>
