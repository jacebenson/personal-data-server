<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to data_uploads_path, class: "inline-flex items-center text-purple-600 hover:text-purple-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Data Uploads
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">👥 Contact Data Upload</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Import contacts from vCard files or zipped vCard collections</p>
    </div>

    <!-- Instructions -->
    <div class="mb-8">
      <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-blue-800 dark:text-blue-200">How to export your contacts:</h3>
            <div class="mt-2 text-sm text-blue-700 dark:text-blue-300">
              <ul class="list-disc list-inside space-y-1">
                <li><strong>Google Contacts:</strong> Go to contacts.google.com → Export → vCard format (.vcf)</li>
                <li><strong>Apple Contacts:</strong> Select contacts → File → Export → Export as vCards</li>
                <li><strong>Outlook:</strong> File → Open & Export → Import/Export → Export to a file → Comma Separated Values</li>
                <li><strong>iPhone:</strong> Settings → [Your Name] → iCloud → Contacts → Export vCard</li>
                <li><strong>Android:</strong> Contacts app → Settings → Export → Save to VCF file</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Form -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Upload vCard Files</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Upload individual .vcf files or .zip archives containing multiple vCard files</p>
      </div>
      <div class="p-6">
        <%= form_with url: upload_vcard_contacts_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
          <div>
            <%= form.label :file, "Select vCard File or ZIP Archive", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".vcf,.vcard,.zip",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 dark:file:bg-purple-900 dark:file:text-purple-300" %>
            </div>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              Supported formats: .vcf, .vcard files, or .zip archives containing vCard files
            </p>
          </div>

          <!-- Expected Format Info -->
          <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-md p-4">
            <h4 class="font-medium text-green-900 dark:text-green-200 mb-2">What data will be imported:</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-green-800 dark:text-green-300">
              <div>
                <h5 class="font-medium mb-1">Personal Information:</h5>
                <ul class="space-y-1">
                  <li>• Full name and display name</li>
                  <li>• Job title and organization</li>
                  <li>• Birthday and notes</li>
                  <li>• Categories and tags</li>
                </ul>
              </div>
              <div>
                <h5 class="font-medium mb-1">Contact Details:</h5>
                <ul class="space-y-1">
                  <li>• Email addresses (multiple)</li>
                  <li>• Phone numbers (multiple)</li>
                  <li>• Physical addresses</li>
                  <li>• Websites and social profiles</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Duplicate Handling Info -->
          <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-md p-3">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm text-yellow-800 dark:text-yellow-200">
                  <strong>Duplicate Detection:</strong> Contacts with the same UID will be skipped to prevent duplicates.
                  Existing contacts will not be overwritten.
                </p>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex space-x-3">
              <%= link_to "Back to Data Uploads", data_uploads_path,
                  class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
            </div>
            <%= form.submit "Upload Contacts",
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- LinkedIn Connections Upload -->
    <div class="mt-8 bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">🔗 Upload LinkedIn Connections</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Import your LinkedIn connections from your data export CSV file</p>
      </div>
      <div class="p-6">
        <%= form_with url: upload_linkedin_connections_contacts_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
          <div>
            <%= form.label :file, "Select LinkedIn Connections.csv File", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".csv",
                  required: true,
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900 dark:file:text-blue-300" %>
            </div>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              Upload the Connections.csv file from your LinkedIn data export
            </p>
          </div>

          <!-- LinkedIn Export Instructions -->
          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-md p-4">
            <h4 class="font-medium text-blue-900 dark:text-blue-200 mb-2">How to get your LinkedIn Connections data:</h4>
            <ol class="space-y-1 text-sm text-blue-800 dark:text-blue-300 list-decimal list-inside">
              <li>Go to LinkedIn → Settings & Privacy → Data Privacy</li>
              <li>Click "Get a copy of your data"</li>
              <li>Select "Connections" from the list</li>
              <li>Request archive and wait for email</li>
              <li>Download and extract the archive</li>
              <li>Upload the "Connections.csv" file here</li>
            </ol>
          </div>

          <!-- Expected LinkedIn Data Info -->
          <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-md p-4">
            <h4 class="font-medium text-green-900 dark:text-green-200 mb-2">LinkedIn data includes:</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-green-800 dark:text-green-300">
              <div>
                <ul class="space-y-1">
                  <li>• Contact names</li>
                  <li>• LinkedIn profile URLs</li>
                  <li>• Company information</li>
                </ul>
              </div>
              <div>
                <ul class="space-y-1">
                  <li>• Job titles/positions</li>
                  <li>• Email addresses (if shared)</li>
                  <li>• Connection dates</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-end">
            <%= form.submit "Import LinkedIn Connections",
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Quick Stats (if contacts exist) -->
    <% if current_user.contacts.any? %>
      <div class="mt-8">
        <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Current Contacts</h3>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="text-center">
                <p class="text-3xl font-bold text-purple-600 dark:text-purple-400"><%= current_user.contacts.count %></p>
                <p class="text-sm text-gray-500 dark:text-gray-400">Total Contacts</p>
              </div>
              <div class="text-center">
                <p class="text-3xl font-bold text-green-600 dark:text-green-400">
                  <%= current_user.contacts.where.not(organization: [nil, '']).count %>
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">With Organizations</p>
              </div>
              <div class="text-center">
                <p class="text-3xl font-bold text-blue-600 dark:text-blue-400">
                  <%= current_user.contacts.where.not(emails: [nil, '']).count %>
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">With Email</p>
              </div>
            </div>

            <div class="mt-6 space-y-3">
              <%= link_to "View All Contacts", contacts_path(show: true),
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
              <%= link_to "Find Duplicates", duplicates_contacts_path,
                  class: "w-full flex justify-center py-2 px-4 border border-yellow-300 dark:border-yellow-600 rounded-md shadow-sm text-sm font-medium text-yellow-700 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/20 hover:bg-yellow-100 dark:hover:bg-yellow-900/30" %>
              <%= link_to "Clear All Contacts", clear_contacts_path,
                  method: :delete,
                  data: { confirm: "Are you sure you want to delete all contacts? This action cannot be undone." },
                  class: "w-full flex justify-center py-2 px-4 border border-red-300 dark:border-red-600 rounded-md shadow-sm text-sm font-medium text-red-700 dark:text-red-400 bg-white dark:bg-gray-700 hover:bg-red-50 dark:hover:bg-red-900/20" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
