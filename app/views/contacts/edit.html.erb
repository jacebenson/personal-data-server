<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to contact_path(@contact), class: "inline-flex items-center text-purple-600 hover:text-purple-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Contact
      <% end %>

      <div class="mt-4">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Contact</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Update contact information</p>
      </div>
    </div>

    <!-- Error Messages -->
    <% if @contact.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-md p-4 mb-6">
        <div class="flex">
          <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
              There were some errors with your submission:
            </h3>
            <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
              <% @contact.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Edit Form -->
    <%= form_with model: @contact, local: true, class: "space-y-6" do |form| %>
      <!-- Basic Information -->
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Basic Information</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <%= form.label :given_name, "First Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :given_name, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :middle_name, "Middle Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :middle_name, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :family_name, "Last Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :family_name, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :display_name, "Display Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :display_name, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :nickname, "Nickname", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :nickname, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :birthday, "Birthday", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.date_field :birthday, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div>
              <%= form.label :name_prefix, "Name Prefix", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :name_prefix, placeholder: "Dr., Mr., Ms., etc.", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :name_suffix, "Name Suffix", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :name_suffix, placeholder: "Jr., Sr., III, etc.", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>
          </div>

          <div class="mt-4">
            <%= form.label :source, "Source", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">The original source or system this contact came from</p>
            <%= form.text_field :source, placeholder: "google, icloud, linkedin, manual, etc.", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
          </div>
        </div>
      </div>

      <!-- Organization Information -->
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Organization</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= form.label :organization, "Company/Organization", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :organization, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :job_title, "Job Title", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :job_title, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :department, "Department", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :department, class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Contact Information</h3>
          
          <div class="space-y-4">
            <div>
              <%= form.label :emails, "Email Addresses", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Separate multiple emails with commas</p>
              <%= form.text_area :emails, rows: 2, placeholder: "john@example.com, john.doe@company.com", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :phones, "Phone Numbers", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Separate multiple phone numbers with commas</p>
              <%= form.text_area :phones, rows: 2, placeholder: "+1-555-123-4567, +1-555-987-6543", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :address, "Address", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_area :address, rows: 3, placeholder: "123 Main St, City, State 12345", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :urls, "Websites", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Separate multiple URLs with commas or new lines</p>
              <%= form.text_area :urls, rows: 2, placeholder: "https://example.com, https://portfolio.com", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Social Media & Additional Info -->
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Additional Information</h3>
          
          <div class="space-y-4">
            <div>
              <%= form.label :social_profiles, "Social Media Profiles", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">One per line, format: Platform: URL</p>
              <%= form.text_area :social_profiles, rows: 3, placeholder: "LinkedIn: https://linkedin.com/in/username\nTwitter: https://twitter.com/username", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :categories, "Categories/Tags", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Separate with commas</p>
              <%= form.text_field :categories, placeholder: "friend, colleague, family", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :photo_url, "Photo URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.url_field :photo_url, placeholder: "https://example.com/photo.jpg", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>

            <div>
              <%= form.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_area :notes, rows: 4, placeholder: "Additional notes about this contact...", class: "mt-1 block w-full border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-purple-500 focus:border-purple-500 dark:bg-gray-700 dark:text-white" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex justify-between items-center">
        <div class="space-x-3">
          <%= form.submit "Update Contact", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700" %>
          <%= link_to "Cancel", contact_path(@contact), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" %>
        </div>
        
        <div>
          <%= link_to "Delete Contact", contact_path(@contact), method: :delete,
              data: { confirm: "Are you sure you want to delete this contact? This action cannot be undone." },
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
