<nav class="flex" aria-label="Breadcrumb">
  <ol class="flex items-center space-x-4">
    <% breadcrumbs.each_with_index do |crumb, index| %>
      <li>
        <% if index == 0 %>
          <%= link_to crumb[:name], crumb[:path], class: "text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
        <% elsif index == breadcrumbs.length - 1 %>
          <div class="flex items-center">
            <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-4 text-gray-900 dark:text-white"><%= crumb[:name] %></span>
          </div>
        <% else %>
          <div class="flex items-center">
            <svg class="flex-shrink-0 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <%= link_to crumb[:name], crumb[:path], class: "ml-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
