<!-- Today's Calendar Events Component -->
<div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
  <%= link_to calendars_path, class: "block" do %>
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="h-8 w-8 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mr-3">
            <span class="text-xl">📅</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">Today's Events</h3>
        </div>
        <svg class="h-5 w-5 text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </div>
    </div>
  <% end %>
  
  <div class="p-6">
    <div class="space-y-3">
      <% today_events = current_user.todays_events.limit(4) %>
      <% if today_events.any? %>
        <% today_events.each do |event| %>
          <div class="border-l-2 border-purple-200 dark:border-purple-700 pl-3">
            <%= link_to calendar_event_path(event), class: "block hover:bg-gray-50 dark:hover:bg-gray-700 rounded p-2 -m-2 transition-colors" do %>
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center">
                    <% if event.all_day? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 mr-2">
                        All Day
                      </span>
                    <% else %>
                      <span class="text-sm font-medium text-purple-600 dark:text-purple-400 mr-2">
                        <%= event.start_time.in_time_zone(current_user.user_timezone).strftime("%l:%M%p").downcase.strip %>
                      </span>
                    <% end %>
                    <% if event.recurring? %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200 mr-2">
                        ↻
                      </span>
                    <% end %>
                  </div>
                  
                  <p class="text-sm font-medium text-gray-900 dark:text-white mt-1 truncate">
                    <span class="privacy-sensitive">
                      <%= event.summary %>
                    </span>
                  </p>
                  
                  <% if event.location.present? %>
                    <div class="flex items-center mt-1">
                      <svg class="flex-shrink-0 mr-1 h-3 w-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <span class="text-xs text-gray-500 dark:text-gray-400 truncate">
                        <span class="privacy-sensitive">
                          <%= event.location %>
                        </span>
                      </span>
                    </div>
                  <% end %>
                  
                  <% if event.calendar_name.present? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 mt-1">
                      <%= event.calendar_name %>
                    </span>
                  <% end %>
                </div>
                
                <div class="flex-shrink-0 ml-2">
                  <% user_time_now = Time.current.in_time_zone(current_user.user_timezone) %>
                  <% if event.start_time.in_time_zone(current_user.user_timezone) > user_time_now %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                      Upcoming
                    </span>
                  <% elsif event.end_time && event.end_time.in_time_zone(current_user.user_timezone) > user_time_now %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                      Now
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                      Past
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        
        <% if current_user.todays_events.count > 4 %>
          <div class="pt-2 border-t border-gray-200 dark:border-gray-700">
            <%= link_to calendars_path(time_filter: "today"), class: "text-sm text-purple-600 dark:text-purple-400 hover:text-purple-500 dark:hover:text-purple-300 font-medium" do %>
              View all <%= current_user.todays_events.count %> events today →
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-4">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">No events scheduled for today</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Enjoy your free time!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
