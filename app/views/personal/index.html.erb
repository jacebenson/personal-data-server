<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <%= render 'shared/breadcrumb', breadcrumbs: [
      { name: "Home", path: root_path },
      { name: "Personal Data", path: nil }
    ] %>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">👤 Personal Data</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your personal information and digital footprint</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Communications (Email & Messages) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Communications</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">MBOX emails, LinkedIn, Discord messages</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= number_with_delimiter(@communications_count) %></p>
                <% if @communications_count > 0 %>
                  <div class="mt-1 text-xs text-gray-500 dark:text-gray-400 space-y-1">
                    <% if @email_messages_count > 0 %>
                      <div>📧 <%= number_with_delimiter(@email_messages_count) %> emails</div>
                    <% end %>
                    <% if @linkedin_messages_count > 0 %>
                      <div>💼 <%= number_with_delimiter(@linkedin_messages_count) %> LinkedIn messages</div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          <div class="mt-6 flex flex-col gap-2">

            <% if @communications_count > 0 %>
              <div>
                <%= link_to "View All Records", view_communications_data_uploads_path,
                    class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
              </div>
            <% end %>
            <div>
              <%= link_to "Upload New Communications", communications_data_uploads_path,
                  class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            </div>
            <!-- link to records is http://localhost:3000/data_uploads/view_communications -->
            <!-- hre's how i did it on finances page -->
            <!--
            -->
          </div>
        </div>
      </div>

      <!-- Contacts (VCards, LinkedIn) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Contacts</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">VCard files, LinkedIn connections</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-teal-600 dark:text-teal-400"><%= @contacts_count %></p>
                <% if @contacts_count > 0 %>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    Last upload: <%= current_user.contacts.maximum(:imported_at)&.strftime("%B %d, %Y") || "Unknown" %>
                  </p>
                <% else %>
                  <p class="text-xs text-gray-500 dark:text-gray-400">No contacts uploaded</p>
                <% end %>
              </div>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% if @contacts_count > 0 %>
              <%= link_to "View All Contacts", contacts_path(show: true),
                  class: "w-full flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
            <%= link_to "Upload Contacts", contacts_path,
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-teal-600 hover:bg-teal-700" %>
          </div>
        </div>
      </div>

      <!-- Calendars (iCal) -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div class="ml-4 flex-1">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">Calendar Data</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">iCal calendar exports</p>
              <div class="mt-2">
                <p class="text-2xl font-semibold text-purple-600 dark:text-purple-400"><%= number_with_delimiter(@calendar_events_count) %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Events imported</p>
              </div>
            </div>
          </div>
          <div class="mt-6">
            <%= link_to calendars_data_uploads_path, class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" do %>
              <% if @calendar_events_count > 0 %>
                View Calendar Events
              <% else %>
                Import Calendar Data
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
