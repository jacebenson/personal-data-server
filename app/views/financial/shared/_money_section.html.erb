<!-- Financial Data Category -->
<%= link_to financial_path, class: "group block" do %>

    <div class="p-6">
      <div class="space-y-3">
        <div>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">
            <span class="privacy-sensitive">$<%= number_with_delimiter((current_user.investments.sum(:amount) / 1000).round(0)) %>k</span> / <span class="privacy-sensitive">$1.2M</span>
          </p>
        </div>
        <div>
          <p class="text-lg font-semibold text-gray-900 dark:text-white">
            <span class="privacy-sensitive">$<%= number_with_delimiter(current_user.bank_statements.where(account: 'Ally Personal Checking').sum(:amount).round(0)) %></span> in your pocket
          </p>
        </div>
      </div>
    </div>
  
<% end %>
