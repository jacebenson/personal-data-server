<div class="mb-8">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Current Account Balances</h2>
  <% if @account_summaries.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @account_summaries.each do |account, data| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 <%= data[:net] >= 0 ? 'border-green-500' : 'border-red-500' %>">
          <div class="p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  <%= account.present? ? account : 'Unknown Account' %>
                </p>
                <p class="text-2xl font-bold <%= data[:net] >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                  $<%= number_with_delimiter('%.2f' % data[:net]) %>
                </p>
                <div class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                  <div class="flex items-center space-x-4">
                    <span class="text-green-600 dark:text-green-400">
                      +$<%= number_with_precision(data[:deposits], precision: 0, delimiter: ',') %>
                    </span>
                    <span class="text-red-600 dark:text-red-400">
                      -$<%= number_with_precision(data[:withdrawals], precision: 0, delimiter: ',') %>
                    </span>
                  </div>
                  <p class="mt-1">
                    <%= data[:count] %> transactions
                    <% if data[:latest_date] %>
                      • Last: <%= data[:latest_date].strftime('%m/%d/%y') %>
                    <% end %>
                  </p>
                </div>
              </div>
              <div class="p-3 rounded-full <%= data[:net] >= 0 ? 'bg-green-100 dark:bg-green-900' : 'bg-red-100 dark:bg-red-900' %>">
                <% if data[:net] >= 0 %>
                  <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                  </svg>
                <% else %>
                  <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-8">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No bank statements</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Upload your bank statements to see account balances.</p>
    </div>
  <% end %>
</div>
