<!-- Balance Adjustment Modal -->
<div id="balance-adjustment-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
  <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
    <div class="mt-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">Account Balance Adjustment</h3>
        <button type="button" id="close-modal" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <div class="mt-4">
        <%= form_with url: add_balance_adjustment_financial_index_path, method: :post, local: true, class: "space-y-4" do |form| %>
          <div>
            <label for="account_name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Account Name
            </label>
            <select name="account_name" id="account_name" required
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
              <option value="">Select an account...</option>
              <% @account_summaries.keys.each do |account| %>
                <option value="<%= account %>"><%= account %></option>
              <% end %>
            </select>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Choose the account to adjust the balance for
            </p>
          </div>

          <div>
            <label for="current_balance_display" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Current Balance (calculated)
            </label>
            <input type="text" id="current_balance_display" readonly
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-600 dark:text-white shadow-sm bg-gray-100"
                placeholder="Select an account first">
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              This shows the current calculated balance based on transactions
            </p>
          </div>

          <div>
            <label for="balance_amount" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Actual Account Balance
            </label>
            <input type="text" name="balance_amount" id="balance_amount" required
                placeholder="1234.56"
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Enter the actual balance from your bank statement or app
            </p>
          </div>

          <div>
            <label for="adjustment_date" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Balance Date
            </label>
            <input type="date" name="adjustment_date" id="adjustment_date" required
                value="<%= Date.current.strftime('%Y-%m-%d') %>"
                class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-green-500 focus:ring-green-500">
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Date as of which this balance is accurate
            </p>
          </div>

          <div class="flex items-center justify-end space-x-3 mt-6">
            <button type="button" id="cancel-modal"
                class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
              Cancel
            </button>
            <button type="submit"
                class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
              Add Adjustment
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
