<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <%= link_to data_uploads_path, class: "inline-flex items-center text-blue-600 hover:text-blue-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Data Uploads
      <% end %>

      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-white">Upload Bank Statements</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Upload a CSV file and map columns to database fields</p>
    </div>

    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">CSV File Upload & Column Mapping</h3>
      </div>

      <div class="p-6">
        <%= form_with url: upload_ally_bank_statements_data_uploads_path, multipart: true, local: true, class: "space-y-6", id: "ally-bank-statement-form" do |form| %>
          <div>
            <label for="file" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
              Select CSV File from Ally Bank
            </label>
            <div class="mt-1">
              <%= form.file_field :file,
                  accept: ".csv",
                  required: true,
                  id: "csv-file-input",
                  class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
            </div>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              Ally Bank CSV format expected: Date, Time, Amount, Type, Description
            </p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Account Name</label>
            <%= form.text_field :default_account,
                value: "Ally Savings",
                placeholder: "e.g., Ally Checking, Ally Savings",
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">This will be used as the account name for all transactions</p>
          </div>

          <!-- Hidden fields with hardcoded Ally bank column mapping -->
          <%= form.hidden_field :date_column, value: "Date" %>
          <%= form.hidden_field :time_column, value: " Time" %>
          <%= form.hidden_field :amount_column, value: " Amount" %>
          <%= form.hidden_field :description_column, value: " Description" %>
          <%= form.hidden_field :category_column, value: " Type" %>

          <div class="flex justify-end">
            <%= form.submit "Upload and Process",
                id: "submit-button",
                class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Example CSV Format -->
    <div class="mt-8 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-6">
      <h3 class="text-lg font-medium text-yellow-800 dark:text-yellow-200 mb-4">Ally Bank CSV Format</h3>
      <p class="text-sm text-yellow-700 dark:text-yellow-300 mb-4">
        This upload is configured for Ally Bank CSV files with this format:
      </p>
      <div class="bg-white dark:bg-gray-800 rounded border p-4">
        <code class="text-sm text-gray-800 dark:text-gray-200">
          Date, Time, Amount, Type, Description<br>
          2025-08-01,16:51:00,-3000.00,Withdrawal,Internet transfer to Spending account XXXXXX9540<br>
          2025-07-25,19:14:44,800.00,Deposit,Internet transfer from Spending account XXXXXX9540<br>
          2025-07-05,23:24:12,41.40,Deposit,Interest Paid
        </code>
      </div>
      <div class="mt-4 text-sm text-yellow-700 dark:text-yellow-300">
        <p>The system will automatically map:</p>
        <ul class="mt-2 space-y-1 ml-4">
          <li>• <strong>Date:</strong> "Date" column</li>
          <li>• <strong>Time:</strong> "Time" column (combined with date)</li>
          <li>• <strong>Amount:</strong> "Amount" column</li>
          <li>• <strong>Description:</strong> "Description" column</li>
          <li>• <strong>Category:</strong> "Type" column</li>
          <li>• <strong>Account:</strong> Whatever you specify above</li>
        </ul>
      </div>
    </div>
  </div>
</div>
