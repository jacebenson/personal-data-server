<section class="bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-800 dark:to-purple-800" id="get-started">
        <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
            <div class="mx-auto max-w-screen-md text-center">
                <h2 class="mb-4 text-4xl font-extrabold leading-tight text-white">Take Control of Your Data</h2>
                <p class="mb-6 font-light text-blue-100 md:text-lg lg:text-xl">Stop letting your personal data live in silos across dozens of platforms. Join the movement to centralize, analyze, and truly own your digital life.</p>
                
                <div class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
                    <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4">
                        <i class="fas fa-shield-alt text-3xl text-blue-200 mb-2"></i>
                        <h3 class="text-white font-semibold">Your Data, Your Control</h3>
                        <p class="text-blue-100 text-sm">No third-party access, no data selling</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4">
                        <i class="fas fa-chart-line text-3xl text-purple-200 mb-2"></i>
                        <h3 class="text-white font-semibold">Powerful Analytics</h3>
                        <p class="text-blue-100 text-sm">Discover patterns across your entire digital life</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4">
                        <i class="fas fa-link text-3xl text-blue-200 mb-2"></i>
                        <h3 class="text-white font-semibold">Connect Everything</h3>
                        <p class="text-blue-100 text-sm">Health, finance, entertainment in one place</p>
                    </div>
                </div>
                
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <%= link_to "Create Your Account", new_user_registration_path, class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-blue-600 bg-white rounded-lg hover:bg-gray-100 focus:ring-4 focus:ring-white/25 transition-all duration-200 shadow-lg" %>
                    <%= link_to "Log In to View Your Data", new_user_session_path, class: "inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-lg hover:bg-white hover:text-blue-600 focus:ring-4 focus:ring-white/25 transition-all duration-200" %>
                </div>
                
                <p class="mt-6 text-blue-100 text-sm">
                    <i class="fas fa-lock mr-1"></i>
                    Free to start • Self-hosted • Open source • Your privacy guaranteed
                </p>
            </div>
        </div>
    </section>