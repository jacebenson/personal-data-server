<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header with back button -->
    <div class="mb-6">
      <%= link_to view_communications_path, class: "inline-flex items-center text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Communications
      <% end %>
    </div>

    <!-- Email Message Card -->
    <div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg overflow-hidden">
      <!-- Email Header -->
      <div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 border-b border-gray-200 dark:border-gray-600">
        <div class="flex items-start justify-between">
          <div class="flex-1">
            <h1 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
              <%= @email_message.subject %>
            </h1>

            <!-- Sender Info -->
            <div class="flex items-center text-sm text-gray-600 dark:text-gray-300 mb-2">
              <span class="font-medium">From:</span>
              <span class="ml-2">
                <% if @email_message.sender_name.present? %>
                  <%= @email_message.sender_name %> &lt;<%= @email_message.sender_email %>&gt;
                <% else %>
                  <%= @email_message.sender_email %>
                <% end %>
              </span>
            </div>

            <!-- Recipients -->
            <% if @email_message.recipient_emails.present? %>
              <div class="flex items-start text-sm text-gray-600 dark:text-gray-300 mb-2">
                <span class="font-medium">To:</span>
                <span class="ml-2 break-all"><%= @email_message.recipient_emails %></span>
              </div>
            <% end %>

            <!-- Date and Folder -->
            <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              <span>
                <span class="font-medium">Date:</span>
                <%= @email_message.received_date.strftime("%B %d, %Y at %I:%M %p") %>
              </span>
              <span>
                <span class="font-medium">Folder:</span>
                <%= @email_message.folder %>
              </span>
              <% if @email_message.attachments_count > 0 %>
                <span>
                  <span class="font-medium">Attachments:</span>
                  <%= @email_message.attachments_count %>
                </span>
              <% end %>
            </div>
          </div>

          <!-- Message Info Badge -->
          <div class="flex flex-col items-end text-xs text-gray-500 dark:text-gray-400">
            <span class="bg-gray-100 dark:bg-gray-600 px-2 py-1 rounded mb-1">
              <%= number_to_human_size(@email_message.message_size) %>
            </span>
            <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded">
              <%= @email_message.content_type %>
            </span>
          </div>
        </div>
      </div>

      <!-- Email Content -->
      <div class="px-6 py-6">
        <div class="prose prose-sm max-w-none dark:prose-invert">
          <% if @email_message.content_type == "text/markdown" %>
            <!-- Render markdown as HTML -->
            <%= simple_format(@email_message.content, {}, wrapper_tag: "div") %>
          <% else %>
            <!-- Fallback for other content types -->
            <pre class="whitespace-pre-wrap font-sans text-sm bg-gray-50 dark:bg-gray-700 p-4 rounded"><%= @email_message.content %></pre>
          <% end %>
        </div>
      </div>

      <!-- Message Metadata Footer -->
      <div class="bg-gray-50 dark:bg-gray-700 px-6 py-3 border-t border-gray-200 dark:border-gray-600">
        <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
          <span>Message ID: <%= @email_message.message_id %></span>
          <span>Imported: <%= time_ago_in_words(@email_message.created_at) %> ago</span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-6 flex gap-3">
      <%= link_to view_communications_data_uploads_path,
          class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
        View All Messages
      <% end %>

      <% if @email_message.folder.present? %>
        <%= link_to view_communications_data_uploads_path(folder: @email_message.folder),
            class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
          </svg>
          View <%= @email_message.folder %> Folder
        <% end %>
      <% end %>
    </div>
  </div>
</div>
